{{ 'section-featured-product.min.css' | asset_url | stylesheet_tag }}
{{ 'template-product.min.css' | asset_url | stylesheet_tag }}

{%- assign product = all_products[section.settings.featured_product] -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

{% assign on_sale = false %}
{% if current_variant.compare_at_price > current_variant.price %}
  {% assign on_sale = true %}
{% endif %}

{% assign options_block = section.blocks | where: "type", "options" | first %}
{% assign trust_block = section.blocks | where: "type", "trust_badges" | first %}
{% assign hide_out_of_stock_variants = options_block.settings.hide_out_of_stock_variants %}

{% if section.settings.variant_style == "swatches" %}
	<safe-load-scripts class="hidden">
		<script src="{{ 'component-product-swatch.js' | asset_url }}" defer="defer" type="module" data-flow-load-key="product-swatch"></script>
	</safe-load-scripts>
{% endif %}

<safe-load-scripts class="hidden">
  <script src="{{ 'component-product-details.js' | asset_url }}" defer="defer" type="module" data-flow-load-key="product-form-information"></script>
</safe-load-scripts>

{% liquid
  comment 
    Check for combined listings
  endcomment

  assign is_combined_listing = false
  for option in product.options_with_values
    for value in option.values
      if value.product_url != blank
        assign is_combined_listing = true
        break
      endif
    endfor
  endfor

  if settings.show_currency_code
    assign variant_compare_at_price = current_variant.compare_at_price | money_with_currency
  else
    assign variant_compare_at_price = current_variant.compare_at_price | money
  endif

  assign product_form_id = 'featured-product-form-' | append: section.id | append: '-' | append: product.id

  comment
    Desktop media width
  endcomment
  case section.settings.image_size
    when 'small'
      assign product_description_width = 'large--seven-twelfths' 
      assign product_image_width = 'large--five-twelfths' 
    when 'medium'
      assign product_description_width = 'large--six-twelfths' 
      assign product_image_width = 'large--six-twelfths' 
    when 'large'
      assign product_description_width = 'large--five-twelfths' 
      assign product_image_width = 'large--seven-twelfths' 
  endcase

  comment
    Desktop media style
  endcomment
  assign desktop_media_style = section.settings.image-display
  
  if product.media.size == 1
    comment 
      No thumbnails 
    endcomment
    assign desktop_media_style = 'grid'
  endif

  comment
    Mobile media style
  endcomment
  assign mobile_media_style = section.settings.image_display_mobile

  comment
    Login to order
  endcomment

  assign login_to_order = false

  if settings.login_to_order and customer == blank
    for tag in product.tags
      assign formatted_tag = tag | downcase | replace: ' ', ''
      if formatted_tag == 'b2b' or formatted_tag == 'wholesale'
        assign login_to_order = true
        break
      endif
    endfor
  endif
%}

{% if section.settings.show_add_to_cart and section.settings.override_button_colors %}
  {% assign button_id = 'featured-product-atc-' | append: section.id %}
  {% render 'button-color-overrides',
    id: button_id,
    style: 'filled',
    text_color: section.settings.button_text_color,
    background_color: section.settings.button_background_color
  %}
  <style>
    .dynamic-section-button--{{ button_id }}--dynamic .shopify-payment-button__button--unbranded {
      color: {{ button_text_color }} !important;
      background-color: {{ button_background_color }} !important;
    }
    product-form .paymentButtonsWrapper .dynamic-section-button--{{ button_id }}--dynamic .shopify-payment-button__button.shopify-payment-button__button--unbranded:hover {
      color: {{ button_text_color }} !important;  
      background-color: {{ button_background_color }} !important;
    }
  </style>
{% endif %}

<div
  class="wrapper-spacing--v wrapper-spacing--h product-section color-scheme--{{ section.settings.color_scheme }}{% if request.visual_preview_mode %} section-preview{% else %} show-on-scroll{% endif %}"
  style="--padding-section-top: {{ section.settings.section_padding_top }}px; --padding-section-bottom: {{ section.settings.section_padding_bottom }}px;"
>

  <div 
    class="width--content product-single" 
    data-wetheme-section-type="featured-product" 
    data-section-id="{{ section.id }}" 
    data-product-content-wrapper
  >

    {% liquid 
      assign show_only_variant_media = section.settings.show_only_variant_media
      assign media_sources = product.media | map: 'src'
      assign variant_images = product.images | where: 'attached_to_variant?', true
      assign variant_image_positions = variant_images | map: 'position'

      if product.has_only_default_variant or variant_images.size == 0
        assign show_only_variant_media = false
      endif

      # puts the first-image positions in ascending order
      assign variant_first_positions = variant_image_positions | sort

      # position of the variant the shopper is currently looking at
      assign start_index = product.selected_or_first_available_variant.featured_media.position

      # default: assume this variant runs right to the end of the list
      assign end_index = product.media.size

      # walk the list to find the *next* first-image position
      for pos in variant_first_positions
        if pos > start_index
          assign end_index = pos | minus: 1
          break
        endif
      endfor

      if show_only_variant_media and variant_images.size > 0
        assign media_sources = ''
        for media in product.media
          unless media.position < start_index or media.position > end_index
            assign media_sources = media_sources | append: media.src
          endunless
        endfor
      endif
    %}

    {% comment %} Section title and description {% endcomment %}
    {% render 'dynamic-section-header', section_title: section.settings.title, section_description: section.settings.description, alignment: section.settings.section_header_alignment %}

    {% capture all_media %}
      {% comment %} ============ PRODUCT MEDIA ============ {% endcomment %}
      <div data-product-media-wrapper data-media-sources="{{ media_sources }}" class="{{ product_image_width }} product-images{% if section.settings.enable_sticky %} product-sticky{% endif %}">
        {% comment %} ==== DESKTOP MEDIA ==== {% endcomment %}
        {% liquid 
          assign media_type = desktop_media_style
          assign has_pagination = false
          if desktop_media_style == 'paginated'
            assign has_pagination = true
          endif
        %}

        {% assign productMediaDesktopId = 'productMediaDesktop-' | append: section.id %}
        {% assign productMediaMobileId = 'productMediaMobile-' | append: section.id %}
        {% if request.visual_preview_mode %}
          {% assign productMediaDesktopId = 'productMediaDesktop-' | append: 'section-preview-desktop' %}
          {% assign productMediaMobileId = 'productMediaMobile-' | append: 'section-preview-mobile' %}
        {% endif %}

        {% if desktop_media_style == 'grid' %}
          {% comment %} GRID {% endcomment %} 
          {% render 'product-media-grid', product: product, section: section, type: media_type, onboarding: true %}
        {% else %}
          {% comment %} THUMBNAILS / SLIDER {% endcomment %}
          {% render 'product-media', id: productMediaDesktopId, product: product, section: section, device: 'desktop', type: media_type, has_pagination: has_pagination, onboarding: true, hide_out_of_stock_variants: section.settings.hide_out_of_stock_variants %}
        {% endif %}

        {% comment %} ==== MOBILE MEDIA ==== {% endcomment %}
        {% comment %} PAGINATED / SLIDER {% endcomment %}
        {% liquid 
          assign media_type = mobile_media_style
          assign has_pagination = false
          assign peep_enabled = false
          if mobile_media_style == 'paginated'
            assign has_pagination = true
          endif

          if mobile_media_style == 'slider' and product.media.size != 1
            assign peep_enabled = true
          endif
        %}

        {% render 'product-media', id: productMediaMobileId, product: product, section: section, device: 'mobile', type: media_type, has_pagination: has_pagination, enable_peep: peep_enabled, onboarding: true, hide_out_of_stock_variants: section.settings.hide_out_of_stock_variants %}
      </div>
    {% endcapture %}

    {% liquid 
      assign wrap_product = false
      if settings.giftwrap_product_selector != blank
        assign wrap_product = all_products[settings.giftwrap_product_selector]
      endif
    %}

    <div class="featured-product-form image-position-{{ section.settings.image-placement }}{% if section.settings.enable_sticky %} product-sticky-wrapper{% endif %}" id="product-box" data-section-id="{{ section.id }}">
      {% comment %} ============ PRODUCT MEDIA (LEFT) ============ {% endcomment %}
      {{ all_media }}

      {% comment %} ============ PRODUCT INFORMATION ============ {% endcomment %}
      <product-details
        data-url="{{ product.url }}"
        data-enable-url-update="false"
        data-section-id="{{ section.id }}"
        data-original-section-id="{{ section.id }}"
        data-is-featured-product="true"
        data-is-combined-listing="{{ is_combined_listing }}"
        data-show-only-variant-media="{{ show_only_variant_media }}"
        data-gift-wrap-prop="{{ 'products.general.giftwrap_label' | t | escape }}"
        class="{{ product_description_width }}{% if section.settings.enable_sticky %} product-sticky{% endif %}"
      >
        {% if product != empty %}
          {% liquid
            assign first_column_blocks = ''
            for block in section.blocks
              if block.settings.block_position == 'first_column'
                assign first_column_blocks = first_column_blocks | append: block.id | append: ','
              endif
            endfor
            assign first_column_blocks = first_column_blocks | split: ',' | compact

            assign second_column_blocks = ''
            for block in section.blocks
              if block.settings.block_position == 'second_column'
                assign second_column_blocks = second_column_blocks | append: block.id | append: ','
              endif
            endfor
            assign second_column_blocks = second_column_blocks | split: ',' | compact

            assign full_width_primary = false
            if first_column_blocks.size > 0 and second_column_blocks.size == 0
              assign full_width_primary = true
            endif

            assign full_width_secondary = false
            if second_column_blocks.size > 0 and first_column_blocks.size == 0
              assign full_width_secondary = true
            endif
          %}

          {% comment %} ============ PRIMARY PRODUCT DETAILS (FIRST COLUMN) ============ {% endcomment %}
          {% render 'product-details-primary',
            product: product,
            section: section,
            current_variant: current_variant,
            login_to_order: login_to_order,
            on_sale: on_sale,
            variant_compare_at_price: variant_compare_at_price,
            hide_out_of_stock_variants: hide_out_of_stock_variants,
            options_block: options_block,
            trust_block: trust_block,
            wrap_product: wrap_product,
            full_width: full_width_primary,
            is_featured_product: true
          %}

          {% comment %} ============ SECONDARY PRODUCT DETAILS (SECOND COLUMN) ============ {% endcomment %}
          {% render 'product-details-secondary',
            product: product,
            section: section,
            current_variant: current_variant,
            login_to_order: login_to_order,
            on_sale: on_sale,
            variant_compare_at_price: variant_compare_at_price,
            hide_out_of_stock_variants: hide_out_of_stock_variants,
            options_block: options_block,
            trust_block: trust_block,
            wrap_product: wrap_product,
            full_width: full_width_secondary
          %}
        {% else %}
          {% comment %} ONBOARDING: Use the same block-based rendering with product: null {% endcomment %}
          {% liquid
            assign first_column_blocks = ''
            for block in section.blocks
              if block.settings.block_position == 'first_column'
                assign first_column_blocks = first_column_blocks | append: block.id | append: ','
              endif
            endfor
            assign first_column_blocks = first_column_blocks | split: ',' | compact

            assign second_column_blocks = ''
            for block in section.blocks
              if block.settings.block_position == 'second_column'
                assign second_column_blocks = second_column_blocks | append: block.id | append: ','
              endif
            endfor
            assign second_column_blocks = second_column_blocks | split: ',' | compact

            assign full_width_primary = false
            if first_column_blocks.size > 0 and second_column_blocks.size == 0
              assign full_width_primary = true
            endif

            assign full_width_secondary = false
            if second_column_blocks.size > 0 and first_column_blocks.size == 0
              assign full_width_secondary = true
            endif
          %}

          {% comment %} ============ PRIMARY PRODUCT DETAILS (FIRST COLUMN) - ONBOARDING ============ {% endcomment %}
          {% render 'product-details-primary',
            product: null,
            section: section,
            current_variant: null,
            login_to_order: false,
            on_sale: false,
            variant_compare_at_price: null,
            hide_out_of_stock_variants: false,
            options_block: options_block,
            trust_block: trust_block,
            wrap_product: null,
            full_width: full_width_primary,
            is_featured_product: true
          %}

          {% comment %} ============ SECONDARY PRODUCT DETAILS (SECOND COLUMN) - ONBOARDING ============ {% endcomment %}
          {% render 'product-details-secondary',
            product: null,
            section: section,
            current_variant: null,
            login_to_order: false,
            on_sale: false,
            variant_compare_at_price: null,
            hide_out_of_stock_variants: false,
            options_block: options_block,
            trust_block: trust_block,
            wrap_product: null,
            full_width: full_width_secondary
          %}
        {% endif %}
      </product-details>
    </div>
  </div>
</div>

{%- for block in section.blocks -%}
  {%- case block.type -%}
    {%- when 'image-offer' -%}
      <style>
        .image-offer-container--is-link:hover img {
          border-color: rgba({{ block.settings.hover_border_color.rgba }});
        }
      </style>
  {% endcase %}
{% endfor %}

{%- liquid
  if product.selected_or_first_available_variant.featured_media
    assign seo_media = product.selected_or_first_available_variant.featured_media
  else
    assign seo_media = product.featured_media
  endif
-%}

<script type="application/ld+json">
  {{ product | structured_data }}
</script>

{% schema %}
{
  "name": "t:sections.products--featured-product.name",
  "class": "homepage-section--indiv-product-wrapper featured-product-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:all.Featured_product_blocks_info"
    },
    {
      "type": "header",
      "content": "t:all.Heading"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:all.Heading",
      "default": "Featured product"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:all.Description"
    },
    {
      "type": "text_alignment",
      "id": "section_header_alignment",
      "label": "t:all.Alignment",
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:all.Product"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "t:all.Product"
    },
    {
      "type": "header",
      "content": "t:all.Media",
      "info": "t:all.Learn_more_about_media_typeshttps___help_shopify_com_en_manual_products_product_media"
    },
    {
      "type": "radio",
      "id": "image-placement",
      "label": "t:sections.products--featured-product.settings.image-placement.label",
      "options": [
        {
          "value": "left",
          "label": "t:all.Left"
        },
        {
          "value": "right",
          "label": "t:all.Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_size",
      "label": "t:all.Size",
      "info": "t:sections.template--product.settings.image_size.info",
      "options": [
        {
          "value": "small",
          "label": "t:all.Small"
        },
        {
          "value": "medium",
          "label": "t:all.Medium"
        },
        {
          "value": "large",
          "label": "t:all.Large"
        }
      ],
      "default": "large"
    },
    {
      "type": "select",
      "id": "image_shape",
      "label": "t:all.Shape",
      "options": [
        {
          "value": "original",
          "label": "t:all.Shape_options.original"
        },
        {
          "value": "square",
          "label": "t:all.Shape_options.square"
        },
        {
          "value": "tall",
          "label": "t:all.Shape_options.tall"
        },
        {
          "value": "wide",
          "label": "t:all.Shape_options.wide"
        },
        {
          "value": "adapt_to_first_image",
          "label": "t:all.Shape_options.adapt_to_first_image"
        }
      ],
      "default": "square"
    },
    {
      "type": "checkbox",
      "id": "show_only_variant_media",
      "label": "t:sections.template--product.settings.show_only_variant_media.label",
      "info": "t:sections.template--product.settings.show_only_variant_media.info",
      "default": false
    },
    {
      "type": "header",
      "content": "t:all.Desktop"
    },
    {
      "type": "radio",
      "id": "image-display",
      "label": "t:sections.template--product.settings.image-display.label",
      "options": [
        {
          "value": "grid",
          "label": "t:sections.template--product.settings.image-display.options.grid"
        },
        {
          "value": "thumbnails",
          "label": "t:sections.template--product.settings.image-display.options.thumbnails"
        },
        {
          "value": "paginated",
          "label": "t:sections.template--product.settings.image-display.options.paginated"
        }
      ],
      "default": "thumbnails"
    },
    {
      "type": "select",
      "id": "thumbnail_position",
      "label": "t:sections.template--product.settings.thumbnail_position.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.template--product.settings.thumbnail_position.options.left"
        },
        {
          "value": "right",
          "label": "t:sections.template--product.settings.thumbnail_position.options.right"
        }
      ],
      "default": "left",
      "visible_if": "{{ section.settings.image-display == 'thumbnails' }}"
    },
    {
      "type": "header",
      "content": "t:all.Mobile"
    },
    {
      "type": "radio",
      "id": "image_display_mobile",
      "label": "t:sections.template--product.settings.image_display_mobile.label",
      "options": [
        {
          "value": "slider",
          "label": "t:sections.template--product.settings.image_display_mobile.options.slider"
        },
        {
          "value": "thumbnails",
          "label": "t:sections.template--product.settings.image_display_mobile.options.thumbnails_below"
        },
        {
          "value": "paginated",
          "label": "t:sections.template--product.settings.image_display_mobile.options.paginated"
        }
      ],
      "default": "thumbnails"
    },
    {
      "type": "header",
      "content": "t:all.Video"
    },
    {
      "type": "checkbox",
      "id": "enable_video_loop",
      "label": "t:all.Enable_video_looping",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "t:all.Autoplay",
      "info": "t:all.Autoplay_info",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_video_controls",
      "label": "t:all.Show_video_controls",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.template--product.settings.product_form_layout.label"
    },
    {
      "type": "checkbox",
      "id": "show_divider_between_columns",
      "label": "t:sections.template--product.settings.product_form_layout.show_divider_between_columns",
      "info": "t:sections.template--product.settings.product_form_layout.divider_info",
      "default": false
    },
    {
      "type": "header",
      "content": "t:all.Product_form_blocks"
    },
    {
      "type": "checkbox",
      "id": "override_form_labels_size",
      "label": "t:all.Labels_font_override",
      "default": false
    },
    {
      "type": "range",
      "id": "labels_font_size",
      "label": "t:all.Font_size",
      "min": 16,
      "max": 24,
      "step": 1,
      "unit": "t:all.px",
      "default": 20,
      "visible_if": "{{ section.settings.override_form_labels_size }}"
    },
    {
      "type": "header",
      "content": "t:sections.template--product.settings.header-8.content"
    },
    {
      "type": "range",
      "id": "app_margin_bottom",
      "label": "t:all.Bottom_margin",
      "info": "t:sections.template--product.settings.app_margin_bottom.info",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "t:all.px",
      "default": 30
    },
    {
      "type": "header",
      "content": "t:all.Layout"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "t:sections.template--product.settings.enable_sticky.label",
      "default": true
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "t:all.Spacing_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "t:all.px",
      "default": 72
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "t:all.Spacing_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "t:all.px",
      "default": 72
    },
    {
      "type": "header",
      "content": "t:all.Color"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:all.Color_scheme",
      "default": "white",
      "options": [
        {
          "value": "white",
          "label": "t:all.Default"
        },
        {
          "value": "light",
          "label": "t:all.First"
        },
        {
          "value": "accent",
          "label": "t:all.Second"
        },
        {
          "value": "dark",
          "label": "t:all.Third"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "button",
      "name": "t:all.Button",
      "settings": [
        {
          "type": "header",
          "content": "t:all.Button"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:all.Link"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:all.Button_label",
          "default": "Additional information"
        },
        {
          "type": "checkbox",
          "id": "is_full_width",
          "label": "t:all.Full_width",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "open_in_new_tab",
          "label": "t:all.open_link_in_new_tab",
          "default": true
        },
        {
          "type": "header",
          "content": "t:all.Style"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "t:all.button_style",
          "default": "filled",
          "options": [
            {
              "value": "filled",
              "label": "t:all.Filled"
            },
            {
              "value": "outlined",
              "label": "t:all.Outlined"
            },
            {
              "value": "underlined",
              "label": "t:all.underlined"
            }
          ]
        },
        {
          "type": "checkbox",
          "id": "override_button_colors",
          "label": "t:all.Button_color_override",
          "default": false,
          "info": "t:all.Button_color_override_info"
        },
        {
          "type": "color",
          "id": "button_background_color",
          "label": "t:all.Primary_color",
          "default": "#E68819",
          "visible_if": "{{ block.settings.override_button_colors }}"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "t:all.Secondary_color",
          "default": "#FFFFFF",
          "info": "t:all.Secondary_button_color_info",
          "visible_if": "{{ block.settings.override_button_colors }}"
        },
