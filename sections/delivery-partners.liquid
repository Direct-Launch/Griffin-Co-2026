{{ 'section-delivery-partners.min.css' | asset_url | stylesheet_tag }}

{% liquid
  assign placeholder_classes = 'icon icon--placeholder icon--placeholder--subdued'
  if section.settings.section_width == 'content'
    assign placeholder_classes = placeholder_classes | append: ' block-radius'
  endif

  assign animation_offset = 2
  assign overlay_opacity = 100 | minus: section.settings.image_overlay_opacity
  assign overlay_color = 'color-mix(in srgb, rgba(' | append: section.settings.image_overlay_color.rgba | append: '), transparent ' | append: overlay_opacity | append: '%)'

  case section.settings.section_width
    when 'content'
      assign section_width = 'content'
    when 'full'
      assign section_width = 'full'
  endcase
%}

<div
  class="wrapper-spacing--v{% if section_width == 'content' %} wrapper-spacing--h{% endif %}{% if request.visual_preview_mode %} section-preview{% else %} show-on-scroll{% endif %}"
  data-wetheme-section-type="delivery-partners"
  data-wetheme-section-id="{{ section.id }}"
  style="--margin-section-top: {{ section.settings.section_margin_top }}px; --margin-section-bottom: {{ section.settings.section_margin_bottom }}px; --logo-max-width-desktop: {{ section.settings.logo_max_width_desktop }}px; --logo-max-width-mobile: {{ section.settings.logo_max_width_mobile }}px;"
>
  <div class="delivery-partners__grid {{ section.id }}{% if section_width == 'content' %} width--content block-radius-clip{% endif %}">
    <div class="delivery-partners__grid--background{% if settings.animations_enabled %} kb-enabled{% endif %}" style="--overlay-color: {{ overlay_color }};">

      {% for i in (1..2) %}
        {%- liquid
          capture device
            cycle 'desktop', 'mobile'
          endcapture
      
          assign image_setting = 'image_' | append: device
          assign height_setting = 'height_' | append: device
          assign original_image_class = 'delivery-partners__' | append: device | append: '-image--original'
          assign cropped_image_class = 'delivery-partners__' | append: device | append: '-image--cropped'
          assign background_image = section.settings[image_setting]
          if device == 'mobile' and section.settings.image_mobile == blank and section.settings.image_desktop
            assign background_image = section.settings.image_desktop
          endif
        -%}

        {% if section.settings[height_setting] == 'original' %}
          <div class="{{ original_image_class }}">
            {% if background_image %}
              {% render 'responsive-image', image: background_image, sizes: '100vw', loading: 'eager', allow_stretch: true %}
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: placeholder_classes | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"' }}
            {% endif %}
          </div>
        {% else %}
          <style>
            .{{ section.id }} {
              --height-{{ device }}: {{ section.settings[height_setting] }};
            }

            {% capture selector %}.{{ section.id }} .{{ cropped_image_class }} .delivery-partners__cropped-image{% endcapture %}
            {% render 'responsive-background-image', image: background_image, selector: selector, sizes: '2000, 4000' %}

            
          </style>
          <div class="{{ cropped_image_class }}">
            {% if background_image %}
              <div class="delivery-partners__cropped-image" role="img" aria-label="{{ background_image.alt | escape }}"></div>
            {% else %}
              <div class="delivery-partners__cropped-placeholder">
                {{ 'lifestyle-1' | placeholder_svg_tag: placeholder_classes | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"' }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="delivery-partners__grid--foreground{% unless section_width == 'full' %} wrapper-spacing--h--content{% else %} wrapper-spacing--h{% endunless %} delivery-partners__text--position-mobile-{{ section.settings.text_position_mobile }} delivery-partners__text--position-desktop-{{ section.settings.text_position_desktop }}">
      {% liquid
        assign caption_bg_transparent = false
        if section.settings.caption_bg_color == 'rgba(0, 0, 0, 0)' or section.settings.caption_bg_color == 'rgba(0,0,0,0)' or section.settings.caption_bg_color == 'none' or section.settings.caption_bg_color == 'transparent' or section.settings.caption_bg_color == ''
          assign caption_bg_transparent = true
        endif

        assign text_color = 'rgba(' | append: section.settings.text_color.rgba | append: ')'
        assign link_color = 'rgba(' | append: section.settings.text_color.rgba | append: ')'
        assign link_border_color = 'color-mix(in srgb, ' | append: text_color | append: ', transparent 50%)'
        assign text_color_transparent25 = 'color-mix(in srgb, ' | append: text_color | append: ', transparent 75%)'
      %}
      <div
        class="delivery-partners__caption delivery-partners__caption-{% if caption_bg_transparent %}transparent{% else %}solid{% endif %}-bg delivery-partners__caption--align-mobile-{{ section.settings.text_alignment_mobile }} delivery-partners__caption--align-desktop-{{ section.settings.text_alignment_desktop }} block-radius"
        style="background: rgba({{ section.settings.caption_bg_color.rgba }}); color: {{ text_color }}; --link-color: {{ link_color }}; --link-border-color: {{ link_border_color }}; --text-color-transparent25: {{ text_color_transparent25 }}; --caption-width-desktop: {{ section.settings.caption_width_desktop }}%;"
      >
        {% assign animation_order = 1 %}
        
        {% if section.settings.title != blank or section.settings.description != blank %}
          <div class="delivery-partners__header">
            {% if section.settings.title != blank %}
              <h3 class="delivery-partners__heading text-link-animated" data-animate data-animate-order="{{ animation_order }}">{{ section.settings.title }}</h3>
              {% assign animation_order = animation_order | plus: 1 %}
            {% endif %}
            
            {% if section.settings.description != blank %}
              <div class="delivery-partners__text text-link-animated richtext-block" data-animate data-animate-order="{{ animation_order }}">{{ section.settings.description }}</div>
              {% assign animation_order = animation_order | plus: 1 %}
            {% endif %}
          </div>
        {% endif %}

        <div class="delivery-partners__logos{% if section.settings.apply_text_color_to_logos %} delivery-partners__logos--match-color{% endif %}">
          {% for block in section.blocks %}

            {% liquid
              assign is_custom_logo = false
              if block.settings.custom_logo != blank
                assign is_custom_logo = true
              endif
            %}

            <div class="delivery-partners__logo-item{% unless is_custom_logo %}{% if block.settings.delivery_partner == 'skip' or block.settings.delivery_partner == 'menulog' %} delivery-partners__logo-item--reduce-width{% endif %}{% endunless %}" data-animate data-animate-order="{{ animation_order | plus: forloop.index0 }}" {{ block.shopify_attributes }}>

              {% if is_custom_logo %}

                {% assign aria_label = block.settings.custom_logo.alt %}
                {% capture block_logo %}
                  {% render 'responsive-image', image: block.settings.custom_logo, sizes: '400px' %}
                {% endcapture %}

              {% else %}

                {% case block.settings.delivery_partner %}
                  {% when 'uber_eats' %}
                    {% assign aria_label = 'Uber Eats' %}
                    {% capture block_logo %}
                      <svg xmlns="http://www.w3.org/2000/svg" aria-label="{{ aria_label }}" role="img" focusable="false" viewBox=".19 .25 367.46 61.175"><g fill="none"><path fill="#05c167" d="M194.32.25h40.87v10h-29.83v14.2h29v9.66h-29v14.44h29.83v10h-40.87zM348.06 59.6c12.53 0 19.59-6 19.59-14.24 0-5.87-4.18-10.25-12.93-12.15l-9.25-1.89c-5.37-1-7.06-2-7.06-4 0-2.59 2.59-4.18 7.36-4.18 5.17 0 9 1.39 10 6.17h10.84c-.59-9-7.06-14.94-20.18-14.94-11.34 0-19.3 4.68-19.3 13.75 0 6.27 4.38 10.35 13.83 12.34l10.34 2.39c4.08.8 5.17 1.9 5.17 3.59 0 2.69-3.08 4.38-8.06 4.38-6.26 0-9.84-1.39-11.23-6.17h-10.9c1.59 8.98 8.25 14.95 21.78 14.95zm-24.93-1.09H311.4c-7.36 0-11.44-4.58-11.44-10.36v-22.9h-8.25v-9.76H300V3.24h10.9v12.25h12.23v9.76H310.9v20.11c0 2.29 1.59 3.39 4.08 3.39h8.15zm-47-43v3.88a21.16 21.16 0 00-13.73-5 22.61 22.61 0 100 45.21 21.1 21.1 0 0013.73-5v3.89H287v-43zM263.3 50.16a13.15 13.15 0 1113-13.14 13 13 0 01-13.02 13.12z"/><path fill="#000" d="M170.06 23.56c-5.47 0-9.35 4.28-9.35 10.85v24.1h-8.35V16.09h8.25v5.18a11.19 11.19 0 019.94-5.48h3v7.77zM146.59 37.3c0-12.65-9-22.11-21.18-22.11a21.83 21.83 0 00-21.68 22.11c0 12.64 9.75 22.2 22.47 22.2a22.17 22.17 0 0018.3-9.06L138.44 46a14.78 14.78 0 01-12.24 6.17 14.22 14.22 0 01-14-12.14h34.41zm-34.21-3.89c1.49-6.47 6.66-10.85 12.93-10.85s11.43 4.38 12.83 10.85zm-35.1-18.22a21.12 21.12 0 00-15 6.27V.25h-8.35v58.26h8.25v-5.38A21.45 21.45 0 0077.3 59.5a22.16 22.16 0 100-44.31zm-.6 36.85A14.69 14.69 0 1191.3 37.4 14.58 14.58 0 0176.68 52zm-53.5-.4c8.06 0 14.32-6.18 14.32-15.44V.25h8.65v58.26H37.6V53a21.24 21.24 0 01-15.41 6.47c-12.43 0-22-9.06-22-22.8V.25H9v36c0 9.31 6 15.39 14.18 15.39z"/></g></svg>
                    {% endcapture %}
