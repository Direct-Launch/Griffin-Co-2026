h-44.529V8.251c0-2.509-2.509-3.764-3.764-3.764h-44.53c-2.509 0-3.762 2.511-3.762 3.764v248.677c0 2.508 2.509 3.762 3.762 3.762h44.53c2.508 0 3.764-2.51 3.764-3.762V157.52h44.529v99.408c0 2.508 2.509 3.762 3.762 3.762h44.529c2.51 0 3.765-2.51 3.765-3.762V8.251c0-1.253-1.255-3.764-3.765-3.764z"/></svg>
                    {% endcapture %}
                  {% when 'just_eat' %}
