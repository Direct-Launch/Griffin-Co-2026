{% layout none %}

{% liquid 
  assign swatch_filters = collection.filters | where: 'presentation', 'swatch'
  assign image_filters = collection.filters | where: 'presentation', 'image'
  assign collection_filters = swatch_filters | concat: image_filters
%}

{
  "collection": {{ collection.handle | json }},
  "filters": [
    {%- for filter in collection_filters -%}
      {%- if filter.presentation == 'swatch' or filter.presentation == 'image' -%}
        {
          "label": {{ filter.label | json }},
          "param_name": {{ filter.param_name | json }},
          "values": [
            {%- for v in filter.values -%}
              {
                "label": {{ v.label | json }},
                "value": {{ v.value | json }},
                "count": {{ v.count | json }},
                "url_to_add": {{ v.url_to_add | json }}
                {%- if v.swatch -%}
                  ,"swatch": {
                    "color": {{ v.swatch.color | json }},
                    "image": {{ v.swatch.image | json }}
                  }
                {%- elsif v.image -%}
                  ,"swatch": {
                    "image": {{ v.image | json }}
                  }
                {%- endif -%}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
