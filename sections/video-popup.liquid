          }
        ]
      },
      {
        "type": "select",
        "id": "size",
        "label": "t:all.Size",
        "default": "medium",
        "options": [
          {
            "value": "small",
            "label": "t:all.Small"
          },
          {
            "value": "medium",
            "label": "t:all.Medium"
          },
          {
            "value": "large",
            "label": "t:all.Large"
          }
        ]
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "t:all.Image",
        "info": "t:sections.video_popup.settings.widget.settings.image.info"
      },
      {
        "type": "header",
        "content": "t:sections.video_popup.settings.expanded_video.label"
      },
      {
        "type": "select",
        "id": "expanded_video_shape",
        "label": "t:all.Shape",
        "default": "circle",
        "options": [
          {
            "value": "square",
            "label": "t:all.Shape_options.square"
          },
          {
            "value": "tall",
            "label": "t:all.Shape_options.tall"
          },
          {
            "value": "wide",
            "label": "t:all.Shape_options.wide"
          },
          {
            "value": "circle",
            "label": "t:all.Shape_options.circle"
          }
        ]
      },
      {
        "type": "select",
        "id": "expanded_video_size",
        "label": "t:all.Size",
        "default": "medium",
        "options": [
          {
            "value": "small",
            "label": "t:all.Small"
          },
          {
            "value": "medium",
            "label": "t:all.Medium"
          },
          {
            "value": "large",
            "label": "t:all.Large"
          }
        ]
      },
      {
        "type": "header",
        "content": "t:sections.video_popup.settings.end_of_video.label"
      },
      {
        "type": "checkbox",
        "id": "enable_test_mode",
        "label": "t:sections.video_popup.settings.end_of_video.settings.enable_test_mode.label",
        "info": "t:sections.video_popup.settings.end_of_video.settings.enable_test_mode.info",
        "default": false
      },
      {
        "type": "paragraph",
        "content": "t:sections.video_popup.settings.end_of_video.settings.description"
      },
      {
        "type": "url",
        "id": "link",
        "label": "t:all.Link"
