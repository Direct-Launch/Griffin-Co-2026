        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "t:all.Required",
          "default": false
        },
        {
          "type": "select",
          "id": "input_width",
          "label": "t:all.Input_width",
          "options": [
            {
              "value": "partial",
              "label": "t:all.Partial"
            },
            {
              "value": "full",
              "label": "t:all.Full"
            }
          ],
          "default": "full"
        }
      ]
    },
    {
      "name": "t:sections.section--contact-form.blocks.radio_buttons.name",
      "type": "radio_buttons",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "label_text",
          "label": "t:all.Label",
          "default": "Radio buttons"
        },
        {
          "type": "inline_richtext",
          "id": "hint_text",
          "label": "t:all.hint_text",
          "info": "t:all.Optional"
        },
        {
          "type": "text",
          "id": "radio_options",
          "label": "t:sections.template--product.blocks.custom_radio_button.settings.options.label",
          "info": "t:sections.template--product.blocks.custom_radio_button.settings.options.info",
          "default": "Yes, No"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "t:all.Required",
          "default": false
        },
        {
          "type": "select",
          "id": "input_width",
          "label": "t:all.Input_width",
          "options": [
            {
              "value": "partial",
              "label": "t:all.Partial"
            },
            {
              "value": "full",
              "label": "t:all.Full"
            }
          ],
          "default": "full"
        }
      ]
    },
    {
      "name": "t:sections.section--contact-form.blocks.dropdown.name",
      "type": "dropdown",
      "settings": [
        {
          "type": "text",
          "id": "label_text",
          "label": "t:all.Label",
          "default": "Dropdown"
        },
        {
          "type": "inline_richtext",
          "id": "hint_text",
          "label": "t:all.hint_text",
          "info": "t:all.Optional"
        },
        {
          "type": "text",
          "id": "dropdown_options",
          "label": "t:sections.template--product.blocks.custom_dropdown.settings.options.label",
          "info": "t:sections.template--product.blocks.custom_dropdown.settings.options.info",
          "default": "Yes, No"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "t:all.Required",
          "default": false
        },
        {
          "type": "select",
          "id": "input_width",
          "label": "t:all.Input_width",
          "options": [
            {
              "value": "partial",
              "label": "t:all.Partial"
            },
            {
              "value": "full",
              "label": "t:all.Full"
            }
          ],
          "default": "full"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.section--contact-form.presets.name",
      "settings": {
      },
      "blocks": [
        {
          "type": "name_input",
          "settings": {
            "required": true,
            "input_width": "partial"
          }
        },
        {
          "type": "email_input",
          "settings": {
            "required": true,
            "input_width": "partial"
          }
        },
        {
          "type": "tel_input",
          "settings": {
            "required": true,
            "input_width": "full"
          }
        },
