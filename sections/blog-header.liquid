<div
  class="blog-header wrapper-spacing--v wrapper-spacing--h{% if request.visual_preview_mode %} section-preview{% else %} show-on-scroll{% endif %}"
  data-wetheme-section-type="blog-header"
  data-wetheme-section-id="{{ section.id }}"
  style="--padding-section-top: {{ section.settings.section_padding_top }}px; --padding-section-bottom: {{ section.settings.section_padding_bottom }}px;"
>
  <div class="width--content" style="text-align: center;">
    <h1 class="blog-header__title {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_mobile }}" style="margin: 0; text-align: {{ settings.template_heading_alignment }};">{{ blog.title }}</h1>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.blog-header.name",
  "limit": 1,
  "settings": [
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "t:all.heading_font_size",
      "default": "h3",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "select",
      "id": "heading_font_size_mobile",
      "label": "t:all.Heading_font_size_mobile",
      "default": "h3-mobile",
      "options": [
        { "value": "h1-mobile", "label": "H1" },
        { "value": "h2-mobile", "label": "H2" },
        { "value": "h3-mobile", "label": "H3" },
        { "value": "h4-mobile", "label": "H4" },
        { "value": "h5-mobile", "label": "H5" },
        { "value": "h6-mobile", "label": "H6" }
      ]
    },
    {
      "type": "header",
      "content": "t:all.Layout"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "t:all.Spacing_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "t:all.px",
      "default": 72
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "t:all.Spacing_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "t:all.px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "t:sections.blog-header.name"
    }
  ],
  "enabled_on": {
    "templates": [ "blog" ]
  }
}
{% endschema %}