{{ 'section-product-info-columns.min.css' | asset_url | stylesheet_tag }}
{{ 'section-content-grid.min.css' | asset_url | stylesheet_tag }}

{% liquid 
  assign layout_mobile = section.settings.layout_style_mobile | default: 'slider'
  assign disable_mobile_slider = false
  if layout_mobile == 'grid'
    assign disable_mobile_slider = true
  endif

  assign layout_desktop = section.settings.layout_style_desktop | default: 'slider'
  assign disable_desktop_slider = false
  if layout_desktop == 'grid'
    assign disable_desktop_slider = true
  endif
  
  assign columns_per_row_mobile = section.settings.columns_per_row_mobile | default: '1'

  assign justify_mobile = 'center'
  if section.settings.text_alignment_mobile == 'left'
    assign justify_mobile = 'flex-start'
  elsif section.settings.text_alignment_mobile == 'right'
    assign justify_mobile = 'flex-end'
  endif

  assign justify_desktop = 'center'
  if section.settings.text_alignment == 'left'
    assign justify_desktop = 'flex-start'
  elsif section.settings.text_alignment == 'right'
    assign justify_desktop = 'flex-end'
  endif

  assign has_slider = false
  if layout_desktop == 'slider' or layout_mobile == 'slider'
    assign has_slider = true
  endif
%}

{% style %}
  /* --- Separate Text & Element Alignments --- */
  .section-{{ section.id }} .info-cols--title,
  .section-{{ section.id }} .info-cols--text {
    text-align: {{ section.settings.text_alignment_mobile }} !important;
  }
  .section-{{ section.id }} .info-cols--link--wrapper {
    display: flex;
    justify-content: {{ justify_mobile }} !important;
  }

  @media (min-width: 768px) {
    .section-{{ section.id }} .info-cols--title,
    .section-{{ section.id }} .info-cols--text {
      text-align: {{ section.settings.text_alignment }} !important;
    }
    .section-{{ section.id }} .info-cols--link--wrapper {
      justify-content: {{ justify_desktop }} !important;
    }
  }

  /* --- Equal Height Slides --- */
  .section-{{ section.id }} .content-grid {
    align-items: stretch !important;
  }
  .section-{{ section.id }} .content-grid-item {
    height: auto !important;
    display: flex;
    flex-direction: column;
    box-sizing: border-box !important;
  }
  .section-{{ section.id }} .content-grid-item .info-cols--text {
    flex-grow: 1; /* Pushes the button neatly to the bottom */
  }

  /* --- Fix Mobile Text Visibility & Swipe Bug --- */
  @media (max-width: 767px) {
    /* Safe visibility override that doesn't break Swiper transform math */
    .section-{{ section.id }} .swiper-slide[data-animate] {
      opacity: 1 !important;
      visibility: visible !important;
      animation: none !important;
    }
  }
{% endstyle %}

{% assign grid_item_id = 'grid-item--' | append: section.id %}

{% if section.settings.override_button_colors %}
  {% render 'button-color-overrides',
    id: grid_item_id,
    style: section.settings.buttons_style,
    text_color: section.settings.button_text_color,
    background_color: section.settings.button_background_color
  %}
{% endif %}

{% assign radius_type = 'block' %}
{% if section.settings.maximum_width < 105 %}
  {% assign radius_type = 'thumbnail' %}
{% endif %}
{% if section.settings.override_border_radius %}
  {% assign radius_type = 'square' %}
{% endif %}
{% assign placeholder_classes = 'icon icon--placeholder ' | append: radius_type | append: '-radius' %}

{% liquid 
  case section.settings.section_width
    when 'content'
      assign section_width = 'content'
    when 'full'
      assign section_width = 'full'
  endcase

  assign background_matches = true
  if section.settings.colors != 'white'
    assign background_matches = false
  endif
%}

<safe-load-scripts class="hidden">
  <script src="{{ 'component-deferred-media.js' | asset_url }}" defer="defer" type="module" data-flow-load-key="deferred-media"></script>
</safe-load-scripts>

<safe-load-scripts class="hidden">
  <script src="{{ 'component-info-columns.js' | asset_url }}" defer="defer" type="module" data-flow-load-key="info-columns"></script>
</safe-load-scripts>

{% if has_slider %}
  <safe-load-scripts class="hidden">
    <script src="{{ 'component-content-grid-slider.js' | asset_url }}" defer="defer" type="module" data-flow-load-key="content-grid-slider"></script>
  </safe-load-scripts>
{% endif %}

<info-columns
  class="wrapper-spacing--v wrapper-spacing--h content-align--{{ section.settings.section_header_alignment }}{% if section_width == 'full' %} color-scheme--{{ section.settings.colors }}{% endif %} info-cols section-{{ section.id }}{% if request.visual_preview_mode %} section-preview{% else %} show-on-scroll{% endif %}{% if section.settings.slider_height_mobile == 'consistent' %} slider-height--consistent{% endif %}"
  data-wetheme-section-type="template--product--info-columns"
  data-wetheme-section-id="{{ section.id }}"
  data-slides-per-row="{{ section.settings.columns_per_row }}"
  data-grid-spacing="{{ settings.grid_spacing }}"
  data-slider-height-mobile="{{ section.settings.slider_height_mobile }}"
  style="
    --padding-section-top: {{ section.settings.section_padding_top }}px; 
    --padding-section-bottom: {{ section.settings.section_padding_bottom }}px;
    --columns-desktop: {{ section.settings.columns_per_row }};
    --columns-mobile: {{ columns_per_row_mobile }};
  "
>

  {% if section_width == 'content' %}
    <div class="width--content{% unless background_matches %} wrapper-spacing--v--content wrapper-spacing--h--content{% endunless %} color-scheme--{{ section.settings.colors }}">
  {% endif %}

    {% comment %} Section title and description {% endcomment %}
    {% render 'dynamic-section-header', section_title: section.settings.title, section_description: section.settings.description, alignment: section.settings.section_header_alignment %}

    <content-grid-slider
      class="info-cols__slider-wrapper block"
      data-grid-slider-wrapper
      data-section-id="{{ section.id }}"
      data-desktop-only="{{ disable_mobile_slider }}"
      data-mobile-only="{{ disable_desktop_slider }}"
      data-slides-per-view-mobile="{{ columns_per_row_mobile }}"
      data-slides-per-view-desktop="{{ section.settings.columns_per_row }}"
      data-peek-desktop-enabled="false"
      data-peek-mobile-enabled="{% if section.settings.navigation_mobile == 'peek' %}true{% else %}false{% endif %}"
      data-pagination-overlay-enabled="false"
      data-remove-spacing="false"
      data-grid-spacing-desktop="{{ settings.grid_spacing | default: 15 }}"
      data-grid-spacing-mobile="{{ settings.grid_spacing | default: 15 | times: 0.75 }}"
    >

      {% if section.blocks.size > section.settings.columns_per_row and disable_desktop_slider == false %}
        <!-- navigation -->
        {% assign navigation_id = 'navigation--' | append: section.id %}
        {% if section.settings.override_button_colors %}
          {% render 'button-color-overrides',
            id: navigation_id,
            style: 'filled',
            text_color: section.settings.button_text_color,
            background_color: section.settings.button_background_color
          %}
        {% endif %}
        
        <div class="swiper-btn--wrapper small-hide swiper-btn-layout__{{ section.settings.hover_navigation_desktop }}">
          <div class="swiper-button--prev btn dynamic-section-button--{{ navigation_id }}">
            {% render 'theme-icon', icon: 'arrow-left' %}
          </div>
          <div class="swiper-button--next btn dynamic-section-button--{{ navigation_id }}">
            {% render 'theme-icon', icon: 'arrow-right' %}
          </div>
        </div>
      {% endif %}

      <div class="content-grid__slider swiper{% if disable_mobile_slider %} disable-mobile{% endif %}{% if disable_desktop_slider %} disable-desktop{% endif %}" data-number-of-slides="{{ section.blocks.size }}" data-animate-overflow-container>
        <div class="content-grid{% if has_slider %} swiper-wrapper{% endif %} content-grid--desktop-{{ layout_desktop }} content-grid--mobile-{{ layout_mobile }} content-grid--gap vertical-align--{{ section.settings.vertical_alignment }}">
          {% for block in section.blocks %}

            <div
              class="content-grid-item grid__item{% if has_slider %} swiper-slide{% endif %} info-cols--{{ block.type }}-column info-block-{{ block.id }}" 
              {{ block.shopify_attributes }} 
              {% if has_slider %}data-content-grid-slide-index="{{ forloop.index0 }}"{% endif %}
              data-animate
              data-animate-order="{% render 'block-animation-offset', 
                title: section.settings.title, 
                description: section.settings.description, 
                base: forloop.index 
              %}"
              {% if has_slider %}data-animate-overflow-item{% endif %}
            >
              {% case block.type %}
                {% when 'image_and_text' %}

                  {% liquid 
                    assign has_content = true
                    if block.settings.heading == blank and block.settings.text == blank and block.settings.button_text == blank
                      assign has_content = false
                    endif
                  %}
                
                  {% if block.settings.button_link != blank %}
                    <a aria-label="{{ block.settings.heading }}" href="{{ block.settings.button_link }}" class="info-cols--image-is-link"><span class="sr-only">{{ block.settings.heading }}</span>
                  {% endif %}

                  <div 
                    class="info-cols--image info-cols--media info-cols--media__desktop-alignment--{{ section.settings.text_alignment }} info-cols--media__mobile-alignment--{{ section.settings.text_alignment_mobile }}{% if block.settings.grid_image_size != 'natural' %} info-cols--media__aspect-ratio--{{ block.settings.grid_image_size }}{% endif %}{% unless has_content %} info-cols--image__no-content{% endunless %}" 
                    aria-hidden="true"
                  >
                    {% if block.settings.image == blank %}
                      <div style="max-width: {{ section.settings.maximum_width }}px;width:100%;"{% unless block.settings.grid_image_size == 'circle' %} class="{{ radius_type }}-radius-clip"{% endunless %}{% if block.settings.button_link != blank %} data-animate-hover-zoom{% endif %}>
                        {{ 'image' | placeholder_svg_tag: placeholder_classes }}
                      </div>
                    {% else %}
                      <div style="max-width: {{ section.settings.maximum_width }}px;"{% unless block.settings.grid_image_size == 'circle' %} class="{{ radius_type }}-radius-clip"{% endunless %}{% if block.settings.button_link != blank %} data-animate-hover-zoom{% endif %}>
                        {% render 'responsive-image', image: block.settings.image, allow_stretch: true %}
                      </div>
                    {% endif %}
                  </div>

                  {% if block.settings.button_link != blank %}
                    </a>
                  {% endif %}

                  {% if block.settings.heading != '' %}
                    <h5 class="info-cols--title h5 h4-mobile">{{ block.settings.heading }}</h5>
                  {% endif %}

                  {% if block.settings.text != '' %}
                    <div class="info-cols--text text-link-animated">{{ block.settings.text }}</div>
                  {% endif %}

                  {% if block.settings.button_text != '' %}
                    {% render 'dynamic-section-button',
                      id: grid_item_id,
                      link: block.settings.button_link,
                      label: block.settings.button_text,
                      style: section.settings.buttons_style,
                      div_classes: 'info-cols--link--wrapper'
                    %}
                  {% endif %}

                {% when 'video_and_text' %}

                  {% liquid 
                    assign has_content = true
                    if block.settings.heading == blank and block.settings.text == blank and block.settings.button_text == blank
                      assign has_content = false
                    endif
                  %}

                  {% assign type = 'mp4' %}
                  {% unless block.settings.video %}
                    {% assign type = block.settings.video_url.type %}
                  {% endunless %}
                
                  {% if block.settings.button_link != blank %}
                    <a aria-label="{{ block.settings.heading }}" href="{{ block.settings.button_link }}" class="info-cols--image-is-link"><span class="sr-only">{{ block.settings.heading }}</span>
                  {% endif %}

                  <div class="info-cols--media info-cols--media__desktop-alignment--{{ section.settings.text_alignment }} info-cols--media__mobile-alignment--{{ section.settings.text_alignment_mobile }}">
                    <div 
                      class="info-cols--video-wrapper info-cols--media__aspect-ratio--{{ block.settings.grid_video_size }}{% unless block.settings.grid_video_size == 'circle' %} {{ radius_type }}-radius-clip{% endunless %}"
                      style="max-width: {{ section.settings.maximum_width }}px;"
                    >
                      <div class="info-cols--video type-{{ type }} size-{{ block.settings.grid_video_size }}{% unless has_content %} info-cols--video__no-content{% endunless %}">
                        {% liquid 
                          if block.settings.video != blank
                            assign video = block.settings.video
                          elsif block.settings.video_url != blank
                            assign video = block.settings.video_url
                          endif
                  
                          assign loop = true
                          assign autoplay = true
                          assign mute = true
                          assign show_controls = false

                          assign is_background_media = true
                          if block.settings.grid_video_size == 'original'
                            assign is_background_media = false
                          endif
                        %}
                        {% if video %}
                          {% render 'deferred-media', 
                            delayed_media: video, 
                            section_id: section.id, 
                            enable_video_loop: loop, 
                            enable_autoplay: autoplay, 
                            mute: mute, 
                            show_controls: show_controls,
                            is_product_media: false,
                            aspect_ratio: 'original',
                            media_type: 'grid',
                            video_alt_text: block.settings.video_alt_text,
                            is_background_media: is_background_media
                          %}
                        {% else %}
                          {{ 'lifestyle-1' | placeholder_svg_tag: placeholder_classes | replace: '<svg', '<svg preserveAspectRatio="xMinYMin slice"' }}
                        {% endif %}
                      </div>
                    </div>
                  </div>

                  {% if block.settings.button_link != blank %}
                    </a>
                  {% endif %}

                  {% if block.settings.heading != '' %}
                    <h5 class="info-cols--title h5 h4-mobile">{{ block.settings.heading }}</h5>
                  {% endif %}

                  {% if block.settings.text != '' %}
                    <div class="info-cols--text text-link-animated">{{ block.settings.text }}</div>
                  {% endif %}

                  {% if block.settings.button_text != '' %}
                    {% render 'dynamic-section-button',
                      id: grid_item_id,
                      link: block.settings.button_link,
                      label: block.settings.button_text,
                      style: section.settings.buttons_style,
                      div_classes: 'info-cols--link--wrapper'
                    %}
                  {% endif %}

                {% when 'text' %}
                
                  {% if block.settings.button_text == '' and block.settings.button_link != blank %}
                    <a href="{{ block.settings.button_link }}">
                  {% endif %}

                  {% if block.settings.heading != '' %}
                    <h5 class="info-cols--title h5 h4-mobile">{{ block.settings.heading }}</h5>
                  {% endif %}

                  {% if block.settings.text != '' %}
                    <div class="info-cols--text text-link-animated">{{ block.settings.text }}</div>
                  {% endif %}

                  {% if block.settings.button_text == '' and block.settings.button_link != blank %}
                    </a>
                  {% endif %}

                  {% if block.settings.button_text != '' %}
                    {% render 'dynamic-section-button',
                      id: grid_item_id,
                      link: block.settings.button_link,
                      label: block.settings.button_text,
                      style: section.settings.buttons_style,
                      div_classes: 'info-cols--link--wrapper'
                    %}
                  {% endif %}

              {% endcase %}
            </div>

          {% endfor %}
        </div>
        
        {% if has_slider %}
          {% if section.blocks.size > 1 %}
            <div class="swiper-pagination{% if disable_mobile_slider or section.settings.navigation_mobile == 'peek' %} small-hide{% endif %}{% if disable_desktop_slider %} large-hide{% endif %}" style="position: relative; margin-top: 15px;"></div>
          {% endif %}
        {% endif %}

      </div>

      {% if section.blocks.size == 0 %}
        <div class="placeholder-noblocks">
          {{ 'general.onboarding.no_content' | t }}
        </div>
      {% endif %}

    </content-grid-slider>

  {% if section_width == 'content' %}
    </div>
  {% endif %}
</info-columns>

{% schema %}
{
  "name": "t:sections.template--product--info-columns.name",
  "class": "product-section--info-columns",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:all.Heading"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:all.Heading",
      "default": "Info columns"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:all.Description",
      "default": "<p>Emphasise your messaging</p>"
    },
    {
      "type": "text_alignment",
      "id": "section_header_alignment",
      "label": "t:all.Alignment",
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:sections.template--product--info-columns.settings.image_or_video.label"
    },
    {
      "type": "range",
      "id": "maximum_width",
      "min": 50,
      "max": 500,
      "step": 5,
      "unit": "px",
      "label": "t:sections.template--product--info-columns.settings.image_or_video.maximum_width",
      "default": 500
    },
    {
      "type": "checkbox",
      "id": "override_border_radius",
      "label": "t:all.override_border_radius",
      "info": "t:all.override_border_radius_info",
      "default": false
    },
    {
      "type": "header",
      "content": "t:all.Buttons"
    },
    {
      "type": "select",
      "id": "buttons_style",
      "label": "t:all.button_style",
      "default": "underlined",
      "options": [
        {
          "value": "filled",
          "label": "t:all.Filled"
        },
        {
          "value": "outlined",
          "label": "t:all.Outlined"
        },
        {
          "value": "underlined",
          "label": "t:all.underlined"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "override_button_colors",
      "label": "t:all.Button_color_override",
      "default": false,
      "info": "t:all.Button_color_override_info"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "t:all.Primary_color",
      "default": "#E68819",
      "visible_if": "{{ section.settings.override_button_colors }}"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "t:all.Secondary_color",
      "default": "#ffffff",
      "info": "t:all.Secondary_button_color_info",
      "visible_if": "{{ section.settings.override_button_colors }}"
    },
    {
      "type": "header",
      "content": "t:all.Desktop"
    },
    {
      "type": "radio",
      "id": "layout_style_desktop",
      "label": "Desktop Layout Style",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "slider",
          "label": "Slider"
        }
      ],
      "default": "slider"
    },
    {
      "type": "radio",
      "id": "hover_navigation_desktop",
      "label": "t:sections.template--product--info-columns.settings.slider_navigation_style.label",
      "options": [
        {
          "value": "left-and-right",
          "label": "t:settings_schema.Product_card.settings.hover_navigation_desktop.options.left_and_right"
        },
        {
          "value": "right",
          "label": "t:settings_schema.Product_card.settings.hover_navigation_desktop.options.right"
        },
        {
          "value": "above",
          "label": "t:settings_schema.Product_card.settings.hover_navigation_desktop.options.above"
        },
        {
          "value": "none",
          "label": "t:settings_schema.Product_card.settings.hover_navigation_desktop.options.none"
        }
      ],
      "default": "left-and-right",
      "visible_if": "{{ section.settings.layout_style_desktop == 'slider' }}"
    },
    {
      "type": "range",
      "id": "columns_per_row",
      "min": 1,
      "max": 9,
      "step": 1,
      "label": "t:sections.template--product--info-columns.settings.columns_per_row.label",
      "default": 3
    },
    {
      "type": "radio",
      "id": "vertical_alignment",
      "label": "t:all.Content_position",
      "options": [
        {
          "value": "top",
          "label": "t:all.Top"
        },
        {
          "value": "center",
          "label": "t:all.Center"
        },
        {
          "value": "bottom",
          "label": "t:all.Bottom"
        }
      ],
      "default": "top"
    },
    {
      "type": "radio",
      "id": "text_alignment",
      "label": "t:all.Alignment",
      "options": [
        {
          "value": "left",
          "label": "t:all.Left"
        },
        {
          "value": "center",
          "label": "t:all.Center"
        },
        {
          "value": "right",
          "label": "t:all.Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:all.Mobile"
    },
    {
      "type": "radio",
      "id": "layout_style_mobile",
      "label": "Mobile Layout Style",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "slider",
          "label": "Slider"
        }
      ],
      "default": "slider"
    },
    {
      "type": "select",
      "id": "navigation_mobile",
      "label": "Mobile Navigation Style",
      "options": [
        {
          "value": "peek",
          "label": "Peek"
        },
        {
          "value": "dots",
          "label": "Dots"
        }
      ],
      "default": "peek",
      "visible_if": "{{ section.settings.layout_style_mobile == 'slider' }}"
    },
    {
      "type": "select",
      "id": "columns_per_row_mobile",
      "label": "Items per row (Mobile)",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "radio",
      "id": "text_alignment_mobile",
      "label": "t:all.Alignment",
      "options": [
        {
          "value": "left",
          "label": "t:all.Left"
        },
        {
          "value": "center",
          "label": "t:all.Center"
        },
        {
          "value": "right",
          "label": "t:all.Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "slider_height_mobile",
      "label": "t:all.Slider_height",
      "info": "t:all.Slider_height_info",
      "options": [
        { 
          "value": "adaptive", 
          "label": "t:all.Slider_height_options.auto" 
        },
        { 
          "value": "consistent", 
          "label": "t:all.Slider_height_options.fixed" 
        }
      ],
      "default": "adaptive"
    },
    {
      "type": "header",
      "content": "t:all.Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:all.Width",
      "info": "t:all.Section_width_info",
      "default": "full",
      "options": [
        {
          "value": "content",
          "label": "t:all.Content_width"
        },
        {
          "value": "full",
          "label": "t:all.Full_width"
        }
      ]
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "t:all.Spacing_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "t:all.px",
      "default": 72
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "t:all.Spacing_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "t:all.px",
      "default": 72
    },
    {
      "type": "header",
      "content": "t:all.Color"
    },
    {
      "type": "select",
      "id": "colors",
      "label": "t:all.Color_scheme",
      "default": "white",
      "options": [
        {
          "value": "white",
          "label": "t:all.Default"
        },
        {
          "value": "light",
          "label": "t:all.First"
        },
        {
          "value": "accent",
          "label": "t:all.Second"
        },
        {
          "value": "dark",
          "label": "t:all.Third"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "image_and_text",
      "name": "t:sections.template--product--info-columns.blocks.image_and_text.name",
      "settings": [
        {
          "type": "header",
          "content": "t:all.Image"
