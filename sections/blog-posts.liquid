    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "t:all.Primary_color",
      "default": "#E68819",
      "visible_if": "{{ section.settings.override_button_colors and section.settings.show_read_more }}"
    },
    {
      "type": "color",
      "id": "button_text_color",
