{{ 'section-content-grid.min.css' | asset_url | stylesheet_tag }}
{{ 'section-blog-posts.min.css' | asset_url | stylesheet_tag }}

<style>
  /* Custom Media Override Styles for Metafield Videos/Images */
  .custom-blog-media-wrapper.has-custom-media .blog-post-card .blog-post-card__image-wrap {
    display: none !important; /* Hide the theme's default image if custom media exists */
  }
  .custom-media-override {
    margin-bottom: 12px;
  }
  .custom-media-override .blog-post-card__image {
    position: relative;
    overflow: hidden;
    width: 100%;
    background-color: #f4f4f4;
  }
  .custom-media-override video, 
  .custom-media-override img {
    width: 100%; 
    height: 100%; 
    object-fit: cover;
    display: block;
    position: absolute; 
    top: 0; 
    left: 0;
  }

  /* Enforce aspect ratios on custom media containers */
  .custom-media-override .custom-ratio--square { aspect-ratio: 1 / 1; }
  .custom-media-override .custom-ratio--4_3 { aspect-ratio: 4 / 3; }
  .custom-media-override .custom-ratio--4_5 { aspect-ratio: 4 / 5; }
  
  .ai-blog-video-control-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: rgba(0, 0, 0, 0.6);
    border: none;
    color: #ffffff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }
  .ai-blog-video-control-btn:hover {
    background-color: rgba(0, 0, 0, 0.9);
  }
</style>

{%-  liquid
  if section.settings.section_width == 'content'
    assign content_width = true
  endif

  assign posts_block = section.blocks.first

  assign posts_count = section.settings.post_limit
  if posts_block.type == 'blog' and posts_block.settings.blog != blank
  assign has_blog = true
    assign posts_count = posts_block.settings.blog.articles_count | at_most: section.settings.post_limit
  endif

  assign layout_desktop = 'grid'
  if section.settings.layout_style_desktop == 'slider' and posts_count > section.settings.images_per_row_desktop
    assign layout_desktop = 'slider'
  endif

  assign layout_mobile = 'grid'
  if section.settings.layout_style_mobile == 'slider' and posts_count > 1
    assign layout_mobile = 'slider'
  endif

  if layout_desktop == 'slider' or layout_mobile == 'slider'
    assign has_slider = true
    if layout_desktop == 'grid'
      assign disable_desktop_slider = true
    endif
    if layout_mobile == 'grid'
      assign disable_mobile_slider = true
    endif
  endif

  assign slider_spacing = settings.grid_spacing
  if settings.grid_spacing == '8'
    assign slider_spacing = '16'
  else
    assign slider_spacing = settings.grid_spacing
  endif

  assign grid_columns_desktop = section.settings.images_per_row_desktop

  assign background_matches = false
  if section.settings.colors == 'white'
    assign background_matches = true
  endif
-%}

{% if has_slider %}
  <safe-load-scripts class="hidden">
    <script src="{{ 'component-content-grid-slider.js' | asset_url }}" defer="defer" type="module" data-flow-load-key="content-grid-slider"></script>
  </safe-load-scripts>
{% endif %}

{% if section.settings.override_button_colors %}
  {% render 'button-color-overrides',
    id: section.id,
    style: section.settings.buttons_style,
    text_color: section.settings.button_text_color,
    background_color: section.settings.button_background_color
  %}
{% endif %}

<div
  class="content-grid--{{ section.id }} blog-posts-section wrapper-spacing--v wrapper-spacing--h content-align--{{ section.settings.section_header_alignment }}{% unless content_width %} color-scheme--{{ section.settings.colors }}{% endunless %}{% if request.visual_preview_mode %} section-preview{% else %} show-on-scroll{% endif %}"
  data-wetheme-section-type="blog-posts"
  data-wetheme-section-id="{{ section.id }}"
  style="--padding-section-top: {{ section.settings.section_padding_top }}px; --padding-section-bottom: {{ section.settings.section_padding_bottom }}px; --columns-desktop: {{ grid_columns_desktop }}; --columns-mobile: 1; --overlay-pagination-offset: 0px;"
>
  <div {% if content_width %}class="width--content{% unless background_matches %} wrapper-spacing--v--content wrapper-spacing--h--content{% endunless %} color-scheme--{{ section.settings.colors }}"{% endif %}>
    {% comment %} Section title and description {% endcomment %}
    {% render 'dynamic-section-header', section_title: section.settings.title, section_description: section.settings.description, alignment: section.settings.section_header_alignment %}

    {% if section.blocks.size == 0 %}
      <div class="placeholder-noblocks">
        {{ 'homepage.onboarding.no_content' | t }}
      </div>
    {% else %}
      {% if has_slider %}
        <content-grid-slider
          data-grid-slider-wrapper
          data-section-id="{{ section.id }}"
          data-desktop-only="{{ disable_mobile_slider }}"
          data-mobile-only="{{ disable_desktop_slider }}"
          data-slides-per-view-mobile="1"
          data-slides-per-view-desktop="{{ section.settings.images_per_row_desktop }}"
          data-peek-desktop-enabled="{{ section.settings.peek_desktop }}"
          data-peek-mobile-enabled="{% if section.settings.navigation_mobile == 'peek' %}true{% else %}false{% endif %}"
          data-pagination-overlay-enabled="false"
          data-remove-spacing="false"
          data-grid-spacing-desktop="{{ slider_spacing }}"
          data-grid-spacing-mobile="{{ slider_spacing | times: 0.75 }}"
        >
          {% if layout_desktop == 'slider' %}
            <!-- navigation -->
            {% assign navigation_id = 'navigation--' | append: section.id %}
            <div class="swiper-btn--wrapper small-hide swiper-btn-layout__{{ section.settings.hover_navigation_desktop }}">
              <div class="swiper-button--prev btn dynamic-section-button--{{ navigation_id }}">
                {% render 'theme-icon', icon: 'arrow-left' %}
              </div>
              <div class="swiper-button--next btn dynamic-section-button--{{ navigation_id }}">
                {% render 'theme-icon', icon: 'arrow-right' %}
              </div>
            </div>
            {% if section.settings.override_button_colors %}
              {% render 'button-color-overrides',
                id: navigation_id,
                style: 'filled',
                text_color: section.settings.button_text_color,
                background_color: section.settings.button_background_color
              %}
            {% endif %}
          {% endif %}
          <div class="content-grid__slider swiper{% if disable_desktop_slider %} disable-desktop{% endif %}{% if disable_mobile_slider %} disable-mobile{% endif %}" data-animate-overflow-container>
      {% endif %}
            <div class="content-grid{% if has_slider %} swiper-wrapper{% endif %} content-grid--desktop-{{ layout_desktop }} content-grid--mobile-{{ layout_mobile }} content-grid--gap">
              {% for i in (1..posts_count) %}
                {%- liquid
                  if posts_block.type == 'blog'
                    assign i_0 = i | minus: 1
                    assign blog_post = posts_block.settings.blog.articles[i_0]
                  elsif posts_block.type == 'article'
                    assign blog_post_setting_id = 'blog_post_' | append: i
                    assign blog_post_handle = posts_block.settings[blog_post_setting_id]
                    assign blog_post = articles[blog_post_handle]
                  endif
                  
                  assign slider_video = blog_post.metafields.custom.slider_video.value
                  assign article_image = blog_post.metafields.custom.image.value | default: blog_post.metafields.custom.image

                  assign use_custom_media = false
                  if section.settings.media_source == 'metafields'
                    if slider_video != blank or article_image != blank
                      assign use_custom_media = true
                    endif
                  endif
                -%}

                <div
                  class="content-grid-item{% if has_slider %} swiper-slide{% endif %}"
                  {% if has_slider %}
                    data-content-grid-slide-index="{{ forloop.index0 }}"
                  {% endif %}
                  data-animate
                  data-animate-order="{% render 'block-animation-offset',
                    title: section.settings.title,
                    description: section.settings.description,
                    base: forloop.index
                  %}"
                  {% if has_slider %}
                    data-animate-overflow-item
                  {% endif %}
                  {{ posts_block.shopify_attributes }}
                >
                  
                  <div class="custom-blog-media-wrapper {% if use_custom_media %}has-custom-media{% endif %}">
                    {% if use_custom_media %}
                      <div class="blog-post-card__image-wrap custom-media-override" style="position: relative;">
                        <a href="{{ blog_post.url }}" style="display: block;">
                          <div class="blog-post-card__image custom-ratio--{{ section.settings.custom_media_ratio }}">
                            {% if slider_video != blank %}
                              <video playsinline autoplay muted loop preload="metadata" webkit-playsinline data-video>
                                {% if slider_video.sources %}
                                  {% for source in slider_video.sources %}
                                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                                  {% endfor %}
                                {% else %}
                                  {% assign video_url = slider_video.url | default: slider_video %}
                                  <source src="{{ video_url }}" type="video/mp4">
                                {% endif %}
                              </video>
                            {% elsif article_image != blank %}
                              <img src="{{ article_image | image_url: width: 800 }}" alt="{{ article_image.alt | escape }}" loading="lazy">
                            {% endif %}
                          </div>
                        </a>
                        {% if slider_video != blank %}
                          <div class="ai-blog-video-controls" style="position: absolute; bottom: 10px; right: 10px; display: flex; gap: 8px; z-index: 2;">
                            <button class="ai-blog-video-control-btn" data-play-pause aria-label="Play/Pause video">
                              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" data-pause-icon><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg>
                              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" data-play-icon style="display: none;"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                            </button>
                            <button class="ai-blog-video-control-btn" data-mute-unmute aria-label="Mute/Unmute video">
                              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-mute-icon><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line></svg>
                              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-unmute-icon style="display: none;"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>
                            </button>
                          </div>
                        {% endif %}
                      </div>
                    {% endif %}

                    {% render 'blog-post-card',
                      post: blog_post,
                      show_date: section.settings.blog_show_date,
                      show_image: section.settings.show_image,
                      show_excerpt: section.settings.show_excerpt,
                      show_read_more: section.settings.show_read_more,
                      image_shape: section.settings.image_shape,
                      show_tags: section.settings.show_tags,
                      heading_font: section.settings.heading_font,
                      heading_font_size: section.settings.heading_font_size,
                      heading_font_size_mobile: section.settings.heading_font_size_mobile,
                      body_font_size: section.settings.body_font_size,
                      alignment: section.settings.alignment,
                      show_author: section.settings.show_author,
                      show_reading_time: section.settings.show_reading_time,
                      show_comment_count: section.settings.show_comment_count,
                      button_style: section.settings.buttons_style,
                      button_id: section.id
                    %}
                  </div>

                </div>
              {% endfor %}
            </div>
      {% if has_slider %}
            {% if layout_mobile == 'slider' and section.settings.navigation_mobile == 'dots' %}
              <div class="swiper-pagination" style="--content-grid-pagination-offset: 0px"></div>
            {% endif %}
          </div>
        </content-grid-slider>
      {% endif %}
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('[data-wetheme-section-id="{{ section.id }}"]');
    if (!section) return;

    // Autoplay logic safely initializing
    const videos = section.querySelectorAll('[data-video]');
    videos.forEach(video => {
      video.muted = true;
      const playPromise = video.play();
      if (playPromise !== undefined) {
        playPromise.catch(e => console.log('Autoplay prevented', e));
      }
    });

    // Control logic
    const wrappers = section.querySelectorAll('.custom-blog-media-wrapper');
    wrappers.forEach(wrapper => {
      const video = wrapper.querySelector('[data-video]');
      if (!video) return;

      const playPauseBtn = wrapper.querySelector('[data-play-pause]');
      const muteUnmuteBtn = wrapper.querySelector('[data-mute-unmute]');
      const playIcon = wrapper.querySelector('[data-play-icon]');
      const pauseIcon = wrapper.querySelector('[data-pause-icon]');
      const muteIcon = wrapper.querySelector('[data-mute-icon]');
      const unmuteIcon = wrapper.querySelector('[data-unmute-icon]');

      if (playPauseBtn) {
        playPauseBtn.addEventListener('click', (e) => {
          e.preventDefault();
          if (video.paused) {
            video.play();
            playIcon.style.display = 'none';
            pauseIcon.style.display = 'block';
          } else {
            video.pause();
            playIcon.style.display = 'block';
            pauseIcon.style.display = 'none';
          }
        });
      }

      if (muteUnmuteBtn) {
        muteUnmuteBtn.addEventListener('click', (e) => {
          e.preventDefault();
          if (video.muted) {
            video.muted = false;
            muteIcon.style.display = 'none';
            unmuteIcon.style.display = 'block';
          } else {
            video.muted = true;
            muteIcon.style.display = 'block';
            unmuteIcon.style.display = 'none';
          }
        });
      }
    });
  });
</script>

{% schema %}
{
  "name": "t:sections.blog-posts.name",
  "class": "section--blog-posts",
  "max_blocks": 1,
  "settings": [
    {
      "type": "paragraph",
      "content": "Add custom metafields to your blog articles: 'custom.slider_video' (file type) for videos and 'custom.image' for custom thumbnail images. Videos will take priority over images."
    },
    {
      "type": "header",
      "content": "t:all.Heading"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:all.Heading",
      "default": "From the blog"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:all.Description"
    },
    {
      "type": "text_alignment",
      "id": "section_header_alignment",
      "label": "t:all.Alignment",
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:all.Image"
    },
    {
      "type": "select",
      "id": "media_source",
      "label": "Media source",
      "default": "metafields",
      "options": [
        {
          "value": "original",
          "label": "Original thumbnail"
        },
        {
          "value": "metafields",
          "label": "Custom Metafields (Video/Image)"
        }
      ]
    },
    {
      "type": "select",
      "id": "custom_media_ratio",
      "label": "Custom media aspect ratio",
      "default": "square",
      "options": [
        {
          "value": "square",
          "label": "Square (1:1)"
        },
        {
          "value": "4_3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "4_5",
          "label": "Portrait (4:5)"
        }
      ],
      "visible_if": "{{ section.settings.media_source == 'metafields' }}"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:sections.template--blog.settings.show_image.label",
      "default": true
    },
    {
      "type": "select",
      "id": "image_shape",
      "label": "t:all.Shape",
      "default": "natural",
      "options": [
        {
          "value": "natural",
          "label": "t:all.Original"
        },
        {
          "value": "circle",
          "label": "t:all.Circle"
        },
        {
          "value": "square",
          "label": "t:all.Square"
        },
        {
          "value": "tall",
          "label": "t:all.Tall"
        },
        {
          "value": "wide",
          "label": "t:all.Wide"
        }
      ],
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "header",
      "content": "t:all.Content"
    },
    {
      "type": "range",
      "id": "post_limit",
      "min": 1,
      "max": 8,
      "step": 1,
      "label": "t:sections.blog-posts.settings.post_limit.label",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "t:sections.template--blog.settings.show_tags.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "blog_show_date",
      "label": "t:all.Show_dates",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "t:sections.template--blog.settings.show_author_name.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_reading_time",
      "label": "t:sections.blog-posts.settings.show_reading_time.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_comment_count",
      "label": "t:sections.blog-posts.settings.show_comment_count.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "t:sections.template--blog.settings.show_excerpt.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_read_more",
      "label": "t:sections.template--blog.settings.show_read_more.label",
      "default": true
    },
    {
      "type": "select",
