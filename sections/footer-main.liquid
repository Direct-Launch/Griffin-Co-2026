<style>
  details.mobile-footer-accordion summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    list-style: none;
    cursor: pointer;
  }
  details.mobile-footer-accordion summary::-webkit-details-marker {
    display: none;
  }
  details.mobile-footer-accordion[open] summary .footer-accordion-icon {
    transform: scaleY(-1);
  }
  .footer-accordion-icon {
    transition: transform 0.2s ease;
    display: flex;
    align-items: center;
  }
</style>

<footer
  class="footer-main {{ section.settings.color_scheme }} flex-full color-scheme--{{ section.settings.color_scheme }} site-footer{% if template contains 'product' %}{% if settings.related_products_enable %}{% else %} product-sticker-stop{% endif %}{% endif %} footer-alignment--{{ section.settings.alignment }} footer-alignment-mobile--{{ section.settings.alignment_mobile }}"
  data-wetheme-section-type="footer-main" data-wetheme-section-id="{{ section.id }}"
>
  <div 
    class="footer-main--inner wrapper-spacing--h"
    style="grid-template-columns: repeat({{ section.blocks.size }}, 1fr);"
  >
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'social' %}

          <div class="social-media-footer{% if forloop.first %} border-none padding-none{% endif %}" {{ block.shopify_attributes }}>
            {% unless block.settings.social_title == "" %}
              <div class="footer-header {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_mobile }}">{{ block.settings.social_title | escape }}</div>
            {% endunless %}
            {% render 'social-icons' %}
          </div>


          {% when 'menu' %}

            {% assign menu = linklists[block.settings.footer_linklist] %}
            <div class="links-footer{% if forloop.first %} border-none padding-none{% endif %}" {{ block.shopify_attributes }}>
              
              {% capture menu_list_html %}
                {% if menu.links.size > 0 %}
                  <ul class="footer-content nav-link-animated">
                    {% for link in menu.links %}
                      {% if link.links != blank %}
                        <li>
                          <a href="{{ link.url }}" class="footer--has-dropdown-title"><span class="animated-underline">{{ link.title }}</span></a>
                          <ul class="footer--level-2">
                            {% for sub_link in link.links %}
                              <li><a href="{{ sub_link.url }}"><span class="animated-underline">{{ sub_link.title | escape }}</span></a></li>
                            {% endfor %}
                          </ul>
                        </li>
                      {% else %}
                        <li>
                          <a href="{{ link.url }}"><span class="animated-underline">{{ link.title }}</span></a>
                        </li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                {% endif %}
              {% endcapture %}

              <!-- Desktop View -->
              <div class="medium-down--hide">
                {% unless block.settings.menu_title == "" %}
                  <div class="footer-header {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_mobile }}">{{ block.settings.menu_title | escape }}</div>
                {% endunless %}
                {{ menu_list_html }}
              </div>

              <!-- Mobile View (Accordion) -->
              <div class="large--hide">
                {% if block.settings.menu_title != "" %}
                  <details class="mobile-footer-accordion">
                    <summary class="footer-header {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_mobile }}">
                      {{ block.settings.menu_title | escape }}
                      <span class="footer-accordion-icon">
                        {% render 'theme-icon', icon: 'chevron_down' %}
                      </span>
                    </summary>
                    <div style="padding-top: 16px; padding-bottom: 8px;">
                      {{ menu_list_html }}
                    </div>
                  </details>
                {% else %}
                  {{ menu_list_html }}
                {% endif %}
              </div>

            </div>

          {% when 'text' %}

            <div class="content-footer{% if forloop.first %} border-none padding-none{% endif %}" {{ block.shopify_attributes }}>
              {% unless block.settings.title == "" %}
                <div class="footer-header {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_mobile }}">{{ block.settings.title | escape }}</div>
              {% endunless %}
              {% unless block.settings.richtext == "" %}
                <div class="rte footer-article text-link-animated richtext-block">{{ block.settings.richtext }}</div>
              {% endunless %}
            </div>

        {% when 'follow_on_shop' %}

          <div class="content-footer{% if forloop.first %} border-none padding-none{% endif %}" {{ block.shopify_attributes }}>
            {% unless block.settings.title == "" %}
              <div class="footer-header {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_mobile }}">{{ block.settings.title | escape }}</div>
            {% endunless %}
            {% if shop.features.follow_on_shop? %}
              {{ shop | login_button: action: 'follow' }}
            {% endif %}
          </div>

        {% when 'image' %}

          <div class="image-footer{% if forloop.first %} border-none padding-none{% endif %}" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {%- assign img_url = block.settings.image | image_url: width: 600 -%}
            {% else %}
              {%- assign img_url = '' -%}
            {% endif %}

            {% unless block.settings.title == "" %}
              <div class="footer-header {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_mobile }}">{{ block.settings.title }}</div>
            {% endunless %}

            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" {% unless block.settings.override_border_radius %}class="block-radius-clip"{% endunless %}>
            {% elsif img_url != blank %}
              <div class="image-bar__item">
            {% else %}
              <div class="image-bar__item">
            {% endif %}

            <div class="image-bar__content">
              {% if img_url == blank %}
                {% assign placeholder_class = 'icon icon--placeholder' %}
                {% unless block.settings.override_border_radius %}
                  {% assign placeholder_class = placeholder_class | append: ' block-radius' %}
                {% endunless %}

                {{ 'image' | placeholder_svg_tag: placeholder_class }}
              {% else %}
                {% assign image_class = '' %}
                {% unless block.settings.override_border_radius %}
                  {% assign image_class = 'block-radius' %}
                {% endunless %}

                {% render 'responsive-image', image: block.settings.image, class: image_class %}
              {% endif %}
            </div>

            {% if block.settings.link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </div>

        {% when 'newsletter' %}

          <div class="newsletter-footer{% if forloop.first %} border-none padding-none{% endif %}" {{ block.shopify_attributes }}>
            {% unless block.settings.newsletter_title == "" %}
              <div class="footer-header {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_mobile }}">{{ block.settings.newsletter_title | escape }}</div>
            {% endunless %}

            <div class="newsletter-footer--wrapper">
              {% if block.settings.footer_newsletter_description != empty %}
                <div class="rte footer-article text-link-animated richtext-block">{{ block.settings.footer_newsletter_description }}</div>
              {% endif %}
              {% form 'customer', id: 'newsletter-footer_form' %}
                {{ form.errors | default_errors }}

                {% unless form.posted_successfully? %}
                  {% if customer and customer.email == form.email %}
                    <div class="errors">
                      <span role="alert" class="error">{{ 'general.newsletter_form_section.already_subscribed' | t }}</span>
                    </div>
                  {% endif %}
                {% endunless %}

                {% if form.posted_successfully? %}
                  <p class="note form-success" role="alert">{{ 'general.newsletter_form.confirmation' | t }}</p>
                {% else %}
                  {% liquid
                    case block.settings.buttons_style
                      when 'filled'
                        assign button_classes = 'btn'
                      when 'outlined'
                        assign button_classes = 'btn btn--secondary'
                      when 'underlined'
                        assign button_classes = 'btn--underlined'
                    endcase
                  %}
                  
                  {% if block.settings.override_button_colors %}
                    {% render 'button-color-overrides',
                      id: block.id,
                      style: block.settings.buttons_style,
                      text_color: block.settings.button_text_color,
                      background_color: block.settings.button_background_color
                    %}
                  {% endif %}
                  <div class="input-group{% if block.settings.buttons_style == 'underlined' %} text-link-animated{% endif %}">
                    <input type="email" value="{% if customer %}{{ customer.email }}{% endif %}" placeholder="{{ 'general.newsletter_form.newsletter_email' | t }}" name="contact[email]" id="FooterEmail" class="input-group-field footer-email-input" aria-label="{{ 'general.newsletter_form.newsletter_email' | t }}" pattern=".+@.+\..+" title="{{ 'general.forms.email_must_be_formatted_as_an_email' | t }}">
                    <input type="hidden" name="contact[tags]" value="newsletter">
                    <button type="submit" class="{{ button_classes }} footer-email-submit dynamic-section-button--{{ block.id }}" name="subscribe" id="FooterSubscribe">{{ 'general.newsletter_form.submit' | t }}</button>
                  </div>
                {% endif %}
              {% endform %}
            </div>
          </div>

        {% when 'brand_information' %}

          <div class="content-footer{% if forloop.first %} border-none padding-none{% endif %}" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {%- assign brand_img_url = block.settings.image | image_url: width: 600 -%}
            {% else %}
              {%- assign brand_img_url = '' -%}
            {% endif %}

            {% if brand_img_url != blank %}
              <div class="brand-info-image" style="width: {{ block.settings.image_width }}px;">
                {% if block.settings.link != blank %}
                  <a href="{{ block.settings.link }}">
                {% endif %}

                {% render 'responsive-image', image: block.settings.image %}

                {% if block.settings.link != blank %}
                  </a>
                {% endif %}
              </div>
            {% endif %}

            {% unless block.settings.title == "" %}
              <div class="footer-header {{ section.settings.heading_font_size }} {{ section.settings.heading_font_size_mobile }}">{{ block.settings.title | escape }}</div>
            {% endunless %}

            {% unless block.settings.richtext == blank %}
              <div class="rte footer-article text-link-animated richtext-block">{{ block.settings.richtext }}</div>
            {% endunless %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer-main.name",
  "max_blocks": 5,
  "settings": [
    {
      "type": "select",
      "id": "alignment",
      "label": "t:all.Alignment_desktop",
      "options": [
        {
          "value": "left",
          "label": "t:all.Left"
        },
        {
          "value": "center",
          "label": "t:all.Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "alignment_mobile",
      "label": "t:all.Alignment_mobile",
      "options": [
        {
          "value": "left",
          "label": "t:all.Left"
        },
        {
          "value": "center",
          "label": "t:all.Center"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "t:all.heading_font_size",
      "default": "h5",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "select",
      "id": "heading_font_size_mobile",
      "label": "t:all.Heading_font_size_mobile",
      "default": "h5-mobile",
      "options": [
        { "value": "h1-mobile", "label": "H1" },
        { "value": "h2-mobile", "label": "H2" },
        { "value": "h3-mobile", "label": "H3" },
        { "value": "h4-mobile", "label": "H4" },
        { "value": "h5-mobile", "label": "H5" },
        { "value": "h6-mobile", "label": "H6" }
      ]
    },
    {
      "type": "header",
      "content": "t:all.Color"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:all.Color_scheme",
      "default": "accent",
      "options": [
        {
          "value": "white",
          "label": "t:all.Default"
        },
        {
          "value": "light",
          "label": "t:all.First"
        },
        {
          "value": "accent",
          "label": "t:all.Second"
        },
        {
          "value": "dark",
          "label": "t:all.Third"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "t:all.Text",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:all.Heading",
          "default": "Text details"
        },
        {
          "type": "richtext",
          "id": "richtext",
          "label": "t:all.Text",
          "default": "<p>Create a captivating brand story, explain details of your products or highlight store promotions</p>"
        }
      ]
    },
    {
      "type": "menu",
      "name": "t:all.Navigation",
      "settings": [
        {
          "type": "text",
          "id": "menu_title",
          "label": "t:all.Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "footer_linklist",
          "label": "t:sections.footer-main.blocks.menu.settings.footer_linklist.label",
          "default": "footer",
          "info": "t:sections.footer-main.blocks.menu.settings.footer_linklist.info"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "t:all.Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "newsletter_title",
          "label": "t:all.Heading",
          "default": "Newsletter"
        },
        {
          "type": "richtext",
          "id": "footer_newsletter_description",
          "label": "t:sections.footer-main.blocks.newsletter.settings.footer_newsletter_description.label"
        },
        {
          "type": "header",
          "content": "t:all.Buttons"
        },
        {
          "type": "select",
          "id": "buttons_style",
          "label": "t:all.button_style",
          "default": "filled",
          "options": [
            {
              "value": "filled",
              "label": "t:all.Filled"
            },
            {
              "value": "outlined",
              "label": "t:all.Outlined"
            },
            {
              "value": "underlined",
              "label": "t:all.underlined"
            }
          ]
        },
        {
          "type": "checkbox",
          "id": "override_button_colors",
          "label": "t:all.Button_color_override",
          "default": false,
          "info": "t:all.Button_color_override_info"
        },
        {
          "type": "color",
          "id": "button_background_color",
          "label": "t:all.Primary_color",
          "default": "#E68819",
          "visible_if": "{{ block.settings.override_button_colors }}"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "t:all.Secondary_color",
          "default": "#ffffff",
          "info": "t:all.Secondary_button_color_info",
          "visible_if": "{{ block.settings.override_button_colors }}"
        }
      ]
    },
    {
      "type": "social",
      "name": "t:sections.footer-main.blocks.social.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "social_title",
          "label": "t:all.Heading",
          "default": "Get connected"
        },
        {
          "type": "paragraph",
          "content": "t:sections.footer-main.blocks.social.settings.paragraph-1.content"
        }
      ]
    },
    {
      "type": "image",
      "name": "t:all.Image",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:all.Heading"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:all.Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:all.Link",
          "info": "t:all.Optional"
        },
        {
          "type": "checkbox",
          "id": "override_border_radius",
          "label": "t:all.override_border_radius",
          "info": "t:all.override_border_radius_info",
          "default": false
        }
      ]
    },
    {
      "type": "follow_on_shop",
      "name": "t:sections.footer-main.blocks.follow_on_shop.name",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.footer-main.blocks.follow_on_shop.settings.paragraph-0.content"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:all.Heading",
          "default": "Follow us on the Shop app"
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "t:sections.footer-main.blocks.brand_information.name",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:all.Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "label": "t:all.Image_width",
          "min": 50,
          "max": 550,
          "step": 10,
          "unit": "px",
          "default": 200
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:all.Link",
          "info": "t:all.Optional"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:all.Heading",
          "default": "Brand information"
        },
        {
          "type": "richtext",
          "id": "richtext",
          "label": "t:all.Text",
          "default": "<p>Use this area to introduce your business and share what makes it unique. Whether it’s your history, craftsmanship, or philosophy, let customers connect with your story.</p>"
        }
      ]
    }
  ]
}
{% endschema %}