{%- comment -%}
  Header Section
  Includes the main navigation loop and the schema for Mega Menus and Icons.
{%- endcomment -%}

<header class="py-6 border-b border-gray-200 sticky top-0 bg-white z-50" data-section-id="{{ section.id }}">
  <div class="container mx-auto px-6 flex justify-between items-center max-w-[1400px]">
    
    <!-- Logo -->
    <div class="text-2xl font-semibold tracking-wider z-10 relative">
      <a href="{{ routes.root_url }}" class="text-gray-900">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}" class="h-8 object-contain">
        {% else %}
          {{ shop.name }}
        {% endif %}
      </a>
    </div>

    <!-- Main Navigation -->
    <nav class="hidden lg:flex space-x-8 tracking-wide text-sm font-medium relative h-full">
      {% for link in linklists[section.settings.menu].links %}
        <div class="group py-2">
          <a href="{{ link.url }}" class="text-gray-600 hover:text-gray-900 transition-colors flex items-center gap-1">
            {{ link.title }}
            {% if link.links != blank %}
              <svg class="w-3 h-3 text-gray-400 group-hover:text-gray-900 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            {% endif %}
          </a>
          
          <!-- Render Mega Menu Snippet -->
          {% render 'mega-menu', link: link, blocks: section.blocks %}
        </div>
      {% endfor %}
    </nav>

    <!-- Icons (Search, Cart) -->
    <div class="flex items-center space-x-5 z-10 relative">
      <a href="{{ routes.search_url }}" class="text-gray-900 hover:text-gray-600">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" class="text-gray-900 hover:text-gray-600 relative">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1zm3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V4h-3.5zM2 5h12v9a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5z"/></svg>
        {% if cart.item_count > 0 %}
          <span class="absolute -top-1.5 -right-2.5 bg-black text-white text-[10px] font-bold rounded-full h-4 w-4 flex items-center justify-center">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu"
    }
  ],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "Mega Menu Panel",
      "settings": [
        {
          "type": "text",
          "id": "menu_item",
          "label": "Target Menu Item",
          "info": "Enter the exact name of the top-level menu item to trigger this mega menu (e.g., 'Engagement Rings')."
        },
        { "type": "header", "content": "Promotion 1" },
        { "type": "image_picker", "id": "promo_1_image", "label": "Image" },
        { "type": "text", "id": "promo_1_heading", "label": "Heading" },
        { "type": "text", "id": "promo_1_text", "label": "Subtext" },
        { "type": "url", "id": "promo_1_link", "label": "Link" },
        
        { "type": "header", "content": "Promotion 2" },
        { "type": "image_picker", "id": "promo_2_image", "label": "Image" },
        { "type": "text", "id": "promo_2_heading", "label": "Heading" },
        { "type": "text", "id": "promo_2_text", "label": "Subtext" },
        { "type": "url", "id": "promo_2_link", "label": "Link" },

        { "type": "header", "content": "Promotion 3" },
        { "type": "image_picker", "id": "promo_3_image", "label": "Image" },
        { "type": "text", "id": "promo_3_heading", "label": "Heading" },
        { "type": "text", "id": "promo_3_text", "label": "Subtext" },
        { "type": "url", "id": "promo_3_link", "label": "Link" },

        { "type": "header", "content": "Promotion 4" },
        { "type": "image_picker", "id": "promo_4_image", "label": "Image" },
        { "type": "text", "id": "promo_4_heading", "label": "Heading" },
        { "type": "text", "id": "promo_4_text", "label": "Subtext" },
        { "type": "url", "id": "promo_4_link", "label": "Link" },

        { "type": "header", "content": "Promotion 5" },
        { "type": "image_picker", "id": "promo_5_image", "label": "Image" },
        { "type": "text", "id": "promo_5_heading", "label": "Heading" },
        { "type": "text", "id": "promo_5_text", "label": "Subtext" },
        { "type": "url", "id": "promo_5_link", "label": "Link" }
      ]
    },
    {
      "type": "menu_icon",
      "name": "Menu Link Icon",
      "settings": [
        {
          "type": "text",
          "id": "link_title",
          "label": "Link Title",
          "info": "Enter the exact name of the Level 2 or Level 3 menu item you want to add an icon to (e.g., 'Oval Cut')."
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image",
          "info": "Upload a square icon (PNG or SVG recommended)."
        }
      ]
    }
  ]
}
{% endschema %}