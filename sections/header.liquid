{% comment %}
Testing Cypress integration
{% endcomment %}

{{ 'component-mobile-menu.min.css' | asset_url | stylesheet_tag: preload: true }}

{% assign overlay_opacity = 100 | minus: section.settings.overlay_opacity %}
{% assign overlay_bg_color = 'rgba(' | append: settings.header-transparent-background.rgba | append: ')' %}
{% assign opaque_color = 'color-mix(in srgb, ' | append: overlay_bg_color | append: ', transparent ' | append: overlay_opacity | append: '%)' %}
{% assign overlay = false %}
{% assign mega_menu_block = section.blocks | where: 'type', 'content' | first %}

{% assign homepage-overlay = false %}
{% if section.settings.overlay_header_homepage and template == 'index' %}
  {% assign homepage-overlay = true %}
{% endif %}

{% assign collection-overlay = false %}
{% if section.settings.overlay_header_collection and template.name == 'collection' %}
  {% assign collection-overlay = true %}
{% endif %}

{% assign list-collection-overlay = false %}
{% if section.settings.overlay_header_list_collection and template == 'list-collections' %}
  {% assign list-collection-overlay = true %}
{% endif %}

{% assign contact-overlay = false %}
{% if section.settings.overlay_header_contact and template == 'page.contact' %}
  {% assign contact-overlay = true %}
{% endif %}

{% assign article-overlay = false %}
{% if section.settings.overlay_header_article and template.name == 'article' %}
  {% assign article-overlay = true %}
{% endif %}

{% if homepage-overlay
  or collection-overlay
  or list-collection-overlay
  or contact-overlay
  or article-overlay
%}
  {% assign overlay = true %}
{% endif %}

{% capture locale %}
  {% render 'localization-form', show_locale_selector: section.settings.show_locale_selector, show_currency_selector: section.settings.show_currency_selector %}
{% endcapture %}

{% capture locale_mobile %}
  {% render 'localization-form', show_locale_selector: section.settings.show_locale_selector_mobile, show_currency_selector: section.settings.show_currency_selector_mobile %}
{% endcapture %}

{% capture utility_bar %}
  {% if section.settings.show_currency_selector or section.settings.show_locale_selector or section.settings.show_social_icons %}
    {% liquid
      assign utility_count = 0
      if section.settings.show_locale_selector
        assign utility_count = utility_count | plus: 1
      endif
      if section.settings.show_social_icons
        assign utility_count = utility_count | plus: 1
      endif
      if section.settings.show_currency_selector
        assign utility_count = utility_count | plus: 1
      endif
    %}
    <div 
      class="site-header__utility-bar{% if section.settings.show_divider %} site-header__utility-bar--divider{% endif %} site-header__utility-bar--{{ section.settings.utility_bar_position }}{% unless section.settings.show_when_header_is_sticky %} hide-on-sticky{% endunless %}"
      style="--divider-color: {{ section.settings.divider_color }}; --overlay-divider-color: {{ section.settings.overlay_divider_color }};"
    >
      <div class="site-header__utility-bar__left">
        {% if utility_count == 3 %}
          {% render 'localization-form', show_currency_selector: false, show_locale_selector: true %}
        {% elsif utility_count == 2 %}
          {% if section.settings.show_locale_selector %}
            {% render 'localization-form', show_currency_selector: false, show_locale_selector: true %}
          {% elsif section.settings.show_social_icons %}
            <div class="social-icons--left-aligned">
              {% render 'social-icons' %}
            </div>
          {% endif %}
        {% endif %}
      </div>
      <div class="site-header__utility-bar__center">
        {% if utility_count == 3 %}
          {% render 'social-icons' %}
        {% elsif utility_count == 1 %}
          {% if section.settings.show_locale_selector %}
            {% render 'localization-form', show_currency_selector: false, show_locale_selector: true %}
          {% elsif section.settings.show_social_icons %}
            {% render 'social-icons' %}
          {% elsif section.settings.show_currency_selector %}
            {% render 'localization-form', show_currency_selector: true, show_locale_selector: false %}
          {% endif %}
        {% endif %}
      </div>
      <div class="site-header__utility-bar__right">
        {% if utility_count == 3 %}
          {% render 'localization-form', show_currency_selector: true, show_locale_selector: false %}
        {% elsif utility_count == 2 %}
          {% if section.settings.show_currency_selector %}
            {% render 'localization-form', show_currency_selector: true, show_locale_selector: false %}
          {% elsif section.settings.show_social_icons %}
            <div class="social-icons--right-aligned">
              {% render 'social-icons' %}
            </div>
          {% endif %}
        {% endif %}
      </div>
    </div>
  {% endif %}
{% endcapture %}

{% assign menu_size = linklists[section.settings.main_linklist] | size %}
{% if menu_size == 0 %}
  {% assign site_nav = blank %}
{% else %}
  {% capture site_nav %}
    <div role="navigation" class="js site-header__nav top-links" id="top_links_wrapper">
      <ul class="site-nav nav-link-animated {% if mega_menu_block %} mega-menu-wrapper{% endif %}" id="AccessibleNav">
        {% render 'nav--main', mega_menu: mega_menu_block, logo_position: section.settings.logo-placement %}
      </ul>
    </div>
  {% endcapture %}
{% endif %}

{% capture offers_icon_link %}
  {% liquid 
    assign offers_drawer_icon_color = 'rgba(' | append: section.settings.offers_drawer_icon_color.rgba | append: ')'
  %}
  {% if section.settings.offers_drawer_color_override %}
    {% assign offers_drawer_header_color = offers_drawer_icon_color %}
  {% else %}
    {% assign offers_drawer_header_color = 'currentColor' %}
    <style>
      .offers-drawer__heading svg {
        color: {{ offers_drawer_icon_color }};
      }
    </style>
  {% endif %}
  <div class="offers-drawer-icon-container">
    <a
      href="#"
      class="standalone-icon--wrapper offers-drawer-icon-wrapper js-drawer-open-offers-link"
      aria-controls="OffersDrawer" 
      aria-expanded="false"
      aria-label="{{ 'layout.header.offers_drawer' | t }}"
    >
      {% render 'theme-icon', icon: section.settings.offers_drawer_icon, iconColor: offers_drawer_header_color, iconAttributes: 'data-offers-drawer-icon' %}
    </a>
    {% if section.settings.offers_drawer_show_tooltip %}
      <div
        {% unless section.settings.offers_drawer_tooltip_test_mode %}data-offers-drawer-tooltip{% endunless %}
        class="offers-drawer-tooltip thumbnail-radius text-link-animated{% unless section.settings.offers_drawer_tooltip_test_mode %} hide{% endunless %}"
        style="color: rgba({{ section.settings.offers_drawer_tooltip_text_color.rgba }}); --tooltip-background-color: rgba({{ section.settings.offers_drawer_tooltip_background_color.rgba }}); --nav-text-color: rgba({{ section.settings.offers_drawer_tooltip_text_color.rgba }}); --nav-text-hover: rgba({{ section.settings.offers_drawer_tooltip_text_color.rgba }}); --link-border-color: rgba({{ section.settings.offers_drawer_tooltip_text_color.rgba }});"
      >
        {{ section.settings.offers_drawer_tooltip_text }}
      </div>
    {% endif %}
  </div>
{% endcapture %}

{% capture top_links %}
  <ul class="site-header__links top-links--icon-links">
    {% if section.settings.enable_search %}
      <li>
        <a href="{{ routes.search_url }}" class="search-button standalone-icon--wrapper" aria-label="{{ 'layout.header.search' | t }}">
          {% if section.settings.show_icons %}
            {% render 'theme-icon', icon: 'search', iconSize: 20 %}
          {% else %}
            <span class="header--supporting-text">{{ 'layout.header.search' | t }}</span>
          {% endif %}
        </a>
      </li>
    {% endif %}

    {% if shop.customer_accounts_enabled %}
      {% if customer %}
        <li>
          <a href="{{ routes.account_url }}" title="{{ 'layout.customer.account' | t }}" class="account-button standalone-icon--wrapper">
            {% if section.settings.show_icons %}
              {% render 'theme-icon', icon: 'user', iconSize: 20 %}
            {% else %}
              <span class="header--supporting-text">{{ 'layout.header.account' | t }}</span>
            {% endif %}
          </a>
        </li>
      {% else %}
        <li>
          <a href="{{ routes.account_login_url }}" aria-label="{{ 'layout.customer.log_in' | t }}" class="log-in-button standalone-icon--wrapper">
            {% if section.settings.show_icons %}
              {% render 'theme-icon', icon: 'user', iconSize: 20 %}
            {% else %}
              <span class="header--supporting-text">{{ 'layout.header.account' | t }}</span>
            {% endif %}
          </a>
        </li>
      {% endif %}
    {% endif %}

    {% if section.settings.show_offers_drawer and section.settings.show_icons %}
      <li>
        {{ offers_icon_link }}
      </li>
    {% endif %}

    <li>
      <a 
        href="{{ routes.cart_url }}" 
        class="site-header__cart-toggle{% if settings.cart_type == "drawer" %} js-drawer-open-right-link{% endif %}{% if section.settings.cart_count %} cart-count-enabled {{ section.settings.cart-style }}{% endif %}{% if cart.item_count > 0 %} cart-count-visible{% endif %} standalone-icon--wrapper{% if section.settings.show_icons %} header-icons-enabled{% endif %}"
        aria-controls="CartDrawer" 
        aria-expanded="false" 
        aria-label="{{ 'layout.header.your_cart' | t }}"
      >
        {% if section.settings.show_icons %}
          {% render 'theme-icon', icon: section.settings.cart-style %}
          {% if section.settings.cart_count %}                                                                                                                                                                                                                                    
              <span 
                data-cart-count-indicator
                class="cart-item-count-bubble cart-item-count-header cart-item-count-header--quantity{% if cart.item_count == 0 %} hide{% endif %}"
              >
                {{ cart.item_count }}
              </span>
          {% endif %}
        {% else %}
          <span class="header--supporting-text">
            {{ 'layout.header.your_cart' | t }}
            {% if section.settings.cart_count %}
                <span 
                  data-cart-count-indicator
                  class="cart-item-count-header cart-item-count-header--has-label cart-item-count-header--quantity{% if cart.item_count == 0 %} hide{% endif %}"
                >
                  {{ cart.item_count }}
                </span>
            {% endif %}
          </span>
        {% endif %}
      </a>
    </li>

    {% if section.settings.show_offers_drawer and section.settings.show_icons == false %}
      <li>
        {{ offers_icon_link }}
      </li>
    {% endif %}
    
    {% if section.settings.show_booking_button %}
      <li>
        <a href="{{ section.settings.booking_button_link }}" class="booking-button standalone-icon--wrapper" aria-label="{{ section.settings.booking_button_text }}">
          {% if section.settings.show_icons %}
            {% render 'theme-icon', icon: section.settings.booking_button_icon, iconSize: 20 %}
          {% endif %}
          <span class="booking-button-text">{{ section.settings.booking_button_text }}</span>
        </a>
      </li>
    {% endif %}
  </ul>
{% endcapture %}

{% style %}
  .default-menu-drawer-text-color {
    color: var(--menu-drawer-text-color);
  }

  {% if section.settings.show_locale_selector_mobile or section.settings.show_currency_selector_mobile %}
    .locale--mobile {
      padding: 16px;
    }
  {% endif %}

  /* Custom styling for mobile mega menu icons */
  .mobile-menu-icon {
    display: inline-block;
    width: 24px;
    height: 24px;
    object-fit: contain;
    vertical-align: middle;
    margin-right: 12px;
  }
  .mobile-menu-icon--small {
    width: 20px;
    height: 20px;
  }
  .mobile-nav__link-wrapper,
  .mega-menu-link-wrapper {
    display: inline-flex;
    align-items: center;
  }
  .mobile-nav__link.with-icon {
    display: inline;
  }

  /* Desktop Booking Button Styles */
  .site-header__links .booking-button {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    background: transparent !important;
    color: inherit;
  }
  
  .site-header__links .booking-button-text {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  /* Booking Button Styles for Mobile Drawer */
  .mobile-nav-booking-button {
    display: block;
    width: 100%;
    text-align: center;
    padding: 12px 16px;
    margin-top: 15px;
    margin-bottom: 15px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 2px;
  }
{% endstyle %}

<div
  class="header-section--wrapper
    {%- if collection-overlay or homepage-overlay or list-collection-overlay or contact-overlay or article-overlay %} overlay-header-wrapper{% endif -%}
    {%- if collection.image %} collection-image-enabled{% endif -%}
  "
  data-wetheme-section-type="header"
  data-wetheme-section-id="{{ section.id }}"
  data-header-sticky="{{ section.settings.sticky_header }}"
  data-header-overlay="{{ overlay }}"
  data-utility-bar-hides-on-sticky="{% unless section.settings.show_when_header_is_sticky %}true{% else %}false{% endunless %}"
>
  <div id="NavDrawerOverlay" class="drawer-overlay"></div>
  <div id="NavDrawer" class="drawer drawer--left" inert>

    <div class="mobile-nav-grid-container">
      <div class="mobile-nav__logo-title">
        <div class="mobile-nav__logo-title--inner">
          <a href="#" class="mobile-menu--close-btn standalone-icon--wrapper" aria-label="{{ 'layout.drawers.close_menu' | t }}" role="button">
            {% render 'theme-icon', icon: 'close', iconSize: 20 %}
          </a>
        </div>
      </div>

      <!-- begin mobile-nav -->
      <ul class="mobile-nav mobile-nav--main">
        {% assign menu = linklists[section.settings.main_linklist] %}
        {% for link in menu.links %}
          {% liquid 
            assign link-title = link.title | strip | downcase
            assign is-mega-menu = false
            assign current_mega_block = blank
 
            for block in section.blocks
              if block.type == 'content'
                assign block-title = block.settings.mega-menu | strip | downcase
                if block-title == link-title
                  assign is-mega-menu = true
                  assign current_mega_block = block
                  break
                endif
              endif
            endfor

            assign show_mobile_links = true
            assign show_mobile_promos = false

            if is-mega-menu
              assign show_mobile_links = current_mega_block.settings.show_mega_menu_links_mobile
              assign show_mobile_promos = current_mega_block.settings.show_mega_menu_promos_mobile
            endif
          %}
          
          {% if link.links != blank %}
            <li class="mobile-nav__item top-level{% if link.active %} mobile-nav__item--active{% endif %}{% if is-mega-menu %} mega-menu--mobile{% endif %}" aria-haspopup="true">
              <div class="mobile-nav__has-sublist">
                <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
                <div class="mobile-nav__toggle">
                  <button type="button" class="icon-fallback-text mobile-nav__toggle-open standalone-icon--wrapper touch-target icon-no-padding" aria-label="{{ 'cart.general.see_more' | t }}">
                    {% render 'theme-icon', icon: 'plus', iconSize: 16, iconAttributes: 'aria-hidden="true"' %}
                  </button>
                  <button type="button" class="icon-fallback-text mobile-nav__toggle-close standalone-icon--wrapper touch-target icon-no-padding" aria-label="{{ 'layout.drawers.close_menu' | t }}">
                    {% render 'theme-icon', icon: 'minus', iconSize: 16, iconAttributes: 'aria-hidden="true"' %}
                  </button>
                </div>
              </div>
              
              <ul class="mobile-nav__sublist">
                {% if show_mobile_links %}
                  {% for sub_link in link.links %}
                    {%- liquid
                      assign sub_icon_url = blank
                      assign sub_title_down = sub_link.title | downcase | strip
                      for icon_block in section.blocks
                        if icon_block.type == 'menu_icon'
                          assign target_down = icon_block.settings.title | downcase | strip
                          if target_down == sub_title_down and icon_block.settings.icon != blank
                            assign sub_icon_url = icon_block.settings.icon | image_url: width: 64
                            break
                          endif
                        endif
                      endfor
                    -%}
                    {% if sub_link.levels > 0 %}
                      <li class="mobile-nav__item {% if sub_link.active %} mobile-nav__item--active{% endif %}">
                        <div class="mobile-nav__has-sublist">
                          <div class="mobile-nav__link-wrapper">
                            {% if sub_icon_url != blank %}
                              <img src="{{ sub_icon_url }}" alt="" class="mobile-menu-icon" loading="lazy">
                            {% endif %}
                            <a href="{{ sub_link.url }}" class="mobile-nav__link{% if sub_icon_url != blank %} with-icon{% endif %}">
                              {{ sub_link.title | escape }}
                            </a>
                          </div>
                          <div class="mobile-nav__toggle">
                            <button type="button" class="icon-fallback-text mobile-nav__toggle-open standalone-icon--wrapper touch-target icon-no-padding" name="{{ 'cart.general.see_more' | t }}">
                              {% render 'theme-icon', icon: 'plus', iconSize: 16, iconAttributes: 'aria-hidden="true"' %}
                              <span class="fallback-text">{{ 'cart.general.see_more' | t }}</span>
                            </button>
                            <button type="button" class="icon-fallback-text mobile-nav__toggle-close standalone-icon--wrapper touch-target icon-no-padding" name="{{ 'layout.drawers.close_menu' | t }}">
                              {% render 'theme-icon', icon: 'minus', iconSize: 16, iconAttributes: 'aria-hidden="true"' %}
                              <span class="fallback-text">{{ 'layout.drawers.close_menu' | t }}</span>
                            </button>
                          </div>
                        </div>
                        <ul class="mobile-nav__sublist">
                          {% for sub_sub_link in sub_link.links %}
                            {%- liquid
                              assign sub_sub_icon_url = blank
                              assign sub_sub_title_down = sub_sub_link.title | downcase | strip
                              for icon_block in section.blocks
                                if icon_block.type == 'menu_icon'
                                  assign target_down = icon_block.settings.title | downcase | strip
                                  if target_down == sub_sub_title_down and icon_block.settings.icon != blank
                                    assign sub_sub_icon_url = icon_block.settings.icon | image_url: width: 64
                                    break
                                  endif
                                endif
                              endfor
                            -%}
                            <li class="mobile-nav__item">
                              <div class="mobile-nav__link-wrapper">
                                {% if sub_sub_icon_url != blank %}
                                  <img src="{{ sub_sub_icon_url }}" alt="" class="mobile-menu-icon mobile-menu-icon--small" loading="lazy">
                                {% endif %}
                                <a href="{{ sub_sub_link.url }}" class="mobile-nav__link{% if sub_sub_icon_url != blank %} with-icon{% endif %}">
                                  {{ sub_sub_link.title | escape }}
                                </a>
                              </div>
                            </li>
                          {% endfor %}
                        </ul>
                      </li>
                    {% else %}
                      <li class="mobile-nav__item{% if sub_link.active %} mobile-nav__item--active{% endif %}">
                        <div class="mobile-nav__link-wrapper">
                          {% if sub_icon_url != blank %}
                            <img src="{{ sub_icon_url }}" alt="" class="mobile-menu-icon" loading="lazy">
                          {% endif %}
                          <a href="{{ sub_link.url }}" class="mobile-nav__link{% if sub_icon_url != blank %} with-icon{% endif %}">
                            {{ sub_link.title | escape }}
                          </a>
                        </div>
                      </li>
                    {% endif %}
                  {% endfor %}
                {% endif %}

                {% if is-mega-menu and show_mobile_promos %}
                  <div class="mobile-promo--block">
                    {% assign block = current_mega_block %}
                    
                    {% assign has_any_promo = false %}
                    {% for i in (1..5) %}
                      {% assign mega_image_key = 'mega_image_' | append: i %}
                      {% assign show_promo_key = 'show_promo_' | append: i | append: '_in_mobile_drawer' %}
                      {% if block.settings[mega_image_key] != blank and block.settings[show_promo_key] %}
                         {% assign has_any_promo = true %}
                      {% endif %}
                    {% endfor %}

                    {% if has_any_promo == false %}
                      <li class="mobile-nav__item">
                        <p class="mega-menu--empty" {% unless request.design_mode %}style="visibility:hidden;"{% endunless %}>
                          {{ 'layout.header.mega_menu_empty' | t }}
                        </p>
                      </li>
                    {% else %}
                      {% for i in (1..5) %}
                        {% assign mega_image_key = 'mega_image_' | append: i %}
                        {% assign show_promo_key = 'show_promo_' | append: i | append: '_in_mobile_drawer' %}
                        
                        {% if block.settings[mega_image_key] != blank and block.settings[show_promo_key] %}
                          {% assign crop_setting_key = 'image_' | append: i | append: '_aspect_ratio' %}
                          {% assign header_key = 'mega_image_header_' | append: i %}
                          {% assign subheader_key = 'mega_image_subheader_' | append: i %}
                          {% assign overlay_text_key = 'overlay_text_on_image_promo_' | append: i %}
                          {% assign link_key = 'mega_image_link_' | append: i %}
                          {% assign text_color_key = 'overlay_text_color_promo_' | append: i %}

                          {% liquid
                            assign image_stretch = false
                            assign crop_setting = block.settings[crop_setting_key]
                            if crop_setting == "square"
                              assign image_crop = "aspect-ratio--square"
                              assign image_stretch = true
                            elsif crop_setting == "tall"
                              assign image_crop = "aspect-ratio--tall"
                              assign image_stretch = true
                            elsif crop_setting == "wide"
                              assign image_crop = "aspect-ratio--wide"
                              assign image_stretch = true
                            else
                              assign image_crop = false
                              assign image_stretch = false
                            endif

                            assign promo_has_text = false
                            if block.settings[header_key] != blank or block.settings[subheader_key] != blank
                              assign promo_has_text = true
                            endif
                          %}

                          {% style %}
                            .block-id-{{ block.id }} .overlay-text-on-image-promo-{{ i }} {
                              color: rgba({{ block.settings[text_color_key].rgba }});
                            }
                          {% endstyle %}

                          <li class="mobile-nav__item block-id-{{ block.id }}">
                            <div class="inner mega-menu--image-wrapper">
                              <div class="mega-menu--image{% if block.settings[overlay_text_key] %} overlay--enabled{% endif %}{% if promo_has_text %} has-promo-text{% endif %}">
                                {% if block.settings[link_key] %}
                                  <a class="mega-menu-promo--image{% if image_crop %} mega-menu-aspect-ratio {{ image_crop }}{% endif %}" href="{{ block.settings[link_key] }}">
                                {% else %}
                                  <div class="mega-menu-promo--image{% if image_crop %} mega-menu-aspect-ratio {{ image_crop }}{% endif %}">
                                {% endif %}
                                
                                {% capture img_props %}style="max-width: {{ block.settings[mega_image_key].width }}px"{% endcapture %}
                                {% render 'responsive-image', image: block.settings[mega_image_key], allow_stretch: image_stretch, props: img_props %}
                                
                                {% if block.settings[link_key] %}
                                  </a>
                                {% else %}
                                  </div>
                                {% endif %}
                       
                                <div class="mega-menu--text">
                                  {% if block.settings[header_key] != blank %}
                                    <p class="h4 mega-menu--image-title{% if block.settings[subheader_key] != blank %} has-padding{% endif %}{% if block.settings[overlay_text_key] %} overlay-text-on-image-promo-{{ i }}{% else %} default-menu-drawer-text-color{% endif %}">
                                      {% if block.settings[link_key] %}
                                        <a href="{{ block.settings[link_key] }}" class="{% if block.settings[overlay_text_key] %} overlay-text-on-image-promo-{{ i }}{% else %} default-menu-drawer-text-color{% endif %}">
                                      {% endif %}
                                      {{ block.settings[header_key] }}
                                      {% if block.settings[link_key] %}
                                        </a>
                                      {% endif %}
                                    </p>
                                  {% endif %}
                                  
                                  {% if block.settings[subheader_key] != blank %}
                                    <p class="h5 mega-menu--image-subtitle{% if block.settings[overlay_text_key] %} overlay-text-on-image-promo-{{ i }}{% else %} default-menu-drawer-text-color{% endif %}">
                                      {% if block.settings[link_key] %}
                                        <a href="{{ block.settings[link_key] }}" class="{% if block.settings[overlay_text_key] %} overlay-text-on-image-promo-{{ i }}{% else %} default-menu-drawer-text-color{% endif %}">
                                      {% endif %}
                                      {{ block.settings[subheader_key] }}
                                      {% if block.settings[link_key] %}
                                        </a>
                                      {% endif %}
                                    </p>
                                  {% endif %}
                                </div>

                              </div>
                            </div>
                          </li>
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                  </div>
                {% endif %}
              </ul>
            </li>
          {% else %}
            <li class="mobile-nav__item top-level{% if link.active %} mobile-nav__item--active{% endif %}{% if is-mega-menu %} mega-menu--mobile no-links{% endif %}">
              {% if is-mega-menu %}
                <div class="mobile-nav__has-sublist">
                  <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
                  <div class="mobile-nav__toggle">
                    <button type="button" class="icon-fallback-text mobile-nav__toggle-open standalone-icon--wrapper touch-target icon-no-padding" aria-label="{{ 'cart.general.see_more' | t }}">
                      {% render 'theme-icon', icon: 'plus', iconSize: 16, iconAttributes: 'aria-hidden="true"' %}
                    </button>
                    <button type="button" class="icon-fallback-text mobile-nav__toggle-close standalone-icon--wrapper touch-target icon-no-padding" aria-label="{{ 'layout.drawers.close_menu' | t }}">
                      {% render 'theme-icon', icon: 'minus', iconSize: 16, iconAttributes: 'aria-hidden="true"' %}
                    </button>
                  </div>
                </div>

                <ul class="mobile-nav__sublist">
                  {% if current_mega_block.settings.show_mega_menu_links_mobile %}
                    {% for sub_link in link.links %}
                      <li class="mobile-nav__item">
                        <div class="mobile-nav__link-wrapper">
                          <a href="{{ sub_link.url }}" class="mobile-nav__link">{{ sub_link.title | escape }}</a>
                        </div>
                      </li>
                    {% endfor %}
                  {% endif %}

                  {% if show_mobile_promos %}
                    <div class="mobile-promo--block">
                      {% assign block = current_mega_block %}
                      
                      {% assign has_any_promo = false %}
                      {% for i in (1..5) %}
                        {% assign mega_image_key = 'mega_image_' | append: i %}
                        {% assign show_promo_key = 'show_promo_' | append: i | append: '_in_mobile_drawer' %}
                        {% if block.settings[mega_image_key] != blank and block.settings[show_promo_key] %}
                           {% assign has_any_promo = true %}
                        {% endif %}
                      {% endfor %}

                      {% if has_any_promo == false %}
                        <li class="mobile-nav__item">
                          <p class="mega-menu--empty" {% unless request.design_mode %}style="visibility:hidden;"{% endunless %}>
                            {{ 'layout.header.mega_menu_empty' | t }}
                          </p>
                        </li>
                      {% else %}
                        {% for i in (1..5) %}
                          {% assign mega_image_key = 'mega_image_' | append: i %}
                          {% assign show_promo_key = 'show_promo_' | append: i | append: '_in_mobile_drawer' %}
                          
                          {% if block.settings[mega_image_key] != blank and block.settings[show_promo_key] %}
                            {% assign crop_setting_key = 'image_' | append: i | append: '_aspect_ratio' %}
                            {% assign header_key = 'mega_image_header_' | append: i %}
                            {% assign subheader_key = 'mega_image_subheader_' | append: i %}
                            {% assign overlay_text_key = 'overlay_text_on_image_promo_' | append: i %}
                            {% assign link_key = 'mega_image_link_' | append: i %}
                            {% assign text_color_key = 'overlay_text_color_promo_' | append: i %}

                            {% liquid
                              assign image_stretch = false
                              assign crop_setting = block.settings[crop_setting_key]
                              if crop_setting == "square"
                                assign image_crop = "aspect-ratio--square"
                                assign image_stretch = true
                              elsif crop_setting == "tall"
                                assign image_crop = "aspect-ratio--tall"
                                assign image_stretch = true
                              elsif crop_setting == "wide"
                                assign image_crop = "aspect-ratio--wide"
                                assign image_stretch = true
                              else
                                assign image_crop = false
                                assign image_stretch = false
                              endif

                              assign promo_has_text = false
                              if block.settings[header_key] != blank or block.settings[subheader_key] != blank
                                assign promo_has_text = true
                              endif
                            %}

                            {% style %}
                              .block-id-{{ block.id }} .overlay-text-on-image-promo-{{ i }} {
                                color: rgba({{ block.settings[text_color_key].rgba }});
                              }
                            {% endstyle %}

                            <li class="mobile-nav__item block-id-{{ block.id }}">
                              <div class="inner mega-menu--image-wrapper">
                                <div class="mega-menu--image{% if block.settings[overlay_text_key] %} overlay--enabled{% endif %}{% if promo_has_text %} has-promo-text{% endif %}">
                                  {% if block.settings[link_key] %}
                                    <a class="mega-menu-promo--image{% if image_crop %} mega-menu-aspect-ratio {{ image_crop }}{% endif %}" href="{{ block.settings[link_key] }}">
                                  {% else %}
                                    <div class="mega-menu-promo--image{% if image_crop %} mega-menu-aspect-ratio {{ image_crop }}{% endif %}">
                                  {% endif %}
                                  
                                  {% capture img_props %}style="max-width: {{ block.settings[mega_image_key].width }}px"{% endcapture %}
                                  {% render 'responsive-image', image: block.settings[mega_image_key], allow_stretch: image_stretch, props: img_props %}
                                  
                                  {% if block.settings[link_key] %}
                                    </a>
                                  {% else %}
                                    </div>
                                  {% endif %}
                         
                                  <div class="mega-menu--text">
                                    {% if block.settings[header_key] != blank %}
                                      <p class="h4 mega-menu--image-title{% if block.settings[subheader_key] != blank %} has-padding{% endif %}{% if block.settings[overlay_text_key] %} overlay-text-on-image-promo-{{ i }}{% else %} default-menu-drawer-text-color{% endif %}">
                                        {% if block.settings[link_key] %}
                                          <a href="{{ block.settings[link_key] }}" class="{% if block.settings[overlay_text_key] %} overlay-text-on-image-promo-{{ i }}{% else %} default-menu-drawer-text-color{% endif %}">
                                        {% endif %}
                                        {{ block.settings[header_key] }}
                                        {% if block.settings[link_key] %}
                                          </a>
                                        {% endif %}
                                      </p>
                                    {% endif %}
                                    
                                    {% if block.settings[subheader_key] != blank %}
                                      <p class="h5 mega-menu--image-subtitle{% if block.settings[overlay_text_key] %} overlay-text-on-image-promo-{{ i }}{% else %} default-menu-drawer-text-color{% endif %}">
                                        {% if block.settings[link_key] %}
                                          <a href="{{ block.settings[link_key] }}" class="{% if block.settings[overlay_text_key] %} overlay-text-on-image-promo-{{ i }}{% else %} default-menu-drawer-text-color{% endif %}">
                                        {% endif %}
                                        {{ block.settings[subheader_key] }}
                                        {% if block.settings[link_key] %}
                                          </a>
                                        {% endif %}
                                      </p>
                                    {% endif %}
                                  </div>

                                </div>
                              </div>
                            </li>
                          {% endif %}
                        {% endfor %}
                      {% endif %}
                    </div>
                  {% endif %}
                </ul>
              {% else %}
                <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
              {% endif %}
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      <div class="mobile-nav--footer">
        {% if section.settings.show_booking_button %}
          <div style="padding: 0 16px;">
            <a href="{{ section.settings.booking_button_link }}" class="btn mobile-nav-booking-button" style="background-color: {{ section.settings.booking_button_bg_color }}; color: {{ section.settings.booking_button_text_color }};">
              {{ section.settings.booking_button_text }}
            </a>
          </div>
        {% endif %}
        
        <div class="mobile-nav locale--mobile">
          {{ locale_mobile }}
        </div>

        {% comment %}
          If customer accounts are enabled, provide login and create account links
        {% endcomment %}
        {% liquid 
          assign social_icons = false
          if settings.sm_facebook_link != blank or settings.sm_x_link != blank or settings.sm_youtube_link != blank or settings.sm_flickr_link != blank or settings.sm_pinterest_link != blank or settings.sm_instagram_link != blank or settings.sm_tumblr_link != blank or settings.sm_pinterest_link != blank or settings.sm_youtube_link != blank or settings.sm_vimeo_link != blank or settings.sm_flickr_link != blank or settings.sm_snapchat_link != blank or settings.sm_houzz_link != blank or settings.sm_linkedin_link != blank or settings.sm_tiktok_link != blank
            assign social_icons = true
          endif
        %}
        {% style %}
          .mobile-nav.nav--meta {
            display: grid;
            gap: 15px;
          }

          .mobile-nav.nav--meta .mobile-nav__item.customer--info,
          .mobile-nav.nav--meta .mobile-nav__item.customer-logout-link,
          .mobile-nav.nav--meta .mobile-nav__item.customer-login-link,
          .mobile-nav.nav--meta .mobile-nav__item.sm-icons--wrapper {
            display: flex;
            flex-wrap: wrap;
          }

          .mobile-nav.nav--meta .mobile-nav__item.sm-icons--wrapper #sm-icons {
            width: 100%;
          }

          {% if shop.customer_accounts_enabled and social_icons %}
            .mobile-nav.nav--meta .mobile-nav__social-icons {
              justify-content: end;
            }

            {% if customer %}
              .mobile-nav.nav--meta {
                grid-template-columns: 1fr 1fr;
                grid-template-rows: repeat(2, minmax(0, auto));
                align-items: center;
              }

              .mobile-nav.nav--meta .mobile-nav__item.customer--info {
                grid-column-start: 1;
                grid-column-end: 3;
                grid-row-start: 1;
                grid-row-end: 2;
              }

              .mobile-nav.nav--meta .mobile-nav__item.customer-logout-link {
                grid-column-start: 1;
                grid-column-end: 2;
                grid-row-start: 2;
                grid-row-end: 3;
              }

              .mobile-nav.nav--meta .mobile-nav__item.sm-icons--wrapper {
                grid-column-start: 2;
                grid-column-end: 3;
                grid-row-start: 2;
                grid-row-end: 3;
              }
            {% else %}
              .mobile-nav.nav--meta {
                grid-template-columns: 1fr 1fr;
              }

              .mobile-nav.nav--meta .mobile-nav__item.customer-login-link {
                grid-column-start: 1;
                grid-column-end: 2;
              }

              .mobile-nav.nav--meta .mobile-nav__item.sm-icons--wrapper {
                grid-column-start: 2;
                grid-column-end: 3;
              }
            {% endif %}
          {% elsif shop.customer_accounts_enabled and social_icons == false %}
            {% if customer %}
              .mobile-nav.nav--meta {
                grid-template-columns: 1fr;
                grid-template-rows: repeat(2, minmax(0, auto));
              }

              .mobile-nav.nav--meta .mobile-nav__item.customer--info {
                grid-column-start: 1;
                grid-column-end: 2;
                grid-row-start: 1;
                grid-row-end: 2;
              }

              .mobile-nav.nav--meta .mobile-nav__item.customer-logout-link {
                grid-column-start: 1;
                grid-column-end: 2;
                grid-row-start: 2;
                grid-row-end: 3;
              }
            {% else %}
              .mobile-nav.nav--meta {
                grid-template-columns: 1fr;
              }

              .mobile-nav.nav--meta .mobile-nav__item.customer-login-link {
                grid-column-start: 1;
                grid-column-end: 2;
              }
            {% endif %}
          {% elsif shop.customer_accounts_enabled == false and social_icons %}
            .mobile-nav.nav--meta {
              grid-template-columns: 1fr;
              justify-content: center;
              width: fit-content;
              margin: 0 auto;
            }

            .mobile-nav.nav--meta .mobile-nav__social-icons {
              justify-content: center;
            }
          {% endif %}
        {% endstyle %}
        <ul class="mobile-nav nav--meta{% unless shop.customer_accounts_enabled or social_icons %} hidden{% endunless %}">
          {% if shop.customer_accounts_enabled %}
            {% if customer %}
              <li class="mobile-nav__item customer--info">
                {% if customer.first_name != blank %}
                  {% capture first_name %}{{ customer.first_name }}{% endcapture %}
                  <a href="{{ routes.account_url }}">{{ 'layout.customer.logged_in_as_html' | t: first_name: first_name }}</a>
                {% else %}
                  <a href="{{ routes.account_url }}">{{ 'layout.customer.account' | t }}</a>
                {% endif %}
              </li>
              <li class="mobile-nav__item customer-logout-link">
                {{ 'layout.customer.log_out' | t | customer_logout_link }}
              </li>
            {% else %}
              <li class="mobile-nav__item customer-login-link">
                {{ 'layout.customer.log_in' | t | customer_login_link }}
              </li>
            {% endif %}
          {% endif %}

          {%- liquid
            assign enable_social_icons = false
            if section.settings.mobile_social_icons and social_icons
              assign enable_social_icons = true
            endif
          -%}
          {% if enable_social_icons %}
            <li class="mobile-nav__item sm-icons--wrapper">{% render 'social-icons', wrapper_classes: 'mobile-nav__social-icons', icon_wrapper_classes: 'icon-no-padding', icon_classes: 'fa-2x' %}</li>
          {% endif %}
        </ul>
      </div>
      <!-- //mobile-nav -->
    </div>
  </div>

  {% capture logo %}
    {% if section.settings.logo %}
      <a href="{{ routes.root_url }}" itemprop="url" class="site-header__logo-image">
        <style>
          .logo_image {
            max-height: unset!important;
            width: {{ section.settings.logo_max_width }}px;
            max-width: 100%;
          }
          @media (max-width: 1024px) {
            .logo_image {
              width: {{ section.settings.logo_max_width_mobile }}px;
              max-width: 100%;
            }
          }
        </style>
        {% assign alt = section.settings.logo.alt | default: shop.name | escape %}
        {% render 'responsive-image', image: section.settings.logo, alt: alt, props: 'itemprop="logo"', allow_stretch: true, blur: false, class: 'logo_image', loading: 'eager' %}
      </a>
    {% else %}
      <a class="site-header__logo-link" href="{{ routes.root_url }}" itemprop="url">{{ shop.name }}</a>
    {% endif %}
  {% endcapture %}

  {% capture overlay_logo %}
    {% if overlay %}
      {% if collection-overlay or homepage-overlay or list-collection-overlay or contact-overlay or article-overlay %}
        {% if section.settings.overlay_logo %}
          {% assign img = section.settings.overlay_logo %}
        {% elsif section.settings.logo %}
          {% assign img = section.settings.logo %}
        {% else %}
          {% assign img = none %}
        {% endif %}

        {% if img %}
          <a href="{{ routes.root_url }}" itemprop="url" class="site-header__logo-overlay-image">
            <style>
              .logo_overlay, 
              .logo_hover {
                max-height: unset!important;
                width: {{ section.settings.logo_max_width }}px;
                max-width: 100% !important;
              }
              @media (max-width: 1024px) {
                .logo_overlay,
                .logo_hover {
                  width: {{ section.settings.logo_max_width_mobile }}px;
                  max-width: 100% !important;
                }
              }
            </style>

            <span class="opacity-logo">
              {% assign opacity_alt = img.alt | default: shop.name | escape %}
              {% render 'responsive-image', image: img, alt: opacity_alt, props: 'itemprop="logo"', blur: false, class: 'logo_overlay' %}
            </span>
            {% if section.settings.overlay_logo and section.settings.logo %}
              <span class="hover-logo">
                {% assign hover_alt = section.settings.logo.alt | default: shop.name | escape %}
                {% render 'responsive-image', image: section.settings.logo, alt: hover_alt, props: 'itemprop="logo"', blur: false, class: 'logo_hover' %}
              </span>
            {% endif %}
          </a>
        {% else %}
          <a class="site-header__logo-overlay-link" href="{{ routes.root_url }}" itemprop="url">{{ shop.name }}</a>
        {% endif %}
      {% endif %}
    {% endif %}
  {% endcapture %}

  {% capture header_logos %}
    <div class="site-header__logowrapper">

      {% if template == 'index' %}
        <h1 class="site-header__logo site-title" itemscope itemtype="http://schema.org/Organization">
      {% else %}
        <div class="header-font site-header__logo site-title" itemscope itemtype="http://schema.org/Organization">
      {% endif %}

        {{ logo }}
        {{ overlay_logo }}

      {% if template == 'index' %}
        </h1>
      {% else %}
        </div>
      {% endif %}

    </div>
  {% endcapture %}

  <header class="site-header wrapper-spacing--h{% if section.settings.sticky_header %} header-is-sticky{% endif %}{% if section.settings.logo-placement == 'above' %} logo_above{% endif %}{% if collection-overlay or homepage-overlay or list-collection-overlay or contact-overlay or article-overlay %} overlay-header{% endif %}{% if section.settings.dropdown_alignment == 'center' %} dropdown-alignment--center{% endif %}{% if section.settings.overlay_logo %} overlay-logo{% endif %}">
    {% if section.settings.utility_bar_position == 'above_header' %}
      {{ utility_bar }}
    {% endif %}

    <div class="site-header__wrapper site-header__wrapper--logo-{{ section.settings.logo-placement }} site-header__wrapper--{% if top_links != blank %}with{% else %}without{% endif %}-menu">
      <div class="site-header__wrapper__left">
        {% if section.settings.logo-placement == 'left' %}
          {{ header_logos }}
        {% elsif section.settings.logo-placement == 'center' and site_nav != blank %}
          {{ site_nav }}
        {% endif %}
      </div>

      <div class="site-header__wrapper__center">
        {% if section.settings.logo-placement == 'left' and site_nav != blank %}
          {{ site_nav }}
        {% elsif section.settings.logo-placement == 'center' or section.settings.logo-placement == 'above' %}
          {{ header_logos }}
        {% endif %}
      </div>

      <div class="site-header__wrapper__right top-links">
        {{ top_links }}
      </div>
    </div>

    {% if section.settings.logo-placement == 'above' and site_nav != blank %}
      <div class="site-header__nav-standalone">
        {{ site_nav }}
      </div>
    {% endif %}

    {% if section.settings.utility_bar_position == 'below_header' %}
      {{ utility_bar }}
    {% endif %}
  </header>

  {% if section.settings.enable_search %}
    {% render 'search-dropdown' %}
  {% endif %}

  <nav class="nav-bar mobile-nav-bar-wrapper{% if collection-overlay or homepage-overlay or list-collection-overlay or contact-overlay or article-overlay %} overlay-header{% endif %}{% if section.settings.overlay_logo %} overlay-logo{% endif %}">
    <div class="wrapper-spacing--h">
      <div class="mobile-nav-bar--inner">
        <div class="mobile-grid--table">

          <div class="grid__item three-twelfths">
            <div class="site-nav--mobile{% if section.settings.show_offers_drawer %} has-offers-icon{% endif %}">
              <button type="button" aria-label="{{ 'layout.navigation.menu' | t }}" class="hamburger-nav-button icon-fallback-text site-nav__link js-drawer-open-left-link standalone-icon--wrapper" aria-controls="NavDrawer" aria-expanded="false">
                {% render 'theme-icon', icon: 'hamburger_nav', iconClasses: 'fa-2x', widthUnset: true %}
                <span class="fallback-text">{{ 'layout.navigation.menu' | t }}</span>
              </button>

              {% if section.settings.show_offers_drawer and section.settings.enable_search %}
                {{ offers_icon_link }}
              {% endif %}
            </div>
          </div>

          <div class="grid__item six-twelfths">
            {{ header_logos }}
          </div>

          <div class="grid__item three-twelfths right-side{% unless section.settings.enable_search or section.settings.show_offers_drawer %} text-right{% else %} has-second-icon{% endunless %}">
            <div class="site-nav--mobile">

              {% if section.settings.enable_search %}
                <a href="{{ routes.search_url }}" class="search-button standalone-icon--wrapper" aria-label="{{ 'layout.header.search' | t }}" aria-controls="SearchDrawer" aria-expanded="false">
                  <span class="icon-fallback-text">
                    {% render 'theme-icon', icon: 'search', iconSize: 20 %}
                    <span class="fallback-text">{{ 'layout.header.search' | t }}</span>
                  </span>
                </a>
              {% elsif section.settings.show_offers_drawer %}
                {{ offers_icon_link }}
              {% endif %}

              <a href="{{ routes.cart_url }}" aria-label="{{ 'layout.cart.title' | t }}" class="{% if settings.cart_type == 'drawer' %}js-drawer-open-right-link {% endif %}site-nav__link{% if section.settings.cart_count %} cart-count-enabled {{ section.settings.cart-style }}{% endif %}{% if cart.item_count > 0 %} cart-count-visible{% endif %} standalone-icon--wrapper{% if section.settings.show_icons %} header-icons-enabled{% endif %}" aria-controls="CartDrawer" aria-expanded="false">
                <span class="icon-fallback-text">
                  {% render 'theme-icon', icon: section.settings.cart-style, iconClasses: 'fa-2x' %}
                  {% if section.settings.cart_count %}
                    <span class="cart-item-count-bubble cart-item-count-header cart-item-count-header--quantity{% if cart.item_count == 0 %} hide{% endif %}">{{ cart.item_count }}</span>
                  {% endif %}
                  <span class="fallback-text">{{ 'layout.cart.title' | t }}</span>
                </span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>
</div>

<style>

  :root {
    --logo-max-width: {{ section.settings.logo_max_width | default: '450' | remove: 'px' }}px;
    --header-overlay-background-color: {{ overlay_bg_color }};

    {% if section.settings.sticky_header %}
      --sticky-header-offset: -1px;
      {%- comment -%}`--sticky-header-offset` compensates the `top: -1px;` on `.sticky-header` (which needs to be -1px so we can detect that header is sticky (using IntersectionObserver)){%- endcomment -%}
    {% endif %}
  }

  .site-title{
  	padding: {{ section.settings.logo_padding }}px 0;
  }

  @media (max-width: 1024px) {
    .site-title{
      padding: 15px 0;
    }
  }

  .site-nav__dropdown li, .inner .h4, .inner .h5 {
    text-align: {{ section.settings.dropdown_alignment }};
  }

  .template-index .header-section.sticky-header:not(.sticked) .overlay-header,
  .template-index .header-section:not(.sticky-header) .overlay-header,
  {% if collection-overlay %}
  .template-collection .header-section.sticky-header:not(.sticked) .overlay-header,
  .template-collection .header-section:not(.sticky-header) .overlay-header,
  {% endif %}
  .template-list-collections .header-section.sticky-header:not(.sticked) .overlay-header,
  .template-list-collections .header-section:not(.sticky-header) .overlay-header,
  .template-article .header-section.sticky-header:not(.sticked) .overlay-header,
  .template-article .header-section:not(.sticky-header) .overlay-header,
  .contact-page .header-section.sticky-header:not(.sticked) .overlay-header,
  .contact-page .header-section:not(.sticky-header) .overlay-header
  {
    background-color: {{ opaque_color }};
  }

  .overlay-header .grid--full {
    padding-left: 30px;
    padding-right: 30px;
  }

  @media (min-width: 1025px) and (max-width: 1200px) {
    .overlay-header .grid--full {
      padding-left: 15px;
      padding-right: 15px;
    }
  }

  .template-index .overlay-header.force-hover,
  {% if collection-overlay %}.template-collection .overlay-header.force-hover, {% endif %}
  .template-list-collections .overlay-header.force-hover,
  .template-article .overlay-header.force-hover,
  .contact-page .overlay-header.force-hover
   {
    background-color: rgba({{ settings.header-bg-color.rgba }});
  }

  {% if section.settings.overlay_logo != blank and section.settings.logo == blank %}
    @media (min-width: 1025px) {
      .template-index .overlay-header.ui.sticky:not(.top) .site-header__logo-link {
          display: none;
      }
      .template-index .header-section.sticky-header:not(.sticked) .overlay-header.force-hover .site-header__logo-link,
      .template-index .header-section.sticky-header:not(.sticked) .overlay-header:hover .site-header__logo-link,
      .template-collection .header-section.sticky-header:not(.sticked) .overlay-header.force-hover .site-header__logo-link,
      .template-collection .header-section.sticky-header:not(.sticked) .overlay-header:hover .site-header__logo-link,
      .template-list-collections .header-section.sticky-header:not(.sticked) .overlay-header.force-hover .site-header__logo-link,
      .template-list-collections .header-section.sticky-header:not(.sticked) .overlay-header:hover .site-header__logo-link,
      .template-article .header-section.sticky-header:not(.sticked) .overlay-header.force-hover .site-header__logo-link,
      .template-article .header-section.sticky-header:not(.sticked) .overlay-header:hover .site-header__logo-link,
      .contact-page .header-section.sticky-header:not(.sticked) .overlay-header.force-hover .site-header__logo-link,
      .contact-page .ui.sticky:not(.top) .overlay-header:hover .site-header__logo-link
      {
        display: block;
      }
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "header-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.header.settings.sticky_header.name"
