{{ 'section-rich-text.min.css' | asset_url | stylesheet_tag }}

{% case section.settings.section_width %}
    {% when 'full-width' %}
      {%- assign section_width = 'large--one whole' -%}
    {% when 'content' %}
      {%- assign section_width = 'width--content' -%}
{% endcase %}

{% liquid 

  case section.settings.section_width
    when 'content'
      assign section_width_setting = 'content'
    when 'full-width'
      assign section_width_setting = 'full'
  endcase

  assign background_matches = false
  if section.settings.colors == 'white'
    assign background_matches = true
  endif
%}

<div
  class="wrapper-spacing--v wrapper-spacing--h{% if section_width_setting == 'full' %} color-scheme--{{ section.settings.colors }}{% endif %}"
  data-wetheme-section-type="text--rich-text" 
  data-wetheme-section-id="{{ section.id }}"
  style="--padding-section-top: {{ section.settings.section_padding_top }}px; --padding-section-bottom: {{ section.settings.section_padding_bottom }}px;"
>

<div class="{% if request.visual_preview_mode %}section-preview{% else %}show-on-scroll{% endif %}">

	<div class="homepage-indiv-section-wrapper grid--full homepage-featured-content-wrapper">

		<div class="homepage-featured-rich-text {{ section_width }}{% if section_width_setting == 'content' %}{% unless background_matches %} wrapper-spacing--v--content wrapper-spacing--h--content{% endunless %} color-scheme--{{ section.settings.colors }}{% endif %} homepage-featured-rich-text__text-alignment-desktop--{{ section.settings.text_alignment_desktop }} homepage-featured-rich-text__text-alignment-mobile--{{ section.settings.text_alignment_mobile }}">

            {% for block in section.blocks %}
                {% case block.type %}

                    {% when 'heading' %}
                        {% if block.settings.heading != blank %}
                            <div 
                              class="sitewide--title-wrapper featured-row__subtext" 
                              style="padding-bottom: {{ block.settings.heading_bottom_spacing }}px;"
                              data-animate
                              data-animate-order="{{ forloop.index }}"
                              {{ block.shopify_attributes }}
                            >
                              <h2 class="rte homepage-sections--title {{ block.settings.heading--text-size }}">{{ block.settings.heading | escape }}</h2>
                            </div>
                        {% endif %}

                    {% when 'richtext' %}
                        {% if block.settings.text != blank %}
                            <div 
                              class="rte featured-row__subtext textarea text-link-animated richtext-block scaled-text" 
                              style="--text-scale: {{ block.settings.text_size }}; --text-scale-mobile: {{ block.settings.text_size }}; padding-bottom: {{ block.settings.text_bottom_spacing }}px;"
                              data-animate
                              data-animate-order="{{ forloop.index }}"
                              {{ block.shopify_attributes }}
                            >
                              {{ block.settings.text }}
                            </div>
                        {% endif %}

                    {% when 'button' %}
                        {% if block.settings.button_text != blank %}
                          {% if block.settings.override_button_colors %}
                            {% render 'button-color-overrides',
                              id: block.id,
                              style: block.settings.buttons_style,
                              text_color: block.settings.button_text_color,
                              background_color: block.settings.button_background_color
                            %}
                          {% endif %}
                          
                          <div 
                            class="rte featured-row__subtext{% if block.settings.buttons_style == 'underlined' %} text-link-animated{% endif %}"
                            style="padding-bottom: {{ block.settings.button_bottom_spacing }}px;"
                            data-animate
                            data-animate-order="{{ forloop.index }}"
                            {{ block.shopify_attributes }}
                          >
                            {% render 'dynamic-section-button',
                              id: block.id,
                              link: block.settings.button_link,
                              label: block.settings.button_text,
                              style: block.settings.buttons_style,
                              wrapper: false,
                              a_classes: 'homepage-featured-box-btn'
                            %}
                          </div>
                        {% endif %}

                    {% when 'page' %}
                        {% if block.settings.page.content %}
                            <div 
                              class="rte featured-row__subtext text-link-animated scaled-text" 
                              style="--text-scale: {{ block.settings.text_size }}; --text-scale-mobile: {{ block.settings.text_size }}; padding-bottom: {{ block.settings.page_bottom_spacing }}px;" 
                              data-animate
                              data-animate-order="{{ forloop.index }}"
                              {{ block.shopify_attributes }}
                            >
                              {{ block.settings.page.content }}
                            </div>
                        {% endif %}

                {% endcase %}

            {% endfor %}

		</div>

	</div>

</div>

</div>

{% schema %}
{
  "name": "t:sections.text--rich-text.name",
  "class": "rich-text",
  "settings": [
    {
      "type": "header",
      "content": "t:all.Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:all.Width",
      "info": "t:all.Section_width_info",
      "options": [
        {
          "value": "content",
          "label": "t:all.Content_width"
        },
        {
          "value": "full-width",
          "label": "t:all.Full_width"
        }
      ],
      "default": "content"
    },
    {
      "type": "select",
      "id": "text_alignment_desktop",
      "label": "t:all.Alignment_desktop",
      "options": [
        {
          "value": "left",
          "label": "t:all.Left"
        },
        {
          "value": "center",
          "label": "t:all.Center"
        },
        {
          "value": "right",
          "label": "t:all.Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "t:all.Alignment_mobile",
      "options": [
        {
          "value": "left",
          "label": "t:all.Left"
        },
        {
          "value": "center",
          "label": "t:all.Center"
        },
        {
          "value": "right",
          "label": "t:all.Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "t:all.Spacing_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "t:all.px",
      "default": 72
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "t:all.Spacing_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "t:all.px",
      "default": 72
    },
    {
      "type": "header",
      "content": "t:all.Color"
    },
    {
      "type": "select",
      "id": "colors",
      "label": "t:all.Color_scheme",
      "default": "white",
      "options": [
        {
          "value": "white",
          "label": "t:all.Default"
        },
        {
          "value": "light",
          "label": "t:all.First"
        },
        {
          "value": "accent",
          "label": "t:all.Second"
        },
        {
          "value": "dark",
          "label": "t:all.Third"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:all.Heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:all.Heading",
          "default": "Heading"
        },
        {
          "type": "select",
          "id": "heading--text-size",
          "label": "t:all.Font_size",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "h4", "label": "H4" },
            { "value": "h5", "label": "H5" },
            { "value": "h6", "label": "H6" }
          ],
          "default": "h3"
        },
        {
          "type": "header",
          "content": "t:all.Layout"
        },
        {
          "type": "range",
          "id": "heading_bottom_spacing",
          "label": "t:all.bottom_spacing",
          "min": 0,
          "max": 40,
          "unit": "t:all.px",
          "default": 20
        }
      ]
    },
    {
      "type": "richtext",
      "name": "t:all.Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "t:all.Text",
          "default": "<p>Use this text block to show store announcements, advertise products and collections, or simply welcome visitors to your store.</p>"
        },
        {
          "type": "range",
          "id": "text_size",
          "min": 50,
          "max": 200,
          "step": 10,
          "unit": "%",
          "label": "t:all.Font_size",
          "default": 100
        },
        {
          "type": "header",
          "content": "t:all.Layout"
        },
        {
          "type": "range",
          "id": "text_bottom_spacing",
          "label": "t:all.bottom_spacing",
          "min": 0,
          "max": 40,
          "unit": "t:all.px",
          "default": 20
        }
      ]
    },
    {
      "type": "button",
      "name": "t:all.Button",
      "settings": [
        {
          "type": "url",
          "id": "button_link",
          "label": "t:all.Button_link"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "t:all.Button_label",
          "info": "t:all.Required_to_show_the_button",
          "default": "Button"
        },
        {
          "type": "header",
          "content": "t:all.Style"
        },
        {
          "type": "select",
          "id": "buttons_style",
          "label": "t:all.button_style",
          "default": "filled",
          "options": [
            {
              "value": "filled",
              "label": "t:all.Filled"
            },
            {
              "value": "outlined",
              "label": "t:all.Outlined"
            },
            {
              "value": "underlined",
              "label": "t:all.underlined"
            }
          ]
        },
        {
          "type": "checkbox",
          "id": "override_button_colors",
          "label": "t:all.Button_color_override",
          "default": false,
          "info": "t:all.Button_color_override_info"
        },
        {
          "type": "color",
          "id": "button_background_color",
          "label": "t:all.Primary_color",
          "default": "#E68819",
          "visible_if": "{{ block.settings.override_button_colors }}"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "t:all.Secondary_color",
          "default": "#ffffff",
          "info": "t:all.Secondary_button_color_info",
          "visible_if": "{{ block.settings.override_button_colors }}"
        },
        {
          "type": "header",
          "content": "t:all.Layout"
        },
        {
          "type": "range",
          "id": "button_bottom_spacing",
          "label": "t:all.bottom_spacing",
          "min": 0,
          "max": 40,
          "unit": "t:all.px",
          "default": 20
        }
      ]
    },
    {
      "type": "page",
      "name": "t:sections.text--rich-text.blocks.page.name",
      "settings": [
        {
          "type": "page",
          "id": "page",
          "label": "t:all.Page"
        },
        {
          "type": "range",
          "id": "text_size",
          "min": 50,
          "max": 200,
          "step": 10,
          "unit": "%",
          "label": "t:all.Font_size",
          "default": 100
        },
        {
          "type": "header",
          "content": "t:all.Layout"
        },
        {
          "type": "range",
          "id": "page_bottom_spacing",
          "label": "t:all.bottom_spacing",
          "min": 0,
          "max": 40,
          "unit": "t:all.px",
          "default": 20
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.text--rich-text.presets.name",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "richtext"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": [
      "custom.overlay"
    ]
  }
}
{% endschema %}

