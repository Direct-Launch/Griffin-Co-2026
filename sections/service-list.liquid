{{ 'section-service-list.min.css' | asset_url | stylesheet_tag }}

{% liquid 
  assign wrapper_classes = ''
  assign slider_enabled = false

  if section.settings.layout_style == 'slider'
    assign slider_enabled = true
  endif

  if section.settings.layout_style == 'slider' and section.settings.hover_navigation_desktop == 'above'
    if section.settings.title != blank or section.settings.description != blank
      assign wrapper_classes = 'remove--spacing'
    endif
  endif
%}

<div
  class="service-list wrapper-spacing--v wrapper-spacing--h content-align--{{ section.settings.section_header_alignment }} color-scheme--{{ section.settings.colors }} {% if request.visual_preview_mode %}section-preview{% else %}show-on-scroll{% endif %}{% if slider_enabled %} slider-nav--{{ section.settings.hover_navigation_desktop }}{% endif %}"
  data-wetheme-section-type="service-list"
  data-wetheme-section-id="{{ section.id }}"
  style="--padding-section-top: {{ section.settings.section_padding_top }}px; --padding-section-bottom: {{ section.settings.section_padding_bottom }}px;"
>
  {% comment %} Section title and description {% endcomment %}
  {% render 'dynamic-section-header', section_title: section.settings.title, section_description: section.settings.description, alignment: section.settings.section_header_alignment %}

  {% if slider_enabled %}
    <safe-load-scripts class="hidden">
      <script src="{{ 'component-grid-slider.js' | asset_url }}" defer="defer" type="module" data-flow-load-key="grid-slider"></script>
    </safe-load-scripts>

    <div class="service-list__grid-slider-wrapper" data-grid-slider-wrapper>
      <grid-slider
        class="swiper"
        data-slides-per-view-desktop="{{ section.settings.grid-desktop }}"
        data-slides-per-view-mobile="1"
        data-grid-spacing-desktop="15"
        data-grid-spacing-mobile="0"
        data-enable-peep="false"
      >

        <!-- navigation -->
        {% assign navigation_id = 'navigation--' | append: section.id %}
        <div class="swiper-btn--wrapper small-hide swiper-btn-layout__{{ section.settings.hover_navigation_desktop }}">
          <div class="swiper-button--prev btn dynamic-section-button--{{ navigation_id }}">
            {% render 'theme-icon', icon: 'arrow-left' %}
          </div>
          <div class="swiper-button--next btn dynamic-section-button--{{ navigation_id }}">
            {% render 'theme-icon', icon: 'arrow-right' %}
          </div>
        </div>
  {% endif %}

    <div
      class="service-list__grid desktop-slider-cols-{{ section.settings.grid-desktop }}{% if slider_enabled %} service-list__grid--slider-enabled swiper-wrapper{% endif %}"
    >
      {% content_for 'blocks' %}
    </div>

  {% if slider_enabled %}
        <!-- scrollbar -->
        <div class="swiper-scrollbar large-hide"></div>
      </grid-slider>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "t:sections.service_list.name",
  "class": "section--service-list",
  "settings": [
    {
      "type": "header",
      "content": "t:all.Heading"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:all.Heading",
      "default": "Service list"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:all.Description"
    },
    {
      "type": "text_alignment",
      "id": "section_header_alignment",
      "label": "t:all.Alignment",
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:all.Layout"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "t:all.Spacing_top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "t:all.px",
      "default": 72
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "t:all.Spacing_bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "t:all.px",
      "default": 72
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "t:all.Style",
      "options": [
        {
          "value": "grid",
          "label": "t:all.Grid"
        },
        {
          "value": "slider",
          "label": "t:all.Slider"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "hover_navigation_desktop",
      "label": "t:settings_schema.Product_card.settings.hover_navigation_desktop.label",
      "visible_if": "{{ section.settings.layout_style == 'slider' }}",
      "options": [
        {
          "value": "left-and-right",
          "label": "t:settings_schema.Product_card.settings.hover_navigation_desktop.options.left_and_right"
        },
        {
          "value": "right",
          "label": "t:settings_schema.Product_card.settings.hover_navigation_desktop.options.right"
        },
        {
          "value": "above",
          "label": "t:settings_schema.Product_card.settings.hover_navigation_desktop.options.above"
        },
        {
          "value": "none",
          "label": "t:settings_schema.Product_card.settings.hover_navigation_desktop.options.none"
        }
      ],
      "default": "left-and-right"
    },
    {
      "type": "range",
      "id": "grid-desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "t:all.Columns_per_row_desktop",
      "default": 4
    },
    {
      "type": "header",
      "content": "t:all.Color"
    },
    {
      "type": "select",
      "id": "colors",
      "label": "t:all.Color_scheme",
      "default": "white",
      "options": [
        {
          "value": "white",
          "label": "t:all.Default"
        },
        {
          "value": "light",
          "label": "t:all.First"
        },
        {
          "value": "accent",
          "label": "t:all.Second"
        },
        {
          "value": "dark",
          "label": "t:all.Third"
        }
      ]
    }
  ],
  "blocks": [{"type": "_service-column"}],
  "presets": [
    {
      "name": "t:sections.service_list.name",
      "blocks": [
        {
          "type": "_service-column",
