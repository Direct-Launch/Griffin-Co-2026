    "faq_with_image_d7jKNe": {
      "type": "faq-with-image",
      "blocks": {
        "accordion_6yjBcP": {
          "type": "accordion",
          "settings": {
            "accordion_header": "What sets Griffin & Co Fine Jewellery apart?",
            "open_by_default": false,
            "text": "<p>At Griffin & Co, we are defined by our commitment to three core principles: <strong>personal service, exceptional quality, and timeless design.</strong> Unlike other high-street jewellers, we offer a truly bespoke experience.</p><p>Our experts guide you through every step, from the initial idea to the final piece, ensuring your jewellery is a perfect reflection of your story.</p>",
            "page": ""
          }
        },
        "accordion_7wMUFa": {
          "type": "accordion",
          "settings": {
            "accordion_header": "How can I see your collection?",
            "open_by_default": false,
            "text": "<p>We invite you to experience our jewellery in the way that suits you best. You can <a href=\"https://griffinfinejewellery.com/pages/schedule-an-appointment\" title=\"Schedule an Appointment\"><strong>book a private consultation </strong></a>to visit our showroom and view our collection in person. We also offer <a href=\"https://griffinfinejewellery.com/pages/home-visits\" title=\"Home Jewellery Viewing Chichester\"><strong>Home Visits </strong></a>where you can arrange for an expert jeweller to bring our collection to your home.</p>",
            "page": ""
          }
        },
        "accordion_UyYwbj": {
          "type": "accordion",
          "settings": {
            "accordion_header": "Where is your Showroom located?",
            "open_by_default": false,
            "text": "<p>Our showroom is located at <strong>64 South Street, Chichester, PO19 1EE</strong>. You can find a map, parking information, and our full opening hours on our <a href=\"https://griffinfinejewellery.com/pages/contact\" title=\"Contact Us\"><strong>Contact Us </strong></a>page.</p>",
            "page": ""
          }
        },
        "accordion_qVBaKQ": {
          "type": "accordion",
          "settings": {
            "accordion_header": "What payment methods do you accept?",
            "open_by_default": false,
            "text": "<p>We accept all major credit cards, PayPal, Apple Pay, and Google Pay for your convenience as well as cash.</p><p><strong>Finance Options:</strong> We've partnered with ClearPay to help you spread the cost of your purchase. </p>",
            "page": ""
          }
        }
      },
