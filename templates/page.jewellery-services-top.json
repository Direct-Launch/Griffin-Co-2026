        "richtext_DxWU4e": {
          "type": "richtext",
          "settings": {
            "text": "<p>When you hand us your jewellery for repair, valuation, or remodelling, it is placed directly into the hands of a master goldsmith with decades of experience. </p><p>This ensures the highest level of security, transparent communication, and absolute perfection in every detail.</p>",
            "text_size": 100,
            "text_bottom_spacing": 20
          }
        }
