            "text_bottom_spacing": 20
          }
        },
        "richtext_DxWU4e": {
          "type": "richtext",
          "settings": {
            "text": "<p>Whether you are looking to create the perfect engagement ring or reimagine unworn family jewellery, our workshop in Chichester, is where the magic happens. </p><p>We invite you to be part of every step, from the initial pencil sketch to the final polish.</p>",
            "text_size": 100,
            "text_bottom_spacing": 20
          }
        }
      },
