{
  "wrapper": "div.collection-wrapper.wrapper",
  "sections": {
    "collection-header-spotlight": {
      "type": "collection-header",
      "settings": {
        "show_breadcrumbs": true,
        "show_title": true,
        "show_description": false,
        "show_image_desktop": false,
        "min_height_desktop": "original",
        "content_position": "left",
        "caption_width_desktop": 70,
        "show_image_mobile": true,
        "min_height_mobile": "original",
        "content_position_mobile": "bottom_center",
        "enable_parallax": true,
        "enable_fade": true,
        "section_width": "full",
        "section_margin_top": 0,
        "section_margin_bottom": 20,
        "colors": "white",
        "caption_bg_color": "rgba(0,0,0,0)",
        "image_overlay_color": "#242424",
        "image_overlay_opacity": 26
      }
    },
    "navigation_banner_hM7878": {
      "type": "navigation-banner",
      "settings": {
        "title": "",
        "description": "",
        "section_header_alignment": "center",
        "banner_linklist": "",
        "buttons_style": "outlined",
        "override_button_colors": false,
        "nav_background_color": "#e68819",
        "nav_text_color": "#ffffff",
        "section_padding_top": 0,
        "section_padding_bottom": 0,
        "layout_style": "grid",
        "navigation_position": "left",
        "colors": "white"
      }
    },
    "product-grid": {
      "type": "template--collection",
      "settings": {
        "products-per-page": 10,
        "desktop-products-per-row": 3,
        "mobile-products-per-row": "1",
        "pagination_options": "pagination_default",
        "desktop_position": "sidebar",
        "enable_sorting": true,
        "enable_filtering": true,
        "enable_collection_title": false,
        "enable_collection_description": false,
        "show_swatch_filter_labels": true,
        "show_highlight": false,
        "highlight_position": "bottom",
        "highlight_icon": "heart",
        "highlight_heading": "Why we love it",
        "highlight_reference": "",
        "highlight_text_color": "rgba(0,0,0,0)",
        "highlight_background_color": "rgba(0,0,0,0)",
        "highlight_alignment": "left",
        "highlight_font_size": "medium",
        "highlight_show_border": true,
        "highlight_collapsible_tab": true,
        "highlight_open_close_icon": "plus_minus",
        "highlight_button_borders": false
      }
    },
    "rich_text_FUCJgp": {
      "type": "rich-text",
      "blocks": {
        "heading_xHEkdd": {
          "type": "heading",
          "settings": {
            "heading": "{{ collection.title }}",
            "heading--text-size": "h5",
            "heading_bottom_spacing": 20
          }
        },
        "richtext_UGjiUA": {
          "type": "richtext",
          "settings": {
            "text": "{{ collection.description }}",
            "text_size": 100,
            "text_bottom_spacing": 20
          }
        }
      },
      "block_order": [
        "heading_xHEkdd",
        "richtext_UGjiUA"
      ],
      "settings": {
        "section_width": "full-width",
        "text_alignment_desktop": "left",
        "text_alignment_mobile": "left",
        "section_padding_top": 0,
        "section_padding_bottom": 30,
        "colors": "white"
      }
    }
  },
  "order": [
    "collection-header-spotlight",
    "navigation_banner_hM7878",
    "product-grid",
    "rich_text_FUCJgp"
  ]
}
