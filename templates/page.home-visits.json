    "rich_text_intro_HV03": {
      "type": "rich-text",
      "blocks": {
        "heading_HV_01": {
          "type": "heading",
          "settings": {
            "heading": "The Luxury of Convenience in {{ page.metafields.custom.location.value }}.",
            "heading--text-size": "h3",
            "heading_bottom_spacing": 20
          }
        },
        "richtext_HV_01": {
          "type": "richtext",
          "settings": {
            "text": "<p>At Griffin & Co., we believe that the acquisition of a fine piece of jewellery should be as seamless and sophisticated as the piece itself. Our Home Visit service is designed for the discerning client who values time, privacy, and a personalised approach.</p>",
            "text_size": 100,
            "text_bottom_spacing": 20
          }
        },
        "richtext_HV_02": {
          "type": "richtext",
          "settings": {
            "text": "<p>Whether you are commissioning a bespoke engagement ring, seeking a master's touch for a cherished heirloom repair, or exploring our curated collections, we bring the entire expertise of our studio to your residence.</p>",
            "text_size": 100,
            "text_bottom_spacing": 20
          }
        }
      },
      "block_order": [
        "heading_HV_01",
        "richtext_HV_01",
        "richtext_HV_02"
      ],
      "name": "Introduction",
      "settings": {
        "section_width": "content",
        "text_alignment_desktop": "center",
        "text_alignment_mobile": "center",
        "section_padding_top": 72,
        "section_padding_bottom": 72,
        "colors": "white"
      }
    },
    "info_columns_services_HV04": {
      "type": "template--product--info-columns",
      "blocks": {
        "service_1_HV": {
          "type": "image_and_text",
