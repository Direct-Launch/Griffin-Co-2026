    "faq_home_visit_HV13": {
      "type": "faq-with-image",
      "settings": {
        "heading": "Home Visit Frequently Asked Questions",
        "image": "shopify://shop_images/FAQ_HomeVisit.jpg",
        "section_width": "full",
        "section_padding_top": 72,
        "section_padding_bottom": 72,
        "colors": "white"
      },
      "blocks": {
        "faq_1_HV": {
          "type": "faq_item",
          "settings": {
            "question": "Which areas do you cover for home visits?",
            "answer": "<p>We primarily serve Chichester, West Sussex, and the surrounding counties. For exceptional commissions, we are happy to discuss travel arrangements across the UK and internationally.</p>"
          }
        },
        "faq_2_HV": {
          "type": "faq_item",
          "settings": {
            "question": "How is security handled during a home visit?",
            "answer": "<p>Security and discretion are our highest priorities. All our consultants are fully vetted, and all items brought for viewing are fully insured. We operate with strict confidentiality.</p>"
          }
        },
        "faq_3_HV": {
          "type": "faq_item",
          "settings": {
            "question": "How long does a typical home consultation last?",
            "answer": "<p>Depending on the complexity of the project, a visit typically lasts between 60 to 90 minutes, ensuring we have ample time to explore all options without rush.</p>"
          }
        },
        "faq_4_HV": {
          "type": "faq_item",
          "settings": {
            "question": "Can I start a repair project via a home visit?",
            "answer": "<p>Yes. We can assess the piece, take precise measurements, and provide a preliminary quote and timeline before securely transporting the item to our workshop.</p>"
          }
        },
        "faq_5_HV": {
          "type": "faq_item",
          "settings": {
            "question": "Is there a fee for the home visit?",
            "answer": "<p>A consultation fee may apply depending on the location and scope of the project, which is typically credited toward the final cost of your commission or service.</p>"
          }
        }
      },
      "block_order": [
        "faq_1_HV",
        "faq_2_HV",
        "faq_3_HV",
        "faq_4_HV",
        "faq_5_HV"
      ]
    },
