            "image": "shopify://shop_images/HomeVisit_Bespoke.jpg",
            "grid_image_size": "square",
            "heading": "Bespoke Design",
            "text": "<p>From initial sketch to final polish, we guide you through the creation of a one-of-a-kind masterpiece, discussing gemstones and settings in your own environment.</p>",
            "button_link": "",
            "button_text": ""
          }
        },
        "service_2_HV": {
          "type": "image_and_text",
          "settings": {
            "image": "shopify://shop_images/HomeVisit_Repair.jpg",
            "grid_image_size": "square",
            "heading": "Repairs & Remodelling",
            "text": "<p>Trust our master goldsmiths with your most precious items. We offer secure collection and consultation for restoration and redesign of family heirlooms.</p>",
            "button_link": "",
            "button_text": ""
          }
        },
        "service_3_HV": {
          "type": "image_and_text",
          "settings": {
            "image": "shopify://shop_images/HomeVisit_Collection.jpg",
            "grid_image_size": "square",
            "heading": "Curated Collections",
            "text": "<p>Browse a selection of our signature pieces and rare gemstones, curated specifically for your tastes and presented for your private viewing.</p>",
            "button_link": "",
            "button_text": ""
          }
        }
      },
      "block_order": [
