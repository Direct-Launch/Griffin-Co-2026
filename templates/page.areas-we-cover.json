        "richtext_K8Gg6x": {
          "type": "richtext",
          "settings": {
            "text": "<p>Whether you wish to browse our curated collections of diamond jewellery, require a delicate antique repair, or want to collaborate with a master goldsmith on a bespoke engagement ring, we are here to guide you.</p>",
