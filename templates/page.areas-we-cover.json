        "richtext_HQjiBW": {
          "type": "richtext",
          "settings": {
            "text": "<p>If you are searching for a highly skilled jeweller in or around {{ page.metafields.custom.location.value }}, Griffin & Co offers a level of craftsmanship and personal service rarely found on the modern high street. </p>",
