    "faq_with_image_m73Xra": {
      "type": "faq-with-image",
      "blocks": {
        "accordion_Jg8nTk": {
          "type": "accordion",
          "settings": {
            "accordion_header": "Is there a fee for Home Visits?",
            "open_by_default": false,
            "text": "<p>We offer complimentary initial consultations for bespoke commissions within a 15-mile radius of Chichester. For repair collections or valuations, a small travel fee may apply which is deductible from the final work.</p>",
            "page": ""
          }
        },
        "accordion_GhRGXt": {
          "type": "accordion",
          "settings": {
            "accordion_header": "How long do repairs typically take?",
            "open_by_default": false,
            "text": "<p>Simple repairs like ring sizing or chain soldering are often completed within 3-5 working days. Complex restoration or stone sourcing may take 2-4 weeks.</p>",
            "page": ""
          }
        },
        "accordion_HmVJLJ": {
          "type": "accordion",
          "settings": {
            "accordion_header": "Are my items insured while in your care?",
            "open_by_default": false,
            "text": "<p><strong>Absolutely</strong>. From the moment you hand your jewellery to us (in-store or at your home) until it is returned, it is fully insured under our comprehensive jewellers block policy.</p>",
            "page": ""
          }
        },
        "accordion_xFhTbU": {
          "type": "accordion",
          "settings": {
            "accordion_header": "What payment methods do you accept?",
            "open_by_default": false,
            "text": "<p>We accept all major credit cards, PayPal, Apple Pay, and Google Pay for your convenience as well as cash.</p>",
            "page": ""
          }
        },
        "accordion_pxHnfz": {
          "type": "accordion",
          "settings": {
            "accordion_header": "Where is your Showroom located?",
            "open_by_default": false,
            "text": "<p>Our showroom is located at 64 South Street, Chichester, PO19 EE. You can find a map, parking information, and our full opening hours on our <a href=\"/pages/contact\" title=\"Contact Us\">Contact Us</a> page.</p>",
            "page": ""
          }
        }
      },
