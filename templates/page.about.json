          "type": "image_and_text",
          "settings": {
            "image": "shopify://shop_images/2.svg",
            "grid_image_size": "square",
            "heading": "Ethical & Responsible",
            "text": "<p>We believe that the journey of fine jewellery from earth to hand should benefit everyone along the way. From our in-house casting process to our stringent diamond sourcing, we ensure transparency and sustainability in every step of our manufacturing process.</p>",
            "button_link": "",
            "button_text": ""
          }
        },
        "image_and_text_J8iYhR": {
