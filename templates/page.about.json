      "disabled": true,
      "settings": {
        "layout": "left",
        "title": "Welcome to Venetia",
        "text": "<p>\"Our mission is to redefine the jewellery industry from its core, pushing boundaries, and welcoming a new era of technology focused craftsmanship.<br/><br/>Witness the evolution of fine jewellery as we challenge norms and embrace diversity, fresh designs, rare gemstones, and revolutionary techniques.</p><p>In an environment that harbours inclusivity and progression, every customer is valued, cherished and empowered.\"<br/><br/><em>- Jessica Flinn</em></p>",
        "text_alignment": "left",
        "text_alignment_mobile": "center",
        "text_overlapping_image": false,
        "desktop-heading-size": "h5",
