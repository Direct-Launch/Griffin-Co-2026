    "template_product_info_columns_6YhcwR": {
      "type": "template--product--info-columns",
      "blocks": {
        "image_and_text_9dhU9W": {
          "type": "image_and_text",
          "settings": {
            "image": "shopify://shop_images/4.svg",
            "grid_image_size": "square",
            "heading": "Creating Family Legacies",
            "text": "<p>Fine jewellery should last generations. We build pieces with longevity in mind, using the finest materials and masterful techniques. Whether crafting a new engagement ring or breathing life into unworn heirlooms, we create pieces designed to endure.</p>",
            "button_link": "",
            "button_text": ""
          }
        },
        "image_and_text_iRmCUj": {
          "type": "image_and_text",
          "settings": {
            "image": "shopify://shop_images/5.svg",
            "grid_image_size": "square",
            "heading": "In-House Expertise",
            "text": "<p>As a true maker brand, we handle production in-house. Our team consists of GIA-qualified diamond specialists, master goldsmiths, and skilled CAD designers. Your precious items never leave our premises, ensuring security and unparalleled quality control.</p>",
            "button_link": "",
            "button_text": ""
          }
        },
        "image_and_text_wajHcp": {
          "type": "image_and_text",
          "settings": {
            "image": "shopify://shop_images/6.svg",
            "grid_image_size": "square",
            "heading": "Guiding, Not Selling",
            "text": "<p>Our role is to educate and guide. Whether you are choosing between platinum and gold, or learning about diamond clarity, we provide honest, transparent advice. We are here to empower your choices in a relaxed, no-pressure environment.</p>",
            "button_link": "",
            "button_text": ""
          }
        }
      },
