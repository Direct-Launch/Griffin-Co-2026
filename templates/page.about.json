    "template_product_info_columns_9YTFAr": {
      "type": "template--product--info-columns",
      "blocks": {
        "image_and_text_BiXm8Y": {
          "type": "image_and_text",
          "settings": {
            "image": "shopify://shop_images/1.svg",
            "grid_image_size": "square",
            "heading": "Your Vision, Your Rules",
            "text": "<p>At Griffin & Co, we do things differently. We are not just retailers; we are makers. When you commission a piece with us, you aren't just buying a product—you are collaborating directly with the artisans to create an individual, enduring legacy that tells your story.</p>",
            "button_link": "",
            "button_text": ""
          }
        },
        "image_and_text_kB3gmU": {
          "type": "image_and_text",
          "settings": {
            "image": "shopify://shop_images/2.svg",
            "grid_image_size": "square",
            "heading": "Ethical & Responsible",
            "text": "<p>We believe that the journey of fine jewellery from earth to hand should benefit everyone along the way. From our in-house casting process to our stringent diamond sourcing, we ensure transparency and sustainability in every step of our manufacturing process.</p>",
            "button_link": "",
            "button_text": ""
          }
        },
        "image_and_text_J8iYhR": {
          "type": "image_and_text",
          "settings": {
            "image": "shopify://shop_images/3.svg",
            "grid_image_size": "square",
            "heading": "Inclusive & Welcoming",
            "text": "<p>Our motto is simple: whoever you are, whoever you love, and whatever your budget, you are welcome at Griffin & Co. Fine jewellery should be accessible to all, and we are here to guide you with complete respect and zero intimidation.</p>",
            "button_link": "",
            "button_text": ""
          }
        }
      },
      "block_order": [
        "image_and_text_BiXm8Y",
        "image_and_text_kB3gmU",
        "image_and_text_J8iYhR"
      ],
      "settings": {
        "title": "Our Values.",
        "description": "<p>For years, the Chichester showroom was known as Smith & Ralier, synonymous with quality. Today, Griffin & Co, a proud family-run business, retains traditional personal service with a modern bespoke design approach.</p>",
