        "custom_liquid_z7wFPR": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n/* 1. Base Container Styles (Retained) */\n.conditional-promo-box {\n  background-color: #f8f8f8; /* Light blue-gray background */\n  border: 1px solid #f8f8f8;  /* Slightly lighter border */\n  padding: 20px 24px;\n  margin: 20px 0;\n  text-align: center;\n}\n.conditional-promo-box h3 {\n  margin-top: 0;\n  margin-bottom: 8px;\n  color: #232323;\n  font-size: 1.25em;\n  font-weight: 600;\n}\n.conditional-promo-box p {\n  margin: 0 0 16px 0;\n  font-size: 1em;\n  color: #232323;\n}\n.conditional-promo-box a.read-conditions { /* Added a class to the 'Read Conditions' link */\n  margin: 0 0 16px 0;\n  font-size: 1em;\n  text-decoration: underline;\n  color: #232323;\n}\n.conditional-promo-box a.read-conditions:hover {\n  color: #555555; /* Darker hover color */\n}\n\n/* 2. NEW Button/Link Styles (Replaces .promo-code) */\n.conditional-promo-box .bundle-button {\n  background-color: #232323; /* Striking color for the button */\n  color: #ffffff; /* White text */\n  padding: 10px 20px;\n  font-size: 1.1em;\n\n  display: inline-block; /* Makes it look like a button */\n  text-decoration: none; /* Removes underline */\n  border-radius: 4px; /* Slightly rounded corners */\n  margin: 16px 0; /* Spacing for the button */\n  transition: background-color 0.3s ease;\n  border: none;\n}\n.conditional-promo-box .bundle-button:hover {\n  background-color: #FFDDA6; /* Darker color on hover */\n  color: #ffffff;\n  text-decoration: none;\n}\n</style>\n\n{% if product.metafields.custom.bundle_title.value == blank %}\n<div class=\"conditional-promo-box\">\n  <h5>Get 10% Off Your Entire Order!</h5>\n  <p><a href=\"/pages/newsletter-sign-up\">Join our newsletter</a> today and receive a special <b>10% discount code</b> for your next purchase.</p>\n</div>\n{% endif %}",
