          "settings": {
            "title": "Product details",
            "open_by_default": false,
            "text": "<table>\n  <tbody>\n    {% comment %} {%- if product.metafields.shopify['ring-size'] != blank -%}\n      <tr>\n        <th>Ring Size:</th>\n        <td>{{ product.metafields.shopify['ring-size'] | metafield_text: field: 'label' }}</td>\n      </tr>\n    {%- endif -%} {% endcomment %}\n    {%- if product.metafields.shopify['ring-design'] != blank -%}\n      <tr>\n        <th>Ring Design:</th>\n        <td>{{ product.metafields.shopify['ring-design'] | metafield_text: field: 'label' }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.custom.band_type != blank -%}\n      <tr>\n        <th>Band Type:</th>\n        <td>{{ product.metafields.custom.band_type | metafield_text }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.shopify['earring-design'] != blank -%}\n      <tr>\n        <th style=\"width:50%\">Earring Design:</th>\n        <td>{{ product.metafields.shopify['earring-design'] | metafield_text: field: 'label' }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.shopify['bracelet-design'] != blank -%}\n      <tr>\n        <th style=\"width:50%\">Bracelet Design:</th>\n        <td>{{ product.metafields.shopify['bracelet-design'] | metafield_text: field: 'label' }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.shopify['necklace-design'] != blank -%}\n      <tr>\n        <th style=\"width:50%\">Necklace Design:</th>\n        <td>{{ product.metafields.shopify['necklace-design'] | metafield_text: field: 'label' }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.custom.setting_type != blank -%}\n      <tr>\n        <th>Setting Type:</th>\n        <td>{{ product.metafields.custom.setting_type | metafield_text }}</td>\n      </tr>\n    {%- endif -%}\n    {%- if product.metafields.shopify['jewelry-material'] != blank -%}\n      <tr>\n        <th>Metal:</th>\n        <td>{{ product.metafields.shopify['jewelry-material'] | metafield_text: field: 'label' }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.custom.metal_plating != blank -%}\n      <tr>\n        <th>Metal Plating:</th>\n        <td>{{ product.metafields.custom.metal_plating | metafield_text }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.custom.gemstone != blank -%}\n      <tr>\n        <th>Gemstone Type:</th>\n        <td>{{ product.metafields.custom.gemstone | metafield_text }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.custom.gemstone_cut != blank -%}\n      <tr>\n        <th>Stone Cut/Shape:</th>\n        <td>{{ product.metafields.custom.gemstone_cut | metafield_text }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.custom.colour != blank -%}\n      <tr>\n        <th>Stone Colour:</th>\n        <td>{{ product.metafields.custom.colour | metafield_text }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.custom.clarity != blank -%}\n      <tr>\n        <th>Clarity:</th>\n        <td>{{ product.metafields.custom.clarity | metafield_text }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.custom.carat != blank -%}\n      <tr>\n        <th>Carat/Size: (total)</th>\n        <td>{{ product.metafields.custom.carat | metafield_text }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.custom.origin != blank -%}\n      <tr>\n        <th>Origin:</th>\n        <td>{{ product.metafields.custom.origin | metafield_text }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.custom.chain != blank -%}\n      <tr>\n        <th>With / Without Chain:</th>\n        <td>{{ product.metafields.custom.chain | metafield_text }}</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.custom.chain_length != blank -%}\n      <tr>\n        <th>Chain Length:</th>\n        <td>{{ product.metafields.custom.chain_length | metafield_text }}cm</td>\n      </tr>\n    {%- endif -%}\n\n    {%- if product.metafields.custom.lab_grown == true -%}\n      <tr>\n        <th>Lab Grown:</th>\n        <td>Yes</td>\n      </tr>\n    {%- endif -%}\n\n    {% comment %}\n      {%- if product.metafields.custom.dimensions != blank -%}\n        <tr>\n          <th>Dimensions (WxHxD):</th>\n          <td>\n            {% for metavalue in product.metafields.custom.dimensions.value %}\n              {{ metavalue }}\n            {% endfor %}\n          </td>\n        </tr>\n      {%- endif -%}\n    {% endcomment %}\n\n    {%- if product.metafields.custom.width != blank -%}\n      <tr>\n        <th>\n          Dimensions:\n          {%- if product.metafields.custom.width != blank -%}\n            (W\n          {%- endif -%}\n          {%- if product.metafields.custom.depth != blank -%}\n            xD\n          {%- endif -%}\n          {%- if product.metafields.custom.height != blank -%}\n            xH\n          {%- endif -%}\n          )\n        </th>\n        <td>\n          {{ product.metafields.custom.width }}\n          {%- if product.metafields.custom.depth != blank -%}\n            x {{ product.metafields.custom.depth }}\n          {%- endif -%}\n          {%- if product.metafields.custom.height != blank -%}\n            x {{ product.metafields.custom.height }}\n          {%- endif -%}\n          mm\n        </td>\n      </tr>\n    {%- endif -%}\n    {%- if product.variants.first.weight != 0 -%}\n      <tr>\n        <th>Weight:</th>\n        <td>{{ product.variants.first.weight | weight_with_unit }}</td>\n      </tr>\n    {%- endif -%}\n  </tbody>\n</table>\n{% comment %} </div> {% endcomment %}\n<style>\n  table {\n    width: 100%;\n    border-collapse: collapse;\n    border-spacing: 0;\n    table-layout: auto;\n    margin: 0;\n  }\n\n  table tr {\n    background: transparent;\n  }\n\n  table tr:nth-child(odd) {\n    background: #f1f1f1;\n  }\n\n  table td {\n    padding: 11px 13px 8px 13px;\n    text-align: left;\n  }\n.title {\n    font-family: var(--font-body-family);\n  }\n  th {\n    width: 50%;\n    text-align: left;\n  }\n  hr {\n    margin: 0;\n  }\n\n  /* .collapsible {\n  color: #232323;\n  cursor: pointer;\n  padding: 18px;\n  width: 100%;\n  border: none;\n  text-align: center;\n  outline: none;\n  font-size: 16px;\n}\n\n.content {\n  padding: 0 18px;\n  display: inline;\n  overflow: hidden;\n  background-color: #f1f1f1;\n} */\n</style>\n\n{% comment %}\n  <script>\n  var coll = document.getElementsByClassName(\"collapsible\");\n  var i;\n\n  for (i = 0; i < coll.length; i++) {\n    coll[i].addEventListener(\"click\", function() {\n      this.classList.toggle(\"active\");\n      var content = this.nextElementSibling;\n      if (content.style.display === \"block\") {\n        content.style.display = \"none\";\n      } else {\n        content.style.display = \"block\";\n      }\n    });\n  }\n  </script>\n{% endcomment %}",
