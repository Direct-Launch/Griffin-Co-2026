{% comment %}
  Accepts:
    - mega_menu_block: The mega menu block object (required)
    - link: The navigation link object (required)

  Usage:
    {% render 'mega-menu', mega_menu_block: mega-menu-block, link: link %}
{% endcomment %}

{% liquid
  assign block = mega_menu_block

  assign promo_count = 0
  if block.settings.mega_image_1 != blank
    assign promo_count = promo_count | plus: 1
  endif
  if block.settings.mega_image_2 != blank
    assign promo_count = promo_count | plus: 1
  endif
  if block.settings.mega_image_3 != blank
    assign promo_count = promo_count | plus: 1
  endif
  if block.settings.mega_image_4 != blank
    assign promo_count = promo_count | plus: 1
  endif
  if block.settings.mega_image_5 != blank
    assign promo_count = promo_count | plus: 1
  endif

  assign show_desktop_links = block.settings.show_mega_menu_links_desktop
  if show_desktop_links == nil
    assign show_desktop_links = true
  endif

  assign hide_links = false
  if link.links.size == 0 or show_desktop_links == false
    assign hide_links = true
  endif

  assign block_grid_cols = '1fr'
  assign links_grid_cols = 'repeat(5, 1fr)'

  if hide_links == false
    if promo_count == 1
      assign block_grid_cols = '2fr 1fr'
      assign links_grid_cols = 'repeat(4, 1fr)'
    elsif promo_count == 2
      assign block_grid_cols = '1.5fr 1fr'
      assign links_grid_cols = 'repeat(3, 1fr)'
    elsif promo_count >= 3
      assign block_grid_cols = '1fr 1fr'
      assign links_grid_cols = 'repeat(2, 1fr)'
    endif
  elsif hide_links and promo_count > 0
    assign block_grid_cols = '1fr'
  endif
%}

{% style %}
  [data-mega-menu-block-id="{{ block.id }}"] {
    grid-template-columns: {{ block_grid_cols }};
  }

  [data-mega-menu-block-id="{{ block.id }}"] .mega-menu--links {
    grid-template-columns: {{ links_grid_cols }};
  }

  [data-mega-menu-block-id="{{ block.id }}"] .mega-menu--promos {
    display: grid;
    grid-template-columns: repeat({{ promo_count | at_least: 1 }}, 1fr);
    gap: 20px;
    width: 100%;
  }

  {% for i in (1..5) %}
    {% assign color_key = 'overlay_text_color_promo_' | append: i %}
    .mega-menu-block .block-id-{{ block.id }} .overlay-text-on-image-promo-{{ i }},
    .mega-menu-block .block-id-{{ block.id }} .overlay-text-on-image-promo-{{ i }} a:hover {
      color: rgba({{ block.settings[color_key].rgba }}) !important;
    }
  {% endfor %}

  /* Flexbox Vertical Alignment for Icons */
  .mega-menu-link-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .mega-menu-link-wrapper p.mega-menu-link--title {
    margin-bottom: 0 !important; /* Forces the text to stay perfectly centered with the image */
    line-height: 1.2;
  }

  .mega-menu-icon {
    width: 28px;
    height: 28px;
    object-fit: contain;
    display: block;
    flex-shrink: 0;
  }
  
  .mega-menu-icon--small {
    width: 30px;
    height: 30px;
  }

  .mega-menu--links .menu-link li {
    margin-bottom: 12px;
  }
{% endstyle %}

<div class="mega-menu-block{% if hide_links and promo_count == 0 %} no--content{% if request.design_mode %} no--content-design-mode{% endif %}{% endif %}" data-mega-menu-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
  
  {% if hide_links %}
    {% if promo_count == 0 %}
      <p class="mega-menu--empty" {% unless request.design_mode %}style="visibility:hidden;"{% endunless %}>
        {{ 'layout.header.mega_menu_empty' | t }}
      </p>
    {% endif %}
  {% endif %}

  {% if hide_links == false %}
    <div class="mega-menu--links">
      {% for sub_link in link.links %}
        {%- liquid
          assign sub_icon_url = blank
          assign sub_title_down = sub_link.title | downcase | strip
          for icon_block in section.blocks
            if icon_block.type == 'menu_icon'
              assign target_down = icon_block.settings.title | downcase | strip
              if target_down == sub_title_down and icon_block.settings.icon != blank
                assign sub_icon_url = icon_block.settings.icon | image_url: width: 64
                break
              endif
            endif
          endfor
        -%}
        <li class="dropdown-submenu nav-link-animated--custom" aria-haspopup="true">
          <div class="inner">
            
            <!-- Flex Wrapper for Level 2 -->
            <div class="mega-menu-link-wrapper" style="margin-bottom: 15px;">
              {% if sub_icon_url != blank %}
                <img src="{{ sub_icon_url }}" alt="" class="mega-menu-icon" loading="lazy">
              {% endif %}
              <p class="h4 mega-menu-link--title">
                <a class="animated-link--item" href="{{ sub_link.url }}">{{ sub_link.title | escape }}</a>
              </p>
            </div>

            <ul class="menu-link">
              {% for sub_sub_link in sub_link.links %}
                {%- liquid
                  assign sub_sub_icon_url = blank
                  assign sub_sub_title_down = sub_sub_link.title | downcase | strip
                  for icon_block in section.blocks
                    if icon_block.type == 'menu_icon'
                      assign target_down = icon_block.settings.title | downcase | strip
                      if target_down == sub_sub_title_down and icon_block.settings.icon != blank
                        assign sub_sub_icon_url = icon_block.settings.icon | image_url: width: 64
                        break
                      endif
                    endif
                  endfor
                -%}
                <li>
                  <!-- Flex Wrapper for Level 3 -->
                  <div class="mega-menu-link-wrapper">
                    {% if sub_sub_icon_url != blank %}
                      <img src="{{ sub_sub_icon_url }}" alt="" class="mega-menu-icon mega-menu-icon--small" loading="lazy">
                    {% endif %}
                    <a class="animated-link--item" href="{{ sub_sub_link.url }}">{{ sub_sub_link.title | escape }}</a>
                  </div>
                </li>
              {% endfor %}
            </ul>

          </div>
        </li>
      {% endfor %}
    </div>
  {% endif %}

  {% if promo_count > 0 %}
    <div class="mega-menu--promos">
      {% for i in (1..5) %}
        {% assign mega_image_key = 'mega_image_' | append: i %}
        {% assign aspect_ratio_key = 'image_' | append: i | append: '_aspect_ratio' %}
        {% assign overlay_text_key = 'overlay_text_on_image_promo_' | append: i %}
        {% assign header_key = 'mega_image_header_' | append: i %}
        {% assign subheader_key = 'mega_image_subheader_' | append: i %}
        {% assign text_color_key = 'overlay_text_color_promo_' | append: i %}
        {% assign link_key = 'mega_image_link_' | append: i %}

        {% if block.settings[mega_image_key] != blank %}
          <div>
            {% render 'mega-menu-promo-card', 
              promo_wrapper_classes: "dropdown-submenu",
              promo_block_id: block.id,
              promo_wrapper_attr: "aria-haspopup='true'",
              promo_img: block.settings[mega_image_key],
              promo_img_crop: block.settings[aspect_ratio_key],
              promo_text_overlay: block.settings[overlay_text_key],
              promo_text_heading: block.settings[header_key],
              promo_text_subheading: block.settings[subheader_key],
              promo_text_color: block.settings[text_color_key],
              promo_link: block.settings[link_key]
            %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>