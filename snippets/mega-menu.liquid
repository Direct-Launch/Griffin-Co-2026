{% comment %}
  Renders a mega menu or a standard dropdown.
  Accepts:
  - link: {Object} The current top-level Link object.
  - blocks: {Array} The section.blocks from the header.
{% endcomment %}

{%- liquid
  assign has_mega_menu = false
  assign promo_block = null
  assign current_title = link.title | downcase | strip

  for block in blocks
    if block.type == 'mega_menu'
      assign target_title = block.settings.menu_item | downcase | strip
      if target_title == current_title
        assign has_mega_menu = true
        assign promo_block = block
        break
      endif
    endif
  endfor
-%}

{% if link.links != blank %}
  {% if has_mega_menu %}
    <!-- Mega Menu Panel -->
    <div class="mega-menu absolute top-full left-0 w-full bg-white border-t border-b border-gray-200 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50">
      <div class="container mx-auto px-6 py-10 max-w-[1400px]">
        <div class="flex flex-col lg:flex-row gap-12">
          
          <!-- Left: Link Columns -->
          <div class="flex-grow grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
            {% for childlink in link.links %}
              <div class="mega-menu__column">
                
                {%- liquid
                  assign child_icon = null
                  assign child_title = childlink.title | downcase | strip
                  for block in blocks
                    if block.type == 'menu_icon'
                      assign icon_target = block.settings.link_title | downcase | strip
                      if icon_target == child_title
                        assign child_icon = block.settings.icon_image
                        break
                      endif
                    endif
                  endfor
                -%}
                
                <!-- Level 2 Link -->
                <a href="{{ childlink.url }}" class="flex items-center gap-3 font-semibold text-gray-900 uppercase tracking-widest text-xs mb-5 hover:text-gray-500 transition">
                  {% if child_icon != blank %}
                    <img src="{{ child_icon | image_url: width: 40 }}" alt="" class="w-6 h-6 object-contain" loading="lazy">
                  {% endif %}
                  {{ childlink.title | escape }}
                </a>
                
                <!-- Level 3 Links -->
                {% if childlink.links != blank %}
                  <ul class="space-y-4">
                    {% for grandchildlink in childlink.links %}
                      {%- liquid
                        assign grandchild_icon = null
                        assign grandchild_title = grandchildlink.title | downcase | strip
                        for block in blocks
                          if block.type == 'menu_icon'
                            assign icon_target = block.settings.link_title | downcase | strip
                            if icon_target == grandchild_title
                              assign grandchild_icon = block.settings.icon_image
                              break
                            endif
                          endif
                        endfor
                      -%}
                      <li>
                        <a href="{{ grandchildlink.url }}" class="flex items-center gap-3 text-gray-600 hover:text-gray-900 transition text-sm">
                          {% if grandchild_icon != blank %}
                            <img src="{{ grandchild_icon | image_url: width: 40 }}" alt="" class="w-5 h-5 object-contain" loading="lazy">
                          {% endif %}
                          {{ grandchildlink.title | escape }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}

              </div>
            {% endfor %}
          </div>

          <!-- Right: Promotions Panel (Up to 5) -->
          <div class="flex-shrink-0 lg:max-w-[50%] flex gap-6 overflow-x-auto pb-4 lg:pb-0 scrollbar-hide">
            {% for i in (1..5) %}
              {% assign img_key = 'promo_' | append: i | append: '_image' %}
              {% assign heading_key = 'promo_' | append: i | append: '_heading' %}
              {% assign text_key = 'promo_' | append: i | append: '_text' %}
              {% assign link_key = 'promo_' | append: i | append: '_link' %}
              
              {% assign promo_img = promo_block.settings[img_key] %}
              {% assign promo_heading = promo_block.settings[heading_key] %}
              {% assign promo_text = promo_block.settings[text_key] %}
              {% assign promo_link = promo_block.settings[link_key] %}
              
              {% if promo_img != blank or promo_heading != blank %}
                <a href="{{ promo_link | default: '#' }}" class="group block w-48 lg:w-56 flex-shrink-0">
                  {% if promo_img != blank %}
                    <div class="aspect-[4/5] bg-gray-100 rounded-sm overflow-hidden mb-4">
                      <img src="{{ promo_img | image_url: width: 500 }}" alt="{{ promo_img.alt | escape }}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy">
                    </div>
                  {% endif %}
                  {% if promo_heading != blank %}
                    <h4 class="font-medium text-sm text-gray-900 group-hover:underline mb-1">{{ promo_heading | escape }}</h4>
                  {% endif %}
                  {% if promo_text != blank %}
                    <p class="text-xs text-gray-500 leading-relaxed">{{ promo_text | escape }}</p>
                  {% endif %}
                </a>
              {% endif %}
            {% endfor %}
          </div>

        </div>
      </div>
    </div>
  {% else %}
    <!-- Standard Dropdown (If no mega menu block targets this link) -->
    <ul class="absolute top-full left-0 min-w-[220px] bg-white border border-gray-100 shadow-lg py-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50">
      {% for childlink in link.links %}
        <li>
          <a href="{{ childlink.url }}" class="block px-6 py-2.5 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition">
            {{ childlink.title | escape }}
          </a>
        </li>
      {% endfor %}
    </ul>
  {% endif %}
{% endif %}