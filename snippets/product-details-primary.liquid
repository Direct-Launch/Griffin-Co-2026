{% comment %}
  Renders the first column of product details.

  Accepts:
  - product: {Object} Product Liquid object
  - section: {Object} Section Liquid object
  - current_variant: {Object} Current variant Liquid object
  - login_to_order: {Boolean} If true, show login to order button
  - on_sale: {Boolean} If true, show sale price
  - variant_compare_at_price: {String} Compare at price
  - hide_out_of_stock_variants: {Boolean} If true, hide out of stock variants
  - options_block: {Object} Options block Liquid object
  - trust_block: {Object} Trust block Liquid object
  - wrap_product: {Object} Gift wrap product Liquid object
  - full_width: {Boolean} If true, the column will take up the full width of the container
  - product_form_id: {String} Custom product form ID (optional, defaults to generated ID)
  - section_id: {String} Custom section ID (optional, defaults to section.id)
  - is_quick_view: {Boolean} If true, we are in quick view mode (optional)

  Usage:
  {% render 'product-details-primary', product: product, section: section, current_variant: current_variant, login_to_order: login_to_order, on_sale: on_sale, variant_compare_at_price: variant_compare_at_price, hide_out_of_stock_variants: hide_out_of_stock_variants, options_block: options_block, trust_block: trust_block, wrap_product: wrap_product, full_width: full_width %}
{% endcomment %}

{% liquid
  assign first_column_blocks = ''
  for block in section.blocks
    if block.settings.block_position == 'first_column'
      assign first_column_blocks = first_column_blocks | append: block.id | append: ','
    endif
  endfor

  assign first_column_blocks = first_column_blocks | split: ',' | compact
%}

{% if first_column_blocks.size > 0 %}
  {%- liquid
    assign is_onboarding = false
    if product == blank
      assign is_onboarding = true
    endif
  -%}

  {%- unless product_form_id -%}
    {%- if is_onboarding -%}
      {%- assign product_form_id = 'product-form-' | append: section.id | append: '-onboarding' -%}
    {%- else -%}
      {%- assign product_form_id = 'product-form-' | append: section.id | append: '-' | append: product.id -%}
    {%- endif -%}
  {%- endunless -%}

  {%- unless section_id -%}
    {%- assign section_id = section.id -%}
  {%- endunless -%}

  {%- liquid
    assign availability_class = 'product-details--form-wrapper---out-of-stock'
    unless is_onboarding
      if product.available
        assign availability_class = 'product-details--form-wrapper---in-stock'
      endif
    endunless
  -%}

  <div class="product-details-wrapper product-details-primary{% if full_width %} product-details-wrapper--full-width{% endif %}">
    <div class="product-details--form-wrapper {{ availability_class }}"{% if section.settings.override_form_labels_size %} style="--labels-font-size: {{ section.settings.labels_font_size }}px;"{% endif %}>
      <div class="form-vertical product--add-to-cart-form">
        {% assign spacing_classes = 'product-form-block' %}

        {% if settings.enable_breadcrumbs %}
          <div id="breadcrumbs">
            {% render 'breadcrumb' %}
          </div>
        {% endif %}

        {% for block in section.blocks %}
          {% case block.type %}
            {% when '@app' %}
              {% comment %} ===== APP BLOCK ===== {% endcomment %}
              <div 
                class="{{ spacing_classes }}" 
                style="--custom-margin-bottom: {{ section.settings.app_margin_bottom }}px" 
                id="shopify-block-{{ block.id }}" {{ block.shopify_attributes }}>
                  {% render block %}
              </div>
          {% endcase %}

          {% if block.settings.block_position == 'first_column' %}
            {% case block.type %}
              {% when 'sku' %}
                {% unless is_onboarding %}
                  {% if current_variant.sku != blank %}
                    <div
                      data-updates-on-change
                      data-update-id="item-{{ block.id }}"
                      data-block-id="{{ block.id }}"
                      class="{{ spacing_classes }} {% if current_variant.sku == "" %}js{% endif %}"
                      style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px"
                      {{ block.shopify_attributes }}
                    >
                      <span class="current-variant--sku">{{ current_variant.sku }}</span>
                    </div>
                  {% endif %}
                {% endunless %}

              {% when 'vendor' %}
                {% comment %} ===== PRODUCT VENDOR BLOCK ===== {% endcomment %}
                {% unless is_onboarding %}
                  {% if product.vendor != "" %}
                    <div 
                      data-updates-on-change
                      data-update-id="item-{{ block.id }}" 
                      class="{{ spacing_classes }}" 
                      style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                      {{ block.shopify_attributes }}
                    >
                      <span class="product__meta--vendor nav-link-animated">
                        <span class="label-font">{{ product.vendor | link_to_vendor }}</span>
                      </span>
                    </div>
                  {% endif %}
                {% endunless %}

              {% when 'title' %}
                {% comment %} ===== PRODUCT TITLE BLOCK ===== {% endcomment %}
                <div
                  data-updates-on-change
                  data-update-id="item-{{ block.id }}"
                  class="{{ spacing_classes }}"
                  style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px"
                  {{ block.shopify_attributes }}
                >
                  {% if is_onboarding %}
                    <h2 class="{{ block.settings.title_font }} product-details-product-title">{{ 'general.onboarding.product_title' | t }}</h2>
                  {% elsif is_featured_product %}
                    <a href="{{ product.url }}">
                      <h2 class="{{ block.settings.title_font }} product-details-product-title">{{ product.title | escape }}</h2>
                    </a>
                  {% else %}
                    <h1 class="{{ block.settings.title_font }} product-details-product-title">{{ product.title | escape }}</h1>
                  {% endif %}
                </div>

              {% when 'separator' %}
                {% comment %} ===== SEPARATOR BLOCK ===== {% endcomment %}
                <div class="product-form-separator {{ spacing_classes }}" style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" {{ block.shopify_attributes }}>
                </div>

              {% when 'price' %}
                {% comment %} ===== PRODUCT PRICE BLOCK ===== {% endcomment %}
                <div
                  data-updates-on-change
                  data-update-id="item-{{ block.id }}"
                  data-block-id="{{ block.id }}"
                  class="{{ spacing_classes }}" style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                  {{ block.shopify_attributes }}
                >
                  {% if is_onboarding %}
                    <div class="scaled-text product-price-group" style="--text-scale: {{ block.settings.price_font }}; --text-scale-mobile: {{ block.settings.price_font }};">
                      <span id="ProductPrice">
                        <span class="money">
                          {% if settings.show_currency_code %}
                            {{ 1699 | money_with_currency }}
                          {% else %}
                            {{ 1699 | money }}
                          {% endif %}
                        </span>
                      </span>
                    </div>
                  {% else %}
                    {% unless login_to_order %}
                      <div class="scaled-text product-price-group" style="--text-scale: {{ block.settings.price_font }}; --text-scale-mobile: {{ block.settings.price_font }};">
                        {% if on_sale %}
                          <span class="visually-hidden">{{ 'products.general.sale_price' | t }}</span>
                          <p id="ComparePrice" class="compare-at-price sale-price{% if on_sale %} on-sale{% else %} js{% endif %}">
                            <span class="money">{{ variant_compare_at_price }}</span>
                          </p>
                        {% endif %}

                        {% render 'product-pricing', current_variant: current_variant %}
                        {% render 'unit-price-measurement-variant', variant: current_variant %}
                      </div>

                      {%- liquid
                        if cart.taxes_included and block.settings.tax_included
                          assign show_tax_included = true
                        endif
                        if shop.shipping_policy.body != blank and block.settings.shipping_policy
                          assign show_shipping_policy = true
                        endif
                      -%}
                      {%- if show_tax_included or show_shipping_policy -%}
                        <div class="product-page__policies rte text-link-animated">
                          {%- if show_tax_included -%}
                            {{ 'products.product.include_taxes' | t }}
                          {%- endif -%}
                          {%- if show_shipping_policy -%}
                            {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                          {%- endif -%}
                        </div>
                      {%- endif -%}

                      <div class="shopify-payment-terms__container">
                        {%- assign product_form_installment_id = 'product-form-installment-' | append: section_id -%}
                        {%- form 'product', product, id: product_form_installment_id -%}
                          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                          {{ form | payment_terms }}
                        {%- endform -%}
                      </div>
                    {% endunless %}
                  {% endif %}
                </div>

                {% when 'product-description' %}
                  {% comment %} ===== PRODUCT DESCRIPTION BLOCK ===== {% endcomment %}
                  {% if is_onboarding %}
                    <div 
                      class="product-description {{ spacing_classes }}" 
                      style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                      {{ block.shopify_attributes }}>
                      <div class="text-link-animated">{{ 'general.onboarding.product_description' | t }}</div>
                    </div>
                  {% else %}
                    {% assign clean_product_description = product.description | strip | strip_html %}
                    {% if clean_product_description != "" %}
                      <div 
                        data-updates-on-change
                        data-update-id="item-{{ block.id }}"
                        class="product-description {{ spacing_classes }}{% if block.settings.collapsible_tab %} product-description--collapsible collapsible{% if block.settings.margin_bottom == 0 %} no_margin_bottom{% endif %}{% endif %}" 
                        style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                        {{ block.shopify_attributes }}>
                        {% unless block.settings.collapsible_tab %}
                          <div class="text-link-animated">{{ product.description }}</div>
                        {% else %}
                          {% liquid
                            if block.settings.custom_icon
                              assign icon = block.settings.custom_icon
                              assign custom_icon = true
                            else
                              assign icon = block.settings.icon
                              assign custom_icon = false
                            endif 
                          %}

                          {% render 'collapsible-tab', icon: icon, custom_icon: custom_icon, heading: block.settings.heading, content: product.description, open_close_icon: block.settings.open_close_icon, open_by_default: block.settings.open_by_default, heading_classes: 'label-font' %}
                        {% endunless %}
                      </div>
                    {%- endif -%}
                  {% endif %}

                {% when 'linked-products' %}
                  {% comment %} ===== LINKED PRODUCTS BLOCK ===== {% endcomment %}
                  {% unless is_onboarding %}
                    <safe-load-scripts class="hidden">
                      <script src="{{ 'component-linked-products.js' | asset_url }}" defer="defer" type="module" data-flow-load-key="linked-products"></script>
                    </safe-load-scripts>

                    {% if block.settings.linked_products != blank %}
                      {% assign linked_products_ids = block.settings.linked_products | map: 'id' %}
                      {% unless linked_products_ids.size == 1 and linked_products_ids contains product.id %}
                        {% assign option_index =  0 %}
                        {% assign swatches_aspect_ratio = block.settings.swatches_aspect_ratio %}
                        <linked-products 
                          data-updates-on-change
                          data-update-id="item-{{ block.id }}" 
                          class="{{ spacing_classes }} linked-products" 
                          style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                          {{ block.shopify_attributes }}
                        >
                          <div class="swatch linked-products-swatch" data-option-index="{{ option_index }}">

                            {% if block.settings.option_name != blank %}
                              <div class="header linked-products--title-wrapper">
                                <span class="linked-option-label label-font">{{ block.settings.option_name }}</span>
                                <span class="linked-option-product-title"></span>
                              </div>
                            {% endif %}
                      
                            <div class="swatch-items-wrapper">
                              {% liquid
                                for linked_product in block.settings.linked_products
                                  assign  escaped_linked_product_variant = linked_product.title | split: ' - ' | last | escape
                                  if linked_product.id == product.id
                                    assign checked = true
                                    assign redirect = blank
                                  else
                                    assign checked = false
                                    assign redirect = linked_product.url
                                  endif
                                  if linked_product.media and linked_product.media.size > 0
                                    assign image_url = linked_product.media[0].preview_image | image_url: width: 250
                                    assign img_aspect_ratio = linked_product.media[0].preview_image.aspect_ratio
                                  elsif linked_product.featured_image != blank
                                    assign image_url = linked_product.featured_image | image_url: width: 250
                                    assign img_aspect_ratio = linked_product.featured_image.aspect_ratio
                                  else
                                    assign image_url = blank
                                    assign img_aspect_ratio = blank
                                  endif
                                  render 'image-swatch', image_url: image_url, value: escaped_linked_product_variant, checked: checked, available: linked_product.available, size: block.settings.swatches_size, aspect_ratio: swatches_aspect_ratio, img_aspect_ratio: img_aspect_ratio, variation_redirect: redirect, section: section, option_index: option_index
                                endfor
                              %}
                            </div>
                          </div>
                        </linked-products>
                      {% endunless %}
                    {% endif %}
                  {% endunless %}

              {% when 'options' %}
                {% comment %} ===== PRODUCT OPTIONS BLOCK ===== {% endcomment %}
                {% unless is_onboarding %}
                  {%- liquid
                    assign show_size_guide_below_options = false
                    if block.settings.size_option_name == '' and block.settings.size_guide_page != blank
                      assign show_size_guide_below_options = true
                    endif

                    assign block_has_content = true
                    if product.has_only_default_variant and show_size_guide_below_options == false
                      assign block_has_content = false
                    endif
                  -%}                
                  <div
                    data-product-options
                    data-updates-on-change
                    data-update-id="item-{{ block.id }}"
                    data-block-id="{{ block.id }}"
                    class="{{ spacing_classes }}" 
                    {% if block_has_content %}
                      style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px"
                    {% endif %}
                  >
                    {% render 'product-options', product: product, 
                      size_option_name: block.settings.size_option_name, 
                      size_guide_page: block.settings.size_guide_page,
                      size_guide_label: block.settings.size_guide_label,
                      variant_style: options_block.settings.variant_style, 
                      section_id: section_id, 
                      current_variant: current_variant, 
                      hide_out_of_stock_variants: hide_out_of_stock_variants, 
                      block_attributes: options_block.shopify_attributes,
                      swatch_size: options_block.settings.swatch_size
                    %}

                    {% if show_size_guide_below_options %}
                      <div data-size-guide-below-options{% if product.has_only_default_variant %} class="no-spacing"{% endif %}>
                        <safe-load-scripts class="hidden">
                          <script src="{{ 'component-size-guide-link.js' | asset_url }}" defer="defer" type="module" data-flow-load-key="size-guide-link"></script>
                        </safe-load-scripts>
                      
                        <size-guide-link id="size-guide" class="text-link-animated">
                          <a data-size-guide-link id="size-guide-link" tabindex="0" href="{{ block.settings.size_guide_page.url }}">{{ block.settings.size_guide_label | default: block.settings.size_guide_page.title }}</a>
                        </size-guide-link>
                      </div>
                    {% endif %}

                    {% if block.settings.size_guide_override_heading_font_size %}
                      {% assign min_heading_size = 16 %}
                      {% assign base_size = block.settings.size_guide_heading_font_size %}
                      <style>
                        size-guide-drawer {
                          --h1-size: {{ base_size | times: 1.25 | round | at_least: min_heading_size | append: 'px' }};
                          --h1-size-mobile: {{ base_size | times: 1.25 | round | at_least: min_heading_size | append: 'px' }};
                          --h2-size: {{ base_size | at_least: min_heading_size | append: 'px' }};
                          --h2-size-mobile: {{ base_size | at_least: min_heading_size | append: 'px' }};
                          --h3-size: {{ base_size | times: 0.875 | round | at_least: min_heading_size | append: 'px' }};
                          --h3-size-mobile: {{ base_size | times: 0.875 | round | at_least: min_heading_size | append: 'px' }};
                          --h4-size: {{ base_size | times: 0.75 | round | at_least: min_heading_size | append: 'px' }};
                          --h4-size-mobile: {{ base_size | times: 0.75 | round | at_least: min_heading_size | append: 'px' }};
                          --h5-size: {{ base_size | times: 0.625 | round | at_least: min_heading_size | append: 'px' }};
                          --h5-size-mobile: {{ base_size | times: 0.625 | round | at_least: min_heading_size | append: 'px' }};
                          --h6-size: {{ base_size | times: 0.5 | round | at_least: min_heading_size | append: 'px' }};
                          --h6-size-mobile: {{ base_size | times: 0.5 | round | at_least: min_heading_size | append: 'px' }};
                        }
                      </style>
                    {% endif %}
                  </div>
                {% endunless %}

              {% when 'complementary-products' %}
                {% unless is_quick_view or is_onboarding %}
                  {% comment %} ===== COMPLEMENTARY PRODUCTS BLOCK ===== {% endcomment %}
                  <div 
                    data-updates-on-change
                    data-update-id="item-{{ block.id }}" 
                    class="complementary-products hidden {{ spacing_classes }}{% if block.settings.collapsible_tab %} collapsible{% if block.settings.margin_bottom == 0 %} no_margin_bottom{% endif %}{% endif %} show-on-scroll show-on-scroll--nested" 
                    style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                    {{ block.shopify_attributes }}
                  >
                    {%- render 'complementary-products-block', title: block.settings.title, products_limit: block.settings.products_limit, collapsible: block.settings.collapsible_tab, open_close_icon: block.settings.open_close_icon, tab_open_by_default: block.settings.open_by_default, custom_icon: block.settings.custom_icon, icon: block.settings.icon, id: block.id -%}
                  </div>
                {% endunless %}

              {% when 'cross-sells' %}
                {% unless is_quick_view or is_onboarding %}
                  {% comment %} ===== CROSS SELL BLOCK ===== {% endcomment %}
                  {% if block.settings.cross_sell_product_1.available or block.settings.cross_sell_product_2.available or block.settings.cross_sell_product_3.available %}
                    <div 
                      data-updates-on-change
                      data-update-id="item-{{ block.id }}" 
                      class="cross-sell {{ spacing_classes }}{% if block.settings.collapsible_tab %} collapsible{% if block.settings.margin_bottom == 0 %} no_margin_bottom{% endif %}{% endif %} show-on-scroll show-on-scroll--nested" 
                      style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                      {{ block.shopify_attributes }}
                    >
                      {%- assign cross_sells_products = block.settings.cross_sell_product_1 | append: ',' | append: block.settings.cross_sell_product_2 | append: ',' | append: block.settings.cross_sell_product_3 | split: ',' | compact -%}
                      <div class="cross-sell-block">
                        {% comment %} {% unless block.settings.collapsible_tab %}
                          {% render 'cross-sells', title: block.settings.title, cross_sells_products: cross_sells_products, id: block.id, main_product_url: product.url %}
                        {% else %}
                          {% liquid
                            if block.settings.custom_icon
                              assign icon = block.settings.custom_icon
                              assign custom_icon = true
                            else
                              assign icon = block.settings.icon
                              assign custom_icon = false
                            endif 
                          %}

                          <div class="collapsible-tab{% if block.settings.open_by_default %} open{% endif %}">
                            <collapsible-button tabindex="0">
                              <div class="summary">
                                {% render 'text-with-icon', icon: icon, custom_icon: custom_icon, text: block.settings.title, text_classes: 'label-font' %}
                                <span class="inline-icon--wrapper icon--right">
                                  {% if block.settings.open_close_icon == "plus_minus" %}
                                    {% render 'theme-icon', icon: 'plus', iconClasses: 'plus-icon' %}
                                    {% render 'theme-icon', icon: 'minus', iconClasses: 'minus-icon' %}
                                  {% elsif block.settings.open_close_icon == "caret" %}
                                    {% render 'theme-icon', icon: 'chevron_down', iconClasses: 'chevron-down' %}
                                  {% endif %}
                                </span>
                              </div>
                            </collapsible-button>
                        
                            <div class="collapsible-content">
                              <div class="content rte">
                                {% render 'cross-sells', title: blank, cross_sells_products: cross_sells_products, id: block.id, main_product_url: product.url %}
                              </div>
                            </div>
                          </div>

                          <safe-load-scripts class="hidden">
                            <script src="{{ 'component-collapsible-button.js' | asset_url }}" type="module" defer="defer" data-flow-load-key="component-collapsible-button"></script>
                          </safe-load-scripts>
                        {% endunless %} {% endcomment %}
                      </div>
                    </div>
                  {% endif %}
                {% endunless %}

              {% when 'collapsible-tab' %}
                {% comment %} ===== COLLAPSIBLE TAB BLOCK ===== {% endcomment %}
                {% liquid
                  if block.settings.custom_icon
                    assign icon = block.settings.custom_icon
                    assign custom_icon = true
                  else
                    assign icon = block.settings.icon
                    assign custom_icon = false
                  endif 
                %}
                
                {% assign content = block.settings.text %}
                {% if block.settings.page.content %}
                  {% assign content = content | append: block.settings.page.content %}
                {% endif %}

                {%- if content != blank -%}

                  <div 
                    data-updates-on-change
                    data-update-id="item-{{ block.id }}" 
                    class="collapsible-tab-container collapsible {{ spacing_classes }}{% if block.settings.margin_bottom == 0 %} no_margin_bottom{% endif %}" 
                    style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                    {{ block.shopify_attributes }}
                  >
                    {% render 'collapsible-tab', icon: icon, custom_icon: custom_icon, heading: block.settings.heading, content: content, open_close_icon: block.settings.open_close_icon, open_by_default: block.settings.open_by_default, heading_classes: 'label-font', block_id: block.id %}
                  </div>

                {%- endif -%}

              {% when 'giftwrap' %}
                {% comment %} ===== GIFT WRAP BLOCK ===== {% endcomment %}
                {% unless is_onboarding %}
                  {%- if settings.giftwrap_product_selector > '' and product.available and wrap_product -%}
                    {% if wrap_product.available %}
                      
                      {% liquid 
                        assign field_id = "checkbox-field-" | append: block.id
                        assign giftwrap_label = settings.giftwrap_label_text | escape
                        assign giftwrap_name = 'products.general.giftwrap_label' | t
                        assign field_name = 'properties[' | append: giftwrap_name | append: ']'
                      %}

                      <div class="{{ spacing_classes }} product__meta--giftwrap" style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" {{ block.shopify_attributes }}>
                        {% render 'form-input--checkbox', id: field_id, form_id: product_form_id, name: field_name, label_text: giftwrap_label %}
                      </div>
                    {% endif %}
                  {%- endif -%}
                {% endunless %}

              {% when 'quantity' %}
                {% comment %} ===== QUANTITY BLOCK ===== {% endcomment %}
                <div
                  data-updates-on-change 
                  data-update-id="item-{{ block.id }}"
                  data-block-id="{{ block.id }}"
                  class="{{ spacing_classes }} {% if section.settings.image_size == 'large' %}col-md-12{% else %}col-md-6{% endif %} col-sm-12 col-xs-12" 
                  style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                  {{ block.shopify_attributes }}>
                  {% render 'quantity-input' product: product, section_id: section_id %}
                </div>

              {% when 'product_resources' %}
                {% unless is_quick_view %}
                  {% comment %} ===== RESOURCES BLOCK ===== {% endcomment %}
                  {% if block.settings.first_button_label != blank or block.settings.second_button_label != blank or block.settings.third_button_label != blank or block.settings.fourth_button_label != blank or block.settings.fifth_button_label != blank %}
                  {% if block.settings.override_button_colors %}
                    {% render 'button-color-overrides',
                      id: block.id,
                      style: block.settings.button_style,
                      text_color: block.settings.button_text_color,
                      background_color: block.settings.button_background_color
                    %}
                  {% endif %}

                  <div 
                    data-updates-on-change
                    data-update-id="item-{{ block.id }}"
                    data-block-id="{{ block.id }}"
                    class="resource-button__wrapper {{ spacing_classes }}{% if block.settings.margin_bottom == 0 %} no_margin_bottom{% endif %}{% if block.settings.button_style == 'underlined' %} text-link-animated{% endif %}"
                    style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" {{ block.shopify_attributes }}
                  >
                    {%- liquid
                      assign button_classes = 'product-block-button'
                      assign modal_button_classes = 'product-block-modal'
                      assign modal_button_attributes = 'data-modal-button'
                    -%}

                    {% comment %} === First Button {% endcomment %}
                    {% if block.settings.first_button_label != blank %}
                      {% liquid 
                        assign button_has_icon = false
                        assign button_icon = ''
                        unless block.settings.first_button_icon == 'none'
                          assign button_has_icon = true
                          assign button_icon = block.settings.first_button_icon
                        endunless
                      %}

                      {% comment %} Content type link {% endcomment %}
                      {% if block.settings.first_button_content_type == 'link' %}
                        {%- liquid
                          if block.settings.first_button_open_in_new_tab
