              {% when 'trust_badges' %}
                {% comment %} ===== TRUST BADGES BLOCK ===== {% endcomment %}
                {%- if trust_block.settings.trust-badge -%}
                  <div 
                    data-updates-on-change
                    data-update-id="item-{{ block.id }}" 
                    class="{{ spacing_classes }} trust-badge-container" 
                    style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                    {{ block.shopify_attributes }}
                  >
                    {% capture styles %}width: {{ trust_block.settings.trust-badge_max_width | escape }}px;{% endcapture %}
                    {% render 'responsive-image', image: trust_block.settings.trust-badge, class: 'trust-badge', blur: false, styles: styles %}
                  </div>
                {%- endif -%}

              {% when 'product_meta' %}
                {% comment %} ===== PRODUCT META BLOCK ===== {% endcomment %}
                {% unless is_onboarding %}
                  {%- if product.tags.size > 0 or product.collections.size > 0 or product.type != "" -%}
                    <div 
                      data-updates-on-change
                      data-update-id="item-{{ block.id }}" 
                      class="{{ spacing_classes }} product__meta" 
                      style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                      {{ block.shopify_attributes }}
                    >
                      {% if product.tags.size > 0 %}
                        <div class="product__meta--tags nav-link-animated--custom">
                          <span><strong>{{ 'products.product.tags' | t }}:</strong></span>
                          {% for tag in product.tags %}
                            <a class="animated-link--item" href="{{ routes.all_products_collection_url }}/{{ tag | handleize }}"><span>{{ tag }}</span></a>{% if forloop.last == false %}, {% endif %}
                          {% endfor %}
                        </div>
                      {% endif %}

                      {% if product.collections.size > 0 %}
                        <div class="product__meta--tagss nav-link-animated--custom">
                          <span><strong>{{ 'products.product.category' | t }}:</strong> </span>
                          {% for collection in product.collections %}
                            <a class="animated-link--item" href="{{ collection.url }}"><span>{{ collection.title }}</span></a>{% if forloop.last == false %}, {% endif %}
                          {% endfor %}
                        </div>
                      {% endif %}

                      {% if product.type != "" %}
                        <div class="product__meta--type">
                          <span><strong>{{ 'products.product.type' | t }}: </strong></span>
                          <span>{{ product.type }}</span>
                        </div>
                      {% endif %}
                    </div>
                  {%- endif -%}
                {% endunless %}

              {% when 'social_sharing' %}
                {% comment %} ===== SOCIAL SHARING BLOCK ===== {% endcomment %}
                {%- if settings.share_facebook or settings.share_x or settings.share_pinterest %}
                  <div
                    data-updates-on-change
                    data-update-id="item-{{ block.id }}"
                    data-block-id="{{ block.id }}"
                    class="{{ spacing_classes }}" 
                    style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                    {{ block.shopify_attributes }}
                  >
                    {% render 'social-share' %}
                  </div>
                {%- endif -%}

              {% when 'custom_liquid' %}
                {% comment %} ===== CUSTOM LIQUID BLOCK ===== {% endcomment %}
                {%- if block.settings.custom_liquid != blank -%}
                  <div class="{{ spacing_classes }} custom-liquid rte text-link-animated" style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" {{ block.shopify_attributes }}>{{ block.settings.custom_liquid }}</div>
                {%- endif -%}

              {% when 'product-rating' %}
                {% comment %} ===== PRODUCT RATING BLOCK ===== {% endcomment %}
                {% if block.settings.rating != blank %}
                  <div 
                    data-updates-on-change
                    data-update-id="item-{{ block.id }}" 
                    class="{{ spacing_classes }} product-rating" 
                    style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                    {{ block.shopify_attributes }}
                  >
                    {% if block.settings.rating-label != blank %}
                      <p class="rating-label label-font">{{ block.settings.rating-label }}</p>
                      {% assign rating_aria_label = block.settings.rating-label %}
                    {% else %}
                      {% assign rating_aria_label = "Rating" %}
                    {% endif %}

                    {% if block.settings.rating-icon-full %}

                      {% liquid
                        assign rating_decimal = 0
                        assign decimal = block.settings.rating | modulo: 1
                        if decimal >= 0.3 and decimal <= 0.7
                          assign rating_decimal = 0.5
                        elsif decimal > 0.7
                          assign rating_decimal = 1
                        endif

                        assign full_icons = block.settings.rating | floor | plus: rating_decimal | floor
                        assign empty_icons = block.settings.rating-max | round | minus: full_icons
                        if rating_decimal == 0.5
                          assign empty_icons = empty_icons | minus: 1
                        endif
                      %}

                      <div class="rating-icons" role="img" aria-label="{{ rating_aria_label }} - {{ block.settings.rating }} out of {{ block.settings.rating-max }}">
                        {% for i in (1..full_icons) %}
                          <div class="rating-icons__icon" aria-hidden="true">
                            {% render 'responsive-image', image: block.settings.rating-icon-full %}
                          </div>
                        {% endfor %}

                        {% if block.settings.rating-icon-empty %}

                          {% if rating_decimal == 0.5 %}
                            <div class="rating-icons__icon rating-icons__icon--half" aria-hidden="true">
                              <div class="rating-icons__image--full">
                                {% render 'responsive-image', image: block.settings.rating-icon-full %}
                              </div>
                              <div class="rating-icons__image--empty">
                                {% render 'responsive-image', image: block.settings.rating-icon-empty %}
                              </div>
                            </div>
                          {% endif %}

                          {% for i in (1..empty_icons) %}
                            <div class="rating-icons__icon" aria-hidden="true">
                              {% render 'responsive-image', image: block.settings.rating-icon-empty %}
                            </div>
                          {% endfor %}

                        {% endif %}                          
                      </div>
                    {% else %}
                      <p>{{ block.settings.rating }} / {{ block.settings.rating-max }}</p>
                    {% endif %}
                  </div>
                {% endif %}

              {% when 'image-offer' %}
                {% comment %} ===== IMAGE OFFER BLOCK ===== {% endcomment %}
                <div 
                  data-updates-on-change
                  data-update-id="item-{{ block.id }}"
                  class="{{ spacing_classes }} image-offer-container" 
                  style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                  {{ block.shopify_attributes }}
                >
                  {% if block.settings.link != blank and block.settings.image != blank %}
                    <a href="{{ block.settings.link }}" class="image-offer-container--is-link">
                  {% endif %}

                  {% if block.settings.image == blank %}
                      {{ 'lifestyle-1' | placeholder_svg_tag: 'icon icon--placeholder block-radius' }}
                  {% else %}
                      {% render 'responsive-image', image: block.settings.image, class: 'block-radius' %}
                  {% endif %}

                  {% if block.settings.link != blank and block.settings.image != blank %}
                    </a>
                  {% endif %}
                </div>

              {% when 'text-with-icon' %}
                {% comment %} ===== TEXT WITH ICON BLOCK ===== {% endcomment %}
                {% liquid
                  if block.settings.custom_icon
                    assign icon = block.settings.custom_icon
                    assign custom_icon = true
                  else
                    assign icon = block.settings.icon
                    assign custom_icon = false
                  endif

                  if block.settings.margin_bottom == 0
                    assign classes = 'no_margin_bottom'
                  endif
                %}

                {% capture styles %}
                  style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px;{% if block.settings.text_color != 'rgba(0,0,0,0)' %} color: rgba({{ block.settings.text_color.rgba }}); --text-color: rgba({{ block.settings.text_color.rgba }});{% endif %}{% if block.settings.override_text_and_icon_size %} font-size: {{ block.settings.text_and_icon_size }}px; --inline-icon-size: {{ block.settings.text_and_icon_size }}px;{% endif %}"
                {% endcapture %}

                {%- if block.settings.text != blank -%}
                  <div class="{{ spacing_classes }}" data-updates-on-change data-update-id="item-{{ block.id }}" {{ styles }}>
                    {% render 'text-with-icon', icon: icon, 
                      custom_icon: custom_icon, 
                      text: block.settings.text, 
                      link: block.settings.link, 
                      borders: true, 
                      block_attributes: block.shopify_attributes,
                      classes: classes
                    %}
                  </div>
                {%- endif -%}

              {% when 'text-with-icon-group' %}
                {% comment %} ===== TEXT WITH ICON GROUP BLOCK ===== {% endcomment %}
                {% liquid
                  if block.settings.margin_bottom == 0
                    assign classes = 'no_margin_bottom'
                  endif
                %}

                {% capture styles %}
                  style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px;{% if block.settings.text_color != 'rgba(0,0,0,0)' %} color: rgba({{ block.settings.text_color.rgba }}); --text-color: rgba({{ block.settings.text_color.rgba }});{% endif %}{% if block.settings.override_text_and_icon_size %} font-size: {{ block.settings.text_and_icon_size }}px; --inline-icon-size: {{ block.settings.text_and_icon_size }}px;{% endif %}"
                {% endcapture %}

                <div class="{{ spacing_classes }} product-block-text-with-icon-group" data-updates-on-change data-update-id="item-{{ block.id }}" {{ styles }} {{ block.shopify_attributes }}>
                  {% for i in (1..3) %}
                    {% assign text_key = 'text_' | append: i %}
                    {% assign link_key = 'link_' | append: i %}
                    {% assign icon_key = 'icon_' | append: i %}
                    {% assign custom_icon_key = 'custom_icon_' | append: i %}
                    {%- if block.settings[text_key] != blank -%}
                      {% liquid
                        if block.settings[custom_icon_key]
                          assign icon = block.settings[custom_icon_key]
                          assign custom_icon = true
                        else
                          assign icon = block.settings[icon_key]
                          assign custom_icon = false
                        endif
                      %}
                      {% render 'text-with-icon', icon: icon, 
                        custom_icon: custom_icon, 
                        text: block.settings[text_key], 
                        link: block.settings[link_key], 
                        borders: true,
                        classes: classes
                      %}
                    {%- endif -%}
                  {% endfor %}
                </div>

              {% when 'stock-level-indicator' %}
                {% comment %} ===== STOCK LEVEL INDICATOR BLOCK ===== {% endcomment %}
                <div
                  data-updates-on-change
                  data-update-id="item-{{ block.id }}"
                  data-block-id="{{ block.id }}"
                  class="{{ spacing_classes }}" 
                  style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px"
                >
                  {% render 'stock-level-indicator', 
                    block_attributes: block.shopify_attributes,
                    stock_product: product,
                    stock_variant: current_variant,
                    stock_style: block.settings.stock-level-indicator-style,
                    stock_bar_color: block.settings.bar-indicator-color,
                    stock_indicator_animation: block.settings.stock_indicator_animation,
                    stock_amt: block.settings.stock-range,
                    stock_notice: block.settings.stock-level-notice,
                    show_stock_count: block.settings.show-stock-count,
                    preorder_message: block.settings.preorder-message,
                    in_stock_message: block.settings.in-stock-message,
                    low_stock_message: block.settings.low-stock-message,
                    out_of_stock_message: block.settings.out-of-stock-message
                  %}
                </div>

              {%- when 'star_rating' -%}
                {% comment %} ===== STAR RATING BLOCK ===== {% endcomment %}
                {% unless is_onboarding %}
                  {% liquid 
                    if product.metafields.loox.avg_rating != blank
                      assign rating_value = product.metafields.loox.avg_rating
                    elsif product.metafields.yotpo.reviews_average != blank 
                      assign rating_value = product.metafields.yotpo.reviews_average
                    elsif product.metafields.stamped.reviews_average != blank
                      assign rating_value = product.metafields.stamped.reviews_average
                    elsif product.metafields.reviews.rating.value != blank
                      assign rating_value = product.metafields.reviews.rating.value.rating
                    endif

                    assign no_reviews = false
                    if rating_value == blank
                      assign no_reviews = true
                    endif
                  %}
                  <div 
                    data-updates-on-change
                    data-update-id="item-{{ block.id }}" 
                    class="{{ spacing_classes }}" 
                    style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px" 
                    {{ block.shopify_attributes }}
                  >
                    {%- unless no_reviews and block.settings.show_product_rating_if_no_reviews == false -%}
                      {% render 'reviews-star-rating',
                        rating_product: product,
                        show_product_rating_if_no_reviews: block.settings.show_product_rating_if_no_reviews,
                        show_rating_as: block.settings.show_rating_as,
                        star_color: settings.star_rating_color,
                        star_size: block.settings.star_size,
                        no_reviews_label: block.settings.no_reviews_label,
                        classes: spacing_classes
                      %}
                    {%- endunless -%}
                  </div>
                {% endunless %}
              
              {% when 'out_of_stock_email_form' %}
                {% comment %} ===== OUT OF STOCK EMAIL FORM BLOCK ===== {% endcomment %}
                {% unless is_onboarding %}
                  <div 
                    data-updates-on-change
                    data-update-id="item-{{ block.id }}" 
                    data-block-id="{{ block.id }}"
                    style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px"
                    class="{{ spacing_classes }}"  
                    {{ block.shopify_attributes }}
                  >
                    <div{% if current_variant.available == true %} hidden{% endif %}>
                      {% render 'out-of-stock-form', product: product %}
                      <div class="shopify-disclaimer--hidden">{{ 'shopify.online_store.spam_detection.disclaimer_html' | t }}</div>
                    </div>
                  </div>
                {% endunless %}
              {% when 'text' %}
                {% if block.settings.title != blank %}
                  {% liquid 
                    assign text_color = 'rgba(' | append: block.settings.text_color.rgba | append: ')'
                    assign link_color = 'rgba(' | append: block.settings.text_color.rgba | append: ')'
                    assign link_border_color = 'color-mix(in srgb, ' | append: text_color | append: ', transparent 50%)'
                  %}

                  <div
                    data-updates-on-change
                    data-update-id="item-{{ block.id }}"
                    data-block-id="{{ block.id }}"
                    class="{{ spacing_classes }} product-block-richtext text-link-animated richtext-block" 
                    style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px;{% if block.settings.text_color != 'rgba(0,0,0,0)' %} color: {{ text_color }}; --link-color: {{ link_color }}; --link-border-color: {{ link_border_color }};{% endif %}" 
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.title }}
                  </div>
                {% endif %}
              {% when 'file_upload' %}
                {{ 'component-file-upload.min.css' | asset_url | stylesheet_tag }}
                {% liquid
                  assign field_id = 'upload-field-' | append: block.id
                  assign label_formatted = block.settings.title | escape
                  assign field_name = 'properties[' | append: label_formatted | append: ']'
                  assign secondary_label = 'general.forms.max_filesize_20mb' | t

                  if block.settings.file_upload_required == true
                    assign file_upload_label = block.settings.title | append: ' *'
                  else 
                    assign file_upload_label = block.settings.title
                  endif
                %}

                <div
                  data-block-id="{{ block.id }}"
                  class="{{ spacing_classes }}" 
                  style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px;" 
                  {{ block.shopify_attributes }}
                >
                  {% render 'form-file-upload', id: field_id, form_id: product_form_id, name: field_name, has_label: true, label: file_upload_label, required: block.settings.file_upload_required, secondary_label: secondary_label, hint_text: block.settings.file_upload_hint %}
                </div>
              {% when 'checkbox' %}
                {% liquid
                  assign field_id = 'checkbox-field-' | append: block.id
                  assign label_formatted = block.settings.title | escape
                  assign field_name = 'properties[' | append: label_formatted | append: ']'

                  if block.settings.checkbox_required == true
                    assign checkbox_label = block.settings.title | append: ' *'
                  else 
                    assign checkbox_label = block.settings.title
                  endif

                  assign field_label_formatted = block.settings.title | remove: ' *'
                  assign error_text = 'general.forms.required_checkbox_error_with_label' | t: label: field_label_formatted | escape
                %}

                <div
                  data-block-id="{{ block.id }}"
                  class="{{ spacing_classes }}" 
                  style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px;" 
                  {{ block.shopify_attributes }}
                >
                  {% render 'form-input--checkbox', id: field_id, form_id: product_form_id, name: field_name, label_text: checkbox_label, required: block.settings.checkbox_required, hint_text: block.settings.checkbox_hint, error_message: error_text %}
                </div>
              {% when 'dropdown' %}
                {% liquid
                  assign field_id = 'dropdown-field-' | append: block.id
                  assign label_formatted = block.settings.title | escape
                  assign field_name = 'properties[' | append: label_formatted | append: ']'

                  if block.settings.dropdown_required == true
                    assign dropdown_label = block.settings.title | append: ' *'
                  else 
                    assign dropdown_label = block.settings.title
                  endif

                  assign field_label_formatted = block.settings.title | remove: ' *'
                  assign error_text = 'general.forms.required_dropdown_error_with_label' | t: label: field_label_formatted | escape
                %}

                <div
                  data-block-id="{{ block.id }}"
                  class="{{ spacing_classes }}" 
                  style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px;" 
                  {{ block.shopify_attributes }}
                >
                  {% render 'form-input--dropdown', id: field_id, form_id: product_form_id, name: field_name, label_text: dropdown_label, required: block.settings.dropdown_required, hint_text: block.settings.dropdown_hint, error_message: error_text, options: block.settings.dropdown_options %}
                </div>
              {% when 'radio_buttons' %}
                {% liquid
                  assign field_id = 'radio-field-' | append: block.id
                  assign label_formatted = block.settings.title | escape
                  assign field_name = 'properties[' | append: label_formatted | append: ']'
                %}

                <div
                  data-block-id="{{ block.id }}"
                  class="{{ spacing_classes }}" 
                  style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px;" 
                  {{ block.shopify_attributes }}
                >
                  {% render 'form-input--radio-buttons', id: field_id, form_id: product_form_id, name: field_name, label_text: label_formatted, hint_text: block.settings.radio_hint, options: block.settings.radio_options, required: false, preselect_first_option: true %}
                </div>
              {% when 'text_field' %}
                {% if block.settings.title != blank %}
                  {% liquid 
                    assign field_id = 'text-field-' | append: block.id
                    assign label_formatted = block.settings.title | escape
                    assign field_name = 'properties[' | append: label_formatted | append: ']'
                    
                    if block.settings.text_field_character_limit != blank
                      assign max_characters = block.settings.text_field_character_limit
                      assign max_characters_message = 'gift_cards.recipient.max_characters' | t: max: max_characters
                    else
                      assign max_characters = ''
                      assign max_characters_message = ''
                    endif

                    if block.settings.text_field_required == true
                      assign field_label = block.settings.title | append: ' *'
                    else 
                      assign field_label = block.settings.title
                    endif

                    assign field_label_formatted = block.settings.title | remove: ' *'
                    assign error_text = 'general.forms.required_input_error_with_label' | t: label: field_label_formatted | escape
                  %}
                  <div
                    data-block-id="{{ block.id }}"
                    class="{{ spacing_classes }} product-block-text-field" 
                    style="--custom-margin-bottom: {{ block.settings.margin_bottom }}px;" 
                    {{ block.shopify_attributes }}
                  >
                    {% if block.settings.text_field_size == 'single' %}
                      {% render 'form-input', type: 'text', id: field_id, form_id: product_form_id, name: field_name, has_label: true, animate_label: false, label_text: field_label, required: block.settings.text_field_required, max_characters: max_characters, data_aid: 'custom-text-field', secondary_label: max_characters_message, classes: 'width-full input-radius', error_message: error_text, label_class: 'label-font', hint_text: block.settings.text_field_hint %}
                    {% else %}
                      {% render 'form-input--textarea', id: field_id, form_id: product_form_id, name: field_name, has_label: true, animate_label: false, label_text: field_label, required: block.settings.text_field_required, max_characters: max_characters, data_aid: 'custom-text-field', secondary_label: max_characters_message, classes: 'width-full block-radius', rows: 6, error_message: error_text, label_class: 'label-font', hint_text: block.settings.text_field_hint %}
                    {% endif %}
                  </div>
                {% endif %}
            {% endcase %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
{% endif %}