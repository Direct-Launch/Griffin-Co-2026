{%- comment -%}
  Minimalist Top-Bar Filtering and Sorting
{%- endcomment -%}

<div class="border-y border-gray-200 bg-white sticky top-[88px] z-40 mb-10">
  <form id="CollectionFiltersForm" class="container mx-auto px-6 py-4 flex flex-col md:flex-row justify-between items-center gap-4">
    
    <!-- Left: Filters -->
    <div class="flex flex-wrap items-center gap-x-8 gap-y-4 w-full md:w-auto">
      <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Filter By</span>
      
      {%- for filter in collection.filters -%}
        <details class="relative group filter-group">
          <summary class="flex items-center gap-1.5 cursor-pointer list-none text-xs uppercase tracking-widest font-semibold text-gray-900 hover:text-gray-500 transition-colors">
            <span>{{ filter.label }}</span>
            {%- if filter.active_values.size > 0 -%}
              <span class="text-[10px] font-bold">({{ filter.active_values.size }})</span>
            {%- endif -%}
            <svg class="w-3 h-3 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </summary>
          
          <div class="absolute top-full left-0 mt-4 bg-white border border-gray-100 shadow-xl min-w-[280px] p-6 z-50 rounded-sm">
            <div class="flex justify-between items-center mb-5 pb-3 border-b border-gray-100">
              <span class="text-xs font-semibold uppercase tracking-widest text-gray-400">{{ filter.active_values.size }} Selected</span>
              <a href="{{ filter.url_to_remove }}" class="text-xs font-semibold uppercase tracking-widest text-gray-900 underline hover:text-gray-500 transition">Reset</a>
            </div>

            {%- case filter.type -%}
              {%- when 'boolean', 'list' -%}
                <ul class="space-y-3 max-h-[300px] overflow-y-auto pr-2 custom-scrollbar">
                  {%- for value in filter.values -%}
                    <li class="flex items-center gap-3">
                      <input type="checkbox"
                        name="{{ value.param_name }}"
                        value="{{ value.value }}"
                        id="Filter-{{ filter.label | escape }}-{{ forloop.index }}"
                        {% if value.active %}checked{% endif %}
                        {% if value.count == 0 and value.active == false %}disabled{% endif %}
                        class="w-4 h-4 border-gray-300 rounded-sm text-black focus:ring-black cursor-pointer disabled:opacity-30"
                      >
                      <label for="Filter-{{ filter.label | escape }}-{{ forloop.index }}" class="text-sm text-gray-600 cursor-pointer hover:text-black transition {% if value.count == 0 and value.active == false %}opacity-30{% endif %}">
                        {{ value.label | escape }} <span class="text-gray-400 ml-1">({{ value.count }})</span>
                      </label>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- when 'price_range' -%}
                <div class="flex items-center gap-4">
                  <div class="relative w-full">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-sm">{{ cart.currency.symbol }}</span>
                    <input name="{{ filter.min_value.param_name }}"
                      id="Filter-{{ filter.label | escape }}-GTE"
                      {%- if filter.min_value.value -%}
                        value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                      {%- endif -%}
                      type="number"
                      placeholder="0"
                      min="0"
                      max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                      class="w-full border border-gray-200 rounded-sm py-2.5 pl-8 pr-3 text-sm focus:border-black focus:ring-0 transition"
                    >
                  </div>
                  <span class="text-gray-400">-</span>
                  <div class="relative w-full">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-sm">{{ cart.currency.symbol }}</span>
                    <input name="{{ filter.max_value.param_name }}"
                      id="Filter-{{ filter.label | escape }}-LTE"
                      {%- if filter.max_value.value -%}
                        value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                      {%- endif -%}
                      type="number"
                      min="0"
                      max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                      placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                      class="w-full border border-gray-200 rounded-sm py-2.5 pl-8 pr-3 text-sm focus:border-black focus:ring-0 transition"
                    >
                  </div>
                </div>
            {%- endcase -%}
          </div>
        </details>
      {%- endfor -%}
    </div>

    <!-- Right: Sorting & Product Count -->
    <div class="flex items-center gap-6 w-full md:w-auto mt-4 md:mt-0 justify-between md:justify-end">
      <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400 hidden lg:block">{{ collection.products_count }} Products</span>
      
      <div class="flex items-center gap-3">
        <label for="SortBy" class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Sort By</label>
        <div class="relative">
          <select name="sort_by" id="SortBy" class="text-xs uppercase tracking-widest font-semibold text-gray-900 bg-transparent border-none focus:ring-0 cursor-pointer appearance-none pr-6 py-1 outline-none">
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value | escape }}" {% if option.value == sort_by %}selected="selected"{% endif %}>
                {{ option.name | escape }}
              </option>
            {%- endfor -%}
          </select>
          <svg class="w-3 h-3 text-gray-400 absolute right-0 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>
      </div>
    </div>

    {%- if collection.current_vendor or collection.current_type -%}
      <input type="hidden" name="q" value="{{ collection.current_vendor }}{{ collection.current_type }}">
    {%- endif -%}

  </form>
</div>

<!-- Active Filters Display (Below Bar) -->
<div class="container mx-auto px-6 flex flex-wrap gap-3 mb-10 -mt-6">
  {%- for filter in collection.filters -%}
    {%- for value in filter.active_values -%}
      <a href="{{ value.url_to_remove }}" class="inline-flex items-center gap-2 px-3 py-1.5 border border-gray-200 text-[10px] uppercase tracking-widest font-semibold text-gray-600 rounded-sm hover:border-black hover:text-black transition-colors">
        {{ value.label | escape }}
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </a>
    {%- endfor -%}
    {%- if filter.type == "price_range" -%}
      {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
        <a href="{{ filter.url_to_remove }}" class="inline-flex items-center gap-2 px-3 py-1.5 border border-gray-200 text-[10px] uppercase tracking-widest font-semibold text-gray-600 rounded-sm hover:border-black hover:text-black transition-colors">
          {%- if filter.min_value.value -%}{{ filter.min_value.value | money }}{%- else -%}{{ 0 | money }}{%- endif -%} - {%- if filter.max_value.value -%}{{ filter.max_value.value | money }}{%- else -%}{{ filter.range_max | money }}{%- endif -%}
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </a>
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
  
  {%- assign has_active_filter = false -%}
  {%- for filter in collection.filters -%}
    {%- if filter.active_values.size > 0 or filter.min_value.value != nil or filter.max_value.value != nil -%}
      {%- assign has_active_filter = true -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if has_active_filter -%}
    <a href="{{ collection.url }}?sort_by={{ collection.sort_by }}" class="inline-flex items-center px-3 py-1.5 text-[10px] uppercase tracking-widest font-semibold text-gray-400 hover:text-black transition-colors underline underline-offset-4 border border-transparent">
      Clear All Filters
    </a>
  {%- endif -%}
</div>

<script>
  document.getElementById('CollectionFiltersForm').addEventListener('change', function() {
    this.submit();
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', function(event) {
    const details = document.querySelectorAll('details.filter-group');
    details.forEach((detail) => {
      if (!detail.contains(event.target)) {
        detail.removeAttribute('open');
      }
    });
  });
</script>
<style>
  /* Optional custom scrollbar for long filter lists */
  .custom-scrollbar::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: #f9fafb; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 4px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #9ca3af; }
  
  details > summary { list-style: none; }
  details > summary::-webkit-details-marker { display: none; }
</style>