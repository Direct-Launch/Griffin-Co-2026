{% comment %}
	Renders a newsletter form section.

	Accepts:
		- section: The section object. Required.
		- form_id: The form ID. Required.
		- text_alignment: The text alignment. Optional.
		- desktop_heading_size: The desktop heading size class. Optional.
		- mobile_heading_size: The mobile heading size class. Optional.
		- desktop_text_size: The desktop text size percentage. Optional.
		- mobile_text_size: The mobile text size percentage. Optional.

	Usage:
		{% render 'newsletter-form', section: section, form_id: 'newsletter_section_form', text_alignment: section.settings.textAlignment %}
{% endcomment %}

{%- liquid
  assign heading_class = desktop_heading_size | default: 'h4'
  assign heading_class_mobile = mobile_heading_size | default: 'h4-mobile'
  assign text_scale = desktop_text_size | default: 100
  assign text_scale_mobile = mobile_text_size | default: 100
-%}

<div class="newsletter-wrapper--outer{% if text_alignment %} newsletter-text--{{ text_alignment }}{% endif %}{% if request.visual_preview_mode %} section-preview{% else %} show-on-scroll{% endif %}">
	<div class="newsletter-content--wrapper" data-animate data-animate-left-bold data-animate-order="1">
		{% if section.settings.newsletter_heading != empty %}
			<h3 class="newsletter-section--title {{ heading_class }} {{ heading_class_mobile }}">{{ section.settings.newsletter_heading }}</h3>
		{% endif %}

		{% if section.settings.newsletter_description != empty %}
			<div class="rte text-link-animated scaled-text" style="--text-scale: {{ text_scale }}; --text-scale-mobile: {{ text_scale_mobile }};">{{ section.settings.newsletter_description }}</div>
		{% endif %}
	</div>

	<div class="newsletter-form--wrapper" data-animate data-animate-right-bold data-animate-order="2">
		{% form 'customer', id: form_id %}
			{{ form.errors | default_errors }}

			{% unless form.posted_successfully? %}
				{% if customer and customer.email == form.email %}
					<div class="errors">
					<span role="alert" class="error">{{ 'general.newsletter_form_section.already_subscribed' | t }}</span>
					</div>
				{% endif %}
			{% endunless %}

			{% if form.posted_successfully? %}
				<p role="alert" class="note form-success success_section">{{ 'general.newsletter_form_section.thanks' | t }}</p>
			{% else %}
				<input type="hidden" name="contact[tags]" value="newsletter">

				<div id="newsletter-wrapper">
					<input id="newsletter_text" type="email" value="{% if customer %}{{ customer.email }}{% endif %}" placeholder="{{ 'general.newsletter_form_section.newsletter_text' | t }}" name="contact[email]" class="input-group-field email" aria-label="{{ 'general.newsletter_form_section.newsletter_email' | t }}" autocorrect="off" autocapitalize="off" pattern=".+@.+\..+" title="{{ 'general.forms.email_must_be_formatted_as_an_email' | t }}">
					<button id="newsletter_submit" type="submit" aria-label="{{ 'general.accessibility.contact_form.submit' | t }}" class="standalone-icon--wrapper">{% render 'theme-icon', icon: 'arrow-right', iconSize: 20 %}</button>
				</div>
			{% endif %}
		{% endform %}
	</div>
</div>