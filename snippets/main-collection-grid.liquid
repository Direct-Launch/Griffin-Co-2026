{% assign display-total-collection-products-number-rows = desktop_products_per_row | default: 6 %}
{% assign display-total-collection-products-per-row = products_per_page | default: 4 %}
{% assign display-total-collection-products-total = display-total-collection-products-number-rows | times: display-total-collection-products-per-row %}

{% paginate collection.products by display-total-collection-products-total %}

  <style>
    /* Minimalist Layout Adjustments */
    #CollectionProductGrid .product-grid--wrapper {
      display: flex;
      flex-wrap: wrap;
      margin-left: -20px;
    }
    #CollectionProductGrid .product-grid--wrapper .grid__item {
      padding-left: 20px;
      padding-bottom: 40px;
    }
    
    @media (min-width: 768px) {
      #CollectionProductGrid .product-grid--wrapper {
        margin-left: -40px;
      }
      #CollectionProductGrid .product-grid--wrapper .grid__item {
        padding-left: 40px;
        padding-bottom: 80px;
      }
    }

    /* Minimalist Pagination */
    .pagination {
      border-top: 1px solid #e5e7eb;
      padding-top: 40px;
      margin-top: 20px;
      text-align: center;
    }
    .pagination .page,
    .pagination .next,
    .pagination .prev {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      margin: 0 4px;
      font-size: 12px;
      color: #6b7280;
      border: 1px solid transparent;
      border-radius: 2px;
      transition: all 0.3s ease;
      text-decoration: none;
    }
    .pagination .page:not(.current):hover,
    .pagination .next:hover,
    .pagination .prev:hover {
      border-color: #d1d5db;
      color: #111827;
    }
    .pagination .page.current {
      border-color: #111827;
      background-color: #111827;
      color: #fff;
    }
    .pagination .next,
    .pagination .prev {
      border-color: #e5e7eb;
    }
  </style>

  {% capture paginate_style %}
    {% if paginate.pages > 1 %}
        {% endif %}
      </div>
    {%- endif -%}
  </div>

{% endpaginate %}