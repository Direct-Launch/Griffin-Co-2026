{% assign display-total-collection-products-number-rows = desktop_products_per_row | default: 6 %}
{% assign display-total-collection-products-per-row = products_per_page | default: 4 %}
{% assign display-total-collection-products-total = display-total-collection-products-number-rows | times: display-total-collection-products-per-row %}

{% paginate collection.products by display-total-collection-products-total %}

  <div id="ProductGridContainer" class="container mx-auto px-6 mb-24">
    {%- if collection.products.size == 0 -%}
      <div class="text-center py-32">
        <h2 class="text-2xl font-serif font-normal text-gray-900 mb-4">{{ 'collections.general.no_matches' | t }}</h2>
        <p class="text-sm text-gray-500 mb-6">Try adjusting your filters or search criteria.</p>
        <a href="{{ collection.url }}" class="inline-block py-3 px-8 rounded-sm text-xs font-semibold uppercase tracking-widest transition-colors bg-black text-white hover:bg-gray-800">Clear All Filters</a>
      </div>
    {%- else -%}
      
      <!-- Minimalist Product Grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-10 md:gap-x-8 md:gap-y-16">
        {%- for product in collection.products -%}
          <div class="grid__item relative group">
            {% render 'product-grid-item', product: product %}
          </div>
        {%- endfor -%}
      </div>

    {%- endif -%}

    <!-- Pagination -->
    {%- if paginate.pages > 1 -%}
      <div class="mt-20 pt-10 border-t border-gray-200 flex justify-center items-center">
        {% if pagination_options == 'pagination_infinite_scrolling' or pagination_options == 'pagination_load_more' %}
          <div class="pagination-loading" style="display: none;">
            {% render 'theme-icon', icon: 'circle-notch', iconClasses: 'spin fa-2x text-gray-400' %}
          </div>
          <div
            class="pagination pagination-infinite"
            data-paginate-items="{{ paginate.items }}"
            data-paginate-offset="{{ paginate.current_offset }}"
            data-paginate-size="{{ paginate.page_size }}"
          >
             <button class="py-3 px-8 rounded-sm text-xs font-semibold uppercase tracking-widest border border-black text-black hover:bg-black hover:text-white transition-colors">
               {{ 'collections.paginate.load_more' | t }}
             </button>
          </div>
        {% else %}
          <!-- Standard Numeric Pagination with minimalist styling -->
          <nav class="flex items-center gap-2 text-sm font-medium">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="w-10 h-10 flex items-center justify-center border border-gray-200 rounded-sm text-gray-500 hover:border-black hover:text-black transition">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
              </a>
            {%- endif -%}

            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="w-10 h-10 flex items-center justify-center border border-transparent rounded-sm text-gray-500 hover:border-gray-300 transition">{{ part.title }}</a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span class="w-10 h-10 flex items-center justify-center border border-black bg-black text-white rounded-sm">{{ part.title }}</span>
                {%- else -%}
                  <span class="w-10 h-10 flex items-center justify-center text-gray-400">{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="w-10 h-10 flex items-center justify-center border border-gray-200 rounded-sm text-gray-500 hover:border-black hover:text-black transition">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </a>
            {%- endif -%}
          </nav>
        {% endif %}
      </div>
    {%- endif -%}
  </div>

{% endpaginate %}