{% assign display-total-collection-products-number-rows = desktop_products_per_row %}
{% assign display-total-collection-products-per-row = products_per_page %}

{% assign display-total-collection-products-total = display-total-collection-products-number-rows | times: display-total-collection-products-per-row %}

{% paginate collection.products by display-total-collection-products-total %}

  <style>
    /* Minimalist Layout Adjustments */
    #CollectionProductGrid .product-grid--wrapper {
      display: flex;
      flex-wrap: wrap;
      margin-left: -20px;
    }
    #CollectionProductGrid .product-grid--wrapper .grid__item {
      padding-left: 20px;
      padding-bottom: 40px;
    }
    
    @media (min-width: 768px) {
      #CollectionProductGrid .product-grid--wrapper {
        margin-left: -40px;
      }
      #CollectionProductGrid .product-grid--wrapper .grid__item {
        padding-left: 40px;
        padding-bottom: 80px;
      }
    }

    /* Minimalist Pagination Overrides */
    .pagination {
      border-top: 1px solid #e5e7eb;
      padding-top: 40px;
      margin-top: 20px;
      text-align: center;
    }
    .pagination .page,
    .pagination .next,
    .pagination .prev {
      display: inline-flex !important;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      margin: 0 4px;
      font-size: 12px !important;
      color: #6b7280 !important;
      border: 1px solid transparent !important;
      border-radius: 2px;
      transition: all 0.3s ease;
      text-decoration: none;
      background: transparent !important;
    }
    .pagination .page:not(.current):hover,
    .pagination .next:hover,
    .pagination .prev:hover {
      border-color: #d1d5db !important;
      color: #111827 !important;
    }
    .pagination .page.current {
      border-color: #111827 !important;
      background-color: #111827 !important;
      color: #fff !important;
    }
    .pagination .next,
    .pagination .prev {
      border-color: #e5e7eb !important;
    }
  </style>

  {% capture paginate_style %}
    {% if paginate.pages > 1 %}
      {% if pagination_options == 'pagination_infinite_scrolling' %}
        <div style="display: none" class="pagination-loading">
          {% liquid 
            assign icon_fill = 'rgba(' | append: settings.color_primary_button_text.rgba | append: ')'
          %}
          {% render 'theme-icon', icon: 'circle-notch', iconClasses: 'spin flex-full', icon_fill: icon_fill, iconSize: '20' %}
          <span class="sr-only">{{ 'collections.paginate.load_more' | t }}</span>
        </div>
      {% endif %}

      <div
        class="pagination{% if pagination_options == 'pagination_infinite_scrolling' %} pagination-infinite{% elsif pagination_options == 'pagination_load_more' %} pagination--load-more{% endif %}"
        data-paginate-items="{{ paginate.items }}"
        data-paginate-offset="{{ paginate.current_offset }}"
        data-paginate-size="{{ paginate.page_size }}"
      >
        {% render 'pagination', paginate: paginate %}
      </div>
    {% endif %}
  {% endcapture %}

{% case desktop_products_per_row %}
  {% when 2 %}
    {% assign desktop_item_width = 'large--one-half' %}
  {% when 3 %}
    {% assign desktop_item_width = 'large--one-third' %}
  {% when 4 %}
    {% assign desktop_item_width = 'large--one-quarter' %}
  {% when 5 %}
    {% assign desktop_item_width = 'large--one-fifth' %}
  {% when 6 %}
    {% assign desktop_item_width = 'large--one-sixth' %}
{% endcase %}

{% assign tablet_item_width = 'medium--one-half' %}

{% case mobile_products_per_row %}
  {% when "1" %}
    {% assign mobile_item_width = 'small--one-whole' %}
  {% when "2" %}
    {% assign mobile_item_width = 'small--one-half' %}
{% endcase %}

{%- assign grid_item_width = desktop_item_width | append: ' ' | append: tablet_item_width | append: ' ' | append: mobile_item_width -%}

{% case desktop_products_per_row %}
  {% when 2 %}
    {% assign promo_desktop_width = 'large--one-whole' %}
  {% when 3 %}
    {% assign promo_desktop_width = 'large--two-thirds' %}
  {% when 4 %}
    {% assign promo_desktop_width = 'large--one-half' %}
  {% when 5 %}
    {% assign promo_desktop_width = 'large--two-fifths' %}
  {% when 6 %}
    {% assign promo_desktop_width = 'large--one-third' %}
{% endcase %}
{% assign promo_grid_item_width = promo_desktop_width | append: ' ' | append: tablet_item_width | append: ' small--one-whole' %}

  <div
    id="CollectionProductGrid"
    data-section-id="{{ section.id }}"
    data-wetheme-section-type="template--collection"
    data-wetheme-section-id="{{ section.id }}"
  >

    <div class="collection-style--grid">
      <div class="collection-main-body grid-uniform">

        <input type="hidden" id="grid_item_width_classes" value="{{ grid_item_width }}" />

        <div
          class="collection-main-body-inner product-grid--wrapper"
          data-grid-id="{{ section.id }}"
          id="template--collection"
        >
          {% for product in collection.products %}
            
            {% if section.settings.show_promo_block and forloop.index0 == desktop_products_per_row %}
              <div class="grid__item {{ promo_grid_item_width }} show-on-scroll">
                <div class="collection-promo-box" style="position: relative; height: 100%; min-height: 400px; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 40px; overflow: hidden; background-color: #1a1a1a;">
                  {% if section.settings.promo_image != blank %}
                    <img src="{{ section.settings.promo_image | image_url: width: 1200 }}" alt="{{ section.settings.promo_heading | escape }}" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; opacity: 0.8;" loading="lazy">
                  {% endif %}
                  
                  <div style="position: relative; z-index: 10; display: flex; flex-direction: column; align-items: center;">
                    {% if section.settings.promo_subtitle != blank %}
                      <span style="font-size: 10px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: #fff; margin-bottom: 12px; display: block;">{{ section.settings.promo_subtitle }}</span>
                    {% endif %}
                    
                    {% if section.settings.promo_heading != blank %}
                      <h4 style="font-family: var(--body-font-stack); font-weight: 400; color: #fff; margin-bottom: 16px; line-height: 1.2;">{{ section.settings.promo_heading }}</h4>
                    {% endif %}
                    
                    {% if section.settings.promo_text != blank %}
                      <div class="promo-rich-text rte" style="color: #fff; margin-bottom: 24px; line-height: 1.6; max-width: 450px;">
                        {{ section.settings.promo_text }}
                      </div>
                    {% endif %}
                    
                    {% if section.settings.promo_button_link != blank %}
                      <a href="{{ section.settings.promo_button_link }}" style="display: inline-block; border: 1px solid #fff; color: #fff; padding: 12px 24px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; text-decoration: none; transition: all 0.3s ease;" onmouseover="this.style.backgroundColor='#fff'; this.style.color='#000';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#fff';">
                        {{ section.settings.promo_button_text | default: 'Discover More' }}
                      </a>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endif %}

            <div class="grid__item {{ grid_item_width }} show-on-scroll">
              {%- liquid
                assign loading = 'lazy'
                if forloop.index <= desktop_products_per_row
                  assign loading = 'eager'
                endif

                assign animate_order = forloop.index | modulo: desktop_products_per_row
                if animate_order == 0
                  assign animate_order = desktop_products_per_row
                endif
                assign badge_anim_order = animate_order | plus: 2

                assign animate_order_ipad = forloop.index | modulo: 2
                if animate_order_ipad == 0
                  assign animate_order_ipad = 2
                endif
                assign badge_anim_order_ipad = animate_order_ipad | plus: 2

                assign animate_order_mobile = forloop.index | modulo: mobile_products_per_row
                if animate_order_mobile == 0
                  assign animate_order_mobile = mobile_products_per_row
                endif
                assign badge_anim_order_mobile = animate_order_mobile | plus: 2
              -%}
              {% render 'grid-view-item',
                product: product,
                collection: collection,
                enable_badges: settings.show_badges,
                grid_count_desktop: desktop_products_per_row,
                grid_count_mobile: mobile_products_per_row,
                loading: loading,
                badge_anim_order: badge_anim_order,
                badge_anim_order_mobile: badge_anim_order_mobile,
                badge_anim_order_ipad: badge_anim_order_ipad,
                animate: true,
                animate_order: animate_order,
                animate_order_ipad: animate_order_ipad,
                animate_order_mobile: animate_order_mobile,
                show_highlight: show_highlight,
                highlight_position: highlight_position,
                highlight_icon: highlight_icon,
                highlight_custom_icon: highlight_custom_icon,
                highlight_heading: highlight_heading,
                highlight_reference: highlight_reference,
                highlight_text_color: highlight_text_color,
                highlight_background_color: highlight_background_color,
                highlight_alignment: highlight_alignment,
                highlight_font_size: highlight_font_size,
                highlight_show_border: highlight_show_border,
                highlight_collapsible_tab: highlight_collapsible_tab,
                highlight_open_close_icon: highlight_open_close_icon,
                highlight_button_borders: highlight_button_borders %}
            </div>
          {% else %}
            {% if collection.handle == 'all' and collection.all_vendors.size == 0 and collection.all_types.size == 0 %}
              {% for i in (1..display-total-collection-products-total) %}
                {% capture svg_index %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                {% capture svg_index_reversed %}{% cycle 6, 5, 4, 3, 2, 1 %}{% endcapture %}
                <div class="grid__item {{ grid_item_width }}">
                  {% render 'grid-view-item-placeholder',
                    svg_index: svg_index,
                    svg_index_reversed: svg_index_reversed,
                    show_highlight: show_highlight,
                    highlight_position: highlight_position,
                    highlight_icon: highlight_icon,
                    highlight_custom_icon: highlight_custom_icon,
                    highlight_heading: highlight_heading,
                    highlight_reference: highlight_reference,
                    highlight_text_color: highlight_text_color,
                    highlight_background_color: highlight_background_color,
                    highlight_alignment: highlight_alignment,
                    highlight_font_size: highlight_font_size,
                    highlight_show_border: highlight_show_border,
                    highlight_collapsible_tab: highlight_collapsible_tab,
                    highlight_open_close_icon: highlight_open_close_icon,
                    highlight_button_borders: highlight_button_borders %}
                </div>
              {% endfor %}
            {% else %}
              {% comment %}
                If collection exists but is empty, display message
              {% endcomment %}
              <div class="grid__item">
                <p>{{ 'collections.general.no_matches' | t }}</p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
    {{ paginate_style }}
  </div>

{% endpaginate %}